<!-- Header -->
<div class="container py-4">
  <div class="page-header-card mb-4">
    <div class="header-content">
      <div class="d-flex align-items-center gap-3">
        <%= link_to participant_portal_training_programs_path, class: "btn-back" do %>
          <i class="bi bi-arrow-left"></i>
        <% end %>
        <div>
          <h4 class="header-title"><%= @training_program.title %></h4>
          <p class="header-subtitle">Training program details</p>
        </div>
      </div>
      <span class="status-badge status-<%= @training_program.status == 'completed' ? 'completed' : 'active' %>">
        <i class="bi bi-<%= @training_program.status == 'completed' ? 'check-circle-fill' : 'play-circle-fill' %> me-1"></i>
        <%= @training_program.status.titleize %>
      </span>
    </div>
  </div>

  <div class="row g-4">
    <!-- Program Details -->
    <div class="col-12 col-lg-8">
      <div class="details-card">
        <div class="card-header-modern">
          <div class="header-icon">
            <i class="bi bi-info-circle-fill"></i>
          </div>
          <div>
            <h5 class="mb-0">Program Details</h5>
            <span class="header-subtitle">Complete information</span>
          </div>
        </div>
        <div class="card-body-modern">
          <div class="description-section">
            <h6 class="section-label">Description</h6>
            <p class="description-text"><%= @training_program.description %></p>
          </div>

          <div class="row g-4">
            <div class="col-md-6">
              <div class="info-list">
                <div class="info-item">
                  <div class="info-icon">
                    <i class="bi bi-calendar-check"></i>
                  </div>
                  <div class="info-content">
                    <small class="info-label">Start Date</small>
                    <span class="info-value"><%= @training_program.start_date.strftime("%B %d, %Y") %></span>
                  </div>
                </div>
                <div class="info-item">
                  <div class="info-icon">
                    <i class="bi bi-calendar-x"></i>
                  </div>
                  <div class="info-content">
                    <small class="info-label">End Date</small>
                    <span class="info-value"><%= @training_program.end_date.strftime("%B %d, %Y") %></span>
                  </div>
                </div>
                <div class="info-item">
                  <div class="info-icon">
                    <i class="bi bi-clock-history"></i>
                  </div>
                  <div class="info-content">
                    <small class="info-label">Duration</small>
                    <span class="info-value"><%= (@training_program.end_date.to_date - @training_program.start_date.to_date).to_i + 1 %> days</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-md-6">
              <div class="info-list">
                <div class="info-item">
                  <div class="info-icon">
                    <i class="bi bi-people-fill"></i>
                  </div>
                  <div class="info-content">
                    <small class="info-label">Program Type</small>
                    <span class="info-value"><%= @training_program.program_type.titleize %></span>
                  </div>
                </div>
                <% if @training_program.section.present? %>
                  <div class="info-item">
                    <div class="info-icon">
                      <i class="bi bi-grid-3x3-gap-fill"></i>
                    </div>
                    <div class="info-content">
                      <small class="info-label">Section</small>
                      <span class="info-value"><%= @training_program.section.name %></span>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Trainer Information -->
    <div class="col-12 col-lg-4">
      <div class="trainer-card">
        <div class="card-header-modern">
          <div class="header-icon">
            <i class="bi bi-person-workspace"></i>
          </div>
          <div>
            <h5 class="mb-0">Trainer Information</h5>
            <span class="header-subtitle">Your instructor</span>
          </div>
        </div>
        <div class="card-body-modern">
          <div class="trainer-profile">
            <div class="trainer-avatar">
              <span class="avatar-text">
                <%= @training_program.trainer.user.first_name&.first&.upcase || @training_program.trainer.user.email.first.upcase %>
              </span>
            </div>
            <h5 class="trainer-name"><%= @training_program.trainer.user.full_name %></h5>
            <p class="trainer-specialization"><%= @training_program.trainer.specialization %></p>
          </div>

          <div class="info-list">
            <div class="info-item">
              <div class="info-icon">
                <i class="bi bi-mortarboard-fill"></i>
              </div>
              <div class="info-content">
                <small class="info-label">Qualification</small>
                <span class="info-value"><%= @training_program.trainer.qualification %></span>
              </div>
            </div>
            <div class="info-item">
              <div class="info-icon">
                <i class="bi bi-briefcase-fill"></i>
              </div>
              <div class="info-content">
                <small class="info-label">Experience</small>
                <span class="info-value"><%= pluralize(@training_program.trainer.experience_years, 'year') %></span>
              </div>
            </div>
            <div class="info-item">
              <div class="info-icon">
                <i class="bi bi-telephone-fill"></i>
              </div>
              <div class="info-content">
                <small class="info-label">Contact</small>
                <span class="info-value"><%= @training_program.trainer.phone_number %></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Feedback Section -->
      <% if @training_program.completed? %>
        <div class="feedback-card mt-4">
          <div class="card-header-modern">
            <div class="header-icon">
              <i class="bi bi-star-fill"></i>
            </div>
            <div>
              <h5 class="mb-0">Feedback</h5>
              <span class="header-subtitle">Your review</span>
            </div>
          </div>
          <div class="card-body-modern">
            <% participant_feedback = @training_program.feedbacks.find_by(participant: current_participant) %>
            <% if participant_feedback.present? %>
              <div class="feedback-display">
                <div class="rating-stars">
                  <% participant_feedback.rating.times do %>
                    <i class="bi bi-star-fill"></i>
                  <% end %>
                  <% (5 - participant_feedback.rating).times do %>
                    <i class="bi bi-star"></i>
                  <% end %>
                </div>
                <p class="feedback-content"><%= participant_feedback.content %></p>
              </div>
            <% else %>
              <div class="feedback-empty">
                <% if @training_program.has_registered_attendance?(current_participant) %>
                  <div class="empty-icon">
                    <i class="bi bi-chat-square-text"></i>
                  </div>
                  <p class="empty-text">You haven't provided feedback yet.</p>
                  <%= link_to new_participant_portal_training_program_feedback_path(@training_program), class: "btn-feedback" do %>
                    <i class="bi bi-star-fill me-1"></i> Give Feedback
                  <% end %>
                <% else %>
                  <div class="alert-modern">
                    <div class="alert-icon">
                      <i class="bi bi-info-circle-fill"></i>
                    </div>
                    <p class="alert-text">You need to have registered attendance in this program to provide feedback.</p>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<% content_for :styles do %>
<style>
  /* Page Header Card */
  .page-header-card {
    background: #ffffff;
    border-radius: 20px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(148, 163, 184, 0.1);
    padding: 1.75rem 2rem;
    position: relative;
    overflow: hidden;
  }
  .page-header-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #6366f1, #818cf8, #a855f7, #6366f1);
    background-size: 200% auto;
    animation: shimmer 3s linear infinite;
  }
  @keyframes shimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .btn-back {
    width: 44px;
    height: 44px;
    border: 1px solid rgba(99, 102, 241, 0.2);
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.05), rgba(129, 140, 248, 0.05));
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6366f1;
    transition: all 0.3s ease;
    text-decoration: none;
  }
  .btn-back:hover {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.15), rgba(129, 140, 248, 0.1));
    transform: scale(1.05);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);
    color: #6366f1;
  }
  .header-title {
    font-weight: 700;
    color: #1e293b;
    margin: 0;
    font-size: 1.5rem;
    letter-spacing: -0.02em;
  }
  .header-subtitle {
    font-size: 0.875rem;
    color: #94a3b8;
    margin: 0.25rem 0 0;
  }

  /* Cards */
  .details-card, .trainer-card, .feedback-card {
    background: #ffffff;
    border-radius: 20px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(148, 163, 184, 0.1);
    overflow: hidden;
    transition: all 0.3s ease;
  }
  .details-card:hover, .trainer-card:hover, .feedback-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }
  .card-header-modern {
    padding: 1.5rem 2rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.1);
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .card-header-modern .header-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(129, 140, 248, 0.1));
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6366f1;
    font-size: 1.25rem;
  }
  .card-header-modern h5 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1e293b;
  }
  .card-body-modern {
    padding: 2rem;
  }

  /* Description Section */
  .description-section {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.1);
  }
  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 1rem;
  }
  .description-text {
    color: #475569;
    line-height: 1.7;
    margin: 0;
  }

  /* Info List */
  .info-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .info-item {
    display: flex;
    align-items: start;
    gap: 1rem;
    padding: 1rem;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.02), rgba(168, 85, 247, 0.02));
    border: 1px solid rgba(148, 163, 184, 0.06);
    transition: all 0.3s ease;
  }
  .info-item:hover {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.05), rgba(168, 85, 247, 0.05));
    border-color: rgba(99, 102, 241, 0.15);
    transform: translateX(4px);
  }
  .info-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(129, 140, 248, 0.1));
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6366f1;
    font-size: 1.1rem;
    flex-shrink: 0;
  }
  .info-content {
    flex: 1;
  }
  .info-label {
    display: block;
    color: #94a3b8;
    font-size: 0.75rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }
  .info-value {
    display: block;
    color: #1e293b;
    font-weight: 600;
    font-size: 0.95rem;
  }

  /* Trainer Profile */
  .trainer-profile {
    text-align: center;
    padding: 1.5rem 0;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.1);
  }
  .trainer-avatar {
    width: 88px;
    height: 88px;
    background: linear-gradient(135deg, #6366f1 0%, #818cf8 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
    box-shadow: 0 8px 24px rgba(99, 102, 241, 0.3);
    animation: floatAvatar 3s ease-in-out infinite;
  }
  @keyframes floatAvatar {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  .avatar-text {
    color: white;
    font-size: 2rem;
    font-weight: 700;
  }
  .trainer-name {
    font-weight: 700;
    color: #1e293b;
    margin: 0 0 0.5rem;
    font-size: 1.15rem;
  }
  .trainer-specialization {
    color: #64748b;
    margin: 0;
    font-size: 0.9rem;
  }

  /* Status Badge */
  .status-badge {
    padding: 0.6rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }
  .status-completed {
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.15), rgba(16, 185, 129, 0.15));
    color: #059669;
  }
  .status-active {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(99, 102, 241, 0.15));
    color: #2563eb;
  }

  /* Feedback Display */
  .feedback-display {
    text-align: center;
    padding: 1rem 0;
  }
  .rating-stars {
    font-size: 1.75rem;
    color: #fbbf24;
    margin-bottom: 1.25rem;
  }
  .feedback-content {
    color: #475569;
    line-height: 1.7;
    margin: 0;
    font-size: 0.95rem;
  }

  /* Empty Feedback */
  .feedback-empty {
    text-align: center;
    padding: 1.5rem 0;
  }
  .empty-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(168, 85, 247, 0.1));
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
  }
  .empty-icon i {
    font-size: 2rem;
    color: #94a3b8;
  }
  .empty-text {
    color: #64748b;
    margin: 0 0 1.5rem;
    font-size: 0.95rem;
  }
  .btn-feedback {
    background: linear-gradient(135deg, #6366f1, #818cf8);
    border: none;
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }
  .btn-feedback:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.4);
    color: white;
  }

  /* Alert Modern */
  .alert-modern {
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.08), rgba(251, 191, 36, 0.08));
    border: 1px solid rgba(245, 158, 11, 0.2);
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    align-items: start;
    gap: 1rem;
  }
  .alert-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.15), rgba(251, 191, 36, 0.15));
    display: flex;
    align-items: center;
    justify-content: center;
    color: #d97706;
    font-size: 1.25rem;
    flex-shrink: 0;
  }
  .alert-text {
    color: #92400e;
    margin: 0;
    line-height: 1.6;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .header-content {
      flex-direction: column;
      align-items: start;
    }
    .trainer-avatar {
      width: 72px;
      height: 72px;
    }
    .avatar-text {
      font-size: 1.75rem;
    }
    .card-body-modern {
      padding: 1.5rem;
    }
  }
</style>
<% end %> 