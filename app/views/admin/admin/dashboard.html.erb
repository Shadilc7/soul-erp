<!-- Admin Dashboard -->
<!-- Key Metrics -->
<div class="row">
  <!-- Basic Stats -->
  <div class="col-md-3 mb-4 d-flex">
    <div class="card card-custom flex-fill kpi-card">
      <div class="card-body d-flex flex-column justify-content-between">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title mb-0">Institutes</h6>
            <h2 class="mt-2 mb-0"><%= @institutes_count %></h2>
          </div>
          <i class="bi bi-building fs-1 text-primary opacity-75"></i>
        </div>
        <%= link_to "View Institutes", admin_institutes_path, class: "btn btn-custom-primary mt-3" %>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-4 d-flex">
    <div class="card card-custom flex-fill kpi-card">
      <div class="card-body d-flex flex-column justify-content-between">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title mb-0">Institute Admins</h6>
            <h2 class="mt-2 mb-0"><%= @institute_admins_count %></h2>
          </div>
          <i class="bi bi-people fs-1 text-success opacity-75"></i>
        </div>
        <%= link_to "Manage Admins", admin_users_path, class: "btn btn-custom-primary mt-3" %>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-4 d-flex">
    <div class="card card-custom flex-fill kpi-card">
      <div class="card-body d-flex flex-column justify-content-between">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title mb-0">Active Programs</h6>
            <h2 class="mt-2 mb-0"><%= @active_programs_count %></h2>
            <!-- removed 'of X' for compactness -->
          </div>
          <i class="bi bi-journal-check fs-1 text-info opacity-75"></i>
        </div>
        <%= link_to 'View Programs', '/admin/programs_by_institute', class: 'btn btn-custom-primary mt-3' %>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-4 d-flex">
    <div class="card card-custom flex-fill kpi-card">
      <div class="card-body d-flex flex-column justify-content-between">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title mb-0">Participants</h6>
            <h2 class="mt-2 mb-0"><%= @total_participants %></h2>
          </div>
          <i class="bi bi-people-fill fs-1 text-primary opacity-75"></i>
        </div>
        <%= link_to 'View Participants', '/admin/participants_by_institute', class: 'btn btn-custom-primary mt-3' %>
      </div>
    </div>
  </div>
</div>

<!-- Secondary KPIs: Questions / Assignments / Trainers -->
<div class="row mt-3">
  <div class="col-md-3 mb-4 d-flex">
    <div class="card card-custom flex-fill kpi-card">
      <div class="card-body d-flex flex-column justify-content-between">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title mb-0">Questions</h6>
            <h2 class="mt-2 mb-0"><%= @total_questions || 0 %></h2>
          </div>
          <i class="bi bi-question-circle fs-1 text-warning opacity-75"></i>
        </div>
  <%= link_to 'View', '/admin/questions', class: 'btn btn-custom-primary mt-3' %>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-4 d-flex">
    <div class="card card-custom flex-fill kpi-card">
      <div class="card-body d-flex flex-column justify-content-between">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title mb-0">Assignments</h6>
            <h2 class="mt-2 mb-0"><%= @total_assignments || 0 %></h2>
          </div>
          <i class="bi bi-journal-text fs-1 text-info opacity-75"></i>
        </div>
  <%= link_to 'View', '/admin/assignments', class: 'btn btn-custom-primary mt-3' %>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-4 d-flex">
    <div class="card card-custom flex-fill kpi-card">
      <div class="card-body d-flex flex-column justify-content-between">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title mb-0">Trainers</h6>
            <h2 class="mt-2 mb-0"><%= (@total_trainers || Trainer.count) rescue 0 %></h2>
          </div>
          <i class="bi bi-person-badge fs-1 text-primary opacity-75"></i>
        </div>
  <%= link_to 'View', '/admin/trainers', class: 'btn btn-custom-primary mt-3' %>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-4 d-flex">
    <!-- Responses KPI -->
    <div class="card card-custom flex-fill kpi-card">
      <div class="card-body d-flex flex-column justify-content-between">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title mb-0">Responses</h6>
            <h2 class="mt-2 mb-0"><%= @total_responses || 0 %></h2>
          </div>
          <i class="bi bi-reply-all fs-1 text-danger opacity-75"></i>
        </div>
        <%= link_to 'View Responses', admin_responses_path, class: 'btn btn-custom-primary mt-3' %>
      </div>
    </div>
  </div>
</div>

<!-- Institution Charts -->
<div class="row">
  <!-- Participants Chart -->
  <div class="col-md-6 mb-4">
    <div class="chart-card-modern h-100">
      <div class="chart-header-modern">
        <div class="chart-icon-float">
          <i class="bi bi-people-fill"></i>
        </div>
        <div class="chart-title-modern">
          <h5>Institution-wise Participants</h5>
          <span class="chart-subtitle">Active & Total Enrollment</span>
        </div>
      </div>
      <div class="chart-body-modern">
        <canvas id="participantsChart" class="chart-canvas"></canvas>
      </div>
    </div>
  </div>

  <!-- Programs Chart -->
  <div class="col-md-6 mb-4">
    <div class="chart-card-modern h-100">
      <div class="chart-header-modern">
        <div class="chart-icon-float">
          <i class="bi bi-journal-check"></i>
        </div>
        <div class="chart-title-modern">
          <h5>Institution-wise Programs</h5>
          <span class="chart-subtitle">Program Overview</span>
        </div>
      </div>
      <div class="chart-body-modern">
        <canvas id="programsChart" class="chart-canvas small"></canvas>
      </div>
    </div>
  </div>
</div>


<!-- Other Statistics -->
<div class="row">
  <!-- Training Resources -->
  <div class="col-md-6 mb-4">
    <div class="chart-card-modern h-100">
      <div class="chart-header-modern">
        <div class="chart-icon-float">
          <i class="bi bi-box-seam"></i>
        </div>
        <div class="chart-title-modern">
          <h5>Training Resources</h5>
          <span class="chart-subtitle">Sections & Assignments</span>
        </div>
      </div>
      <div class="chart-body-modern">
        <canvas id="resourcesChart" class="chart-canvas chart-tall"></canvas>
      </div>
    </div>
  </div>

  <!-- Feedback Ratings -->
  <div class="col-md-6 mb-4">
    <div class="chart-card-modern h-100">
      <div class="chart-header-modern">
        <div class="chart-icon-float">
          <i class="bi bi-star-fill"></i>
        </div>
        <div class="chart-title-modern">
          <h5>Feedback Ratings</h5>
          <span class="chart-subtitle">Average Scores</span>
        </div>
      </div>
      <div class="chart-body-modern">
        <canvas id="ratingsChart" class="chart-canvas chart-tall"></canvas>
      </div>
    </div>
  </div>
</div>

<!-- Institution Details Table -->
<div class="row">
  <div class="col-12 mb-4">
    <div class="modern-table-card">
      <div class="modern-table-header">
        <div class="d-flex align-items-center gap-2">
          <div class="header-icon">
            <i class="bi bi-table"></i>
          </div>
          <div>
            <h5 class="mb-0">Institution Statistics</h5>
            <span class="header-subtitle">Comprehensive overview</span>
          </div>
        </div>
        <div class="btn-group">
          <button type="button" id="downloadCsvBtn" class="btn btn-sm btn-export csv" title="Download CSV">
            <i class="bi bi-file-earmark-spreadsheet"></i>
            <span class="d-none d-sm-inline ms-1">CSV</span>
          </button>
          <button type="button" id="downloadPdfBtn" class="btn btn-sm btn-export pdf" title="Download PDF">
            <i class="bi bi-file-earmark-pdf"></i>
            <span class="d-none d-sm-inline ms-1">PDF</span>
          </button>
        </div>
      </div>
      <div class="modern-table-body">
        <div class="table-responsive">
          <table class="table modern-table mb-0" id="institutions-stats-table">
            <thead>
              <tr>
                <th>Institution</th>
                <th>Programs</th>
                <th>Participants</th>
                <th>Sections</th>
                <th>Assignments</th>
                <th>Questions</th>
              </tr>
            </thead>
            <tbody>
              <% @institutes.each do |institute| %>
                <tr>
                  <td>
                    <div class="institute-name">
                      <i class="bi bi-building-fill me-2 text-primary"></i>
                      <%= institute[:name] %>
                    </div>
                  </td>
                  <td>
                    <span class="stat-value"><%= institute[:stats][:programs][:active] %> active</span>
                    <small class="stat-label">of <%= institute[:stats][:programs][:total] %> total</small>
                  </td>
                  <td>
                    <span class="stat-value"><%= institute[:stats][:participants][:active] %> active</span>
                    <small class="stat-label">of <%= institute[:stats][:participants][:total] %> total</small>
                  </td>
                  <td>
                    <span class="stat-value"><%= institute[:stats][:sections][:active] %> active</span>
                    <small class="stat-label">of <%= institute[:stats][:sections][:total] %> total</small>
                  </td>
                  <td><span class="badge stat-badge"><%= institute[:stats][:assignments][:total] %></span></td>
                  <td><span class="badge stat-badge"><%= institute[:stats][:questions] %></span></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Recent Activity and Recent Feedback (side-by-side) -->
<div class="row">
  <!-- Recent Activity -->
  <div class="col-md-6 mb-4">
    <div class="activity-card h-100">
      <div class="activity-card-header">
        <div class="header-icon">
          <i class="bi bi-clock-history"></i>
        </div>
        <div>
          <h5 class="mb-0">Recent Activity</h5>
          <span class="header-subtitle">Latest additions</span>
        </div>
      </div>
      <div class="activity-card-body">
        <div class="activity-list">
          <% @recent_institutes.each do |institute| %>
            <div class="activity-item">
              <div class="activity-icon-wrapper">
                <i class="bi bi-building"></i>
              </div>
              <div class="activity-content">
                <h6 class="activity-title"><%= institute.name %></h6>
                <p class="activity-time">
                  <i class="bi bi-clock me-1"></i>
                  Added <%= time_ago_in_words(institute.created_at) %> ago
                </p>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent Feedback -->
  <div class="col-md-6 mb-4">
    <div class="feedback-card h-100">
      <div class="feedback-card-header">
        <div class="header-icon">
          <i class="bi bi-chat-square-text"></i>
        </div>
        <div>
          <h5 class="mb-0">Recent Feedback</h5>
          <span class="header-subtitle">User reviews</span>
        </div>
      </div>
      <div class="feedback-card-body">
        <% @recent_feedbacks.each do |feedback| %>
          <div class="feedback-item">
            <div class="feedback-header">
              <h6 class="feedback-title"><%= feedback.training_program.title %></h6>
              <div class="rating-stars">
                <% feedback.rating.times do %>
                  <i class="bi bi-star-fill"></i>
                <% end %>
              </div>
            </div>
            <p class="feedback-content"><%= truncate(feedback.content, length: 100) %></p>
            <div class="feedback-meta">
              <i class="bi bi-person-circle me-1"></i>
              <%= feedback.participant.user.full_name %>
              <span class="meta-divider">•</span>
              <i class="bi bi-clock me-1"></i>
              <%= time_ago_in_words(feedback.created_at) %> ago
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Recent Training Programs (full width) -->
<div class="row">
  <div class="col-12 mb-4">
    <div class="programs-card">
      <div class="programs-card-header">
        <div class="d-flex align-items-center gap-2">
          <div class="header-icon">
            <i class="bi bi-mortarboard"></i>
          </div>
          <div>
            <h5 class="mb-0">Recent Training Programs</h5>
            <span class="header-subtitle">Latest program activities</span>
          </div>
        </div>
      </div>
      <div class="programs-card-body">
        <div class="table-responsive">
          <table class="table modern-programs-table mb-0">
            <thead>
              <tr>
                <th>Program</th>
                <th>Institute</th>
                <th>Trainer</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% @recent_programs.each do |program| %>
                <tr>
                  <td>
                    <div class="program-name">
                      <i class="bi bi-book me-2 text-info"></i>
                      <%= program.title %>
                    </div>
                  </td>
                  <td class="institute-cell"><%= program.institute.name %></td>
                  <td>
                    <div class="trainer-info">
                      <i class="bi bi-person-badge me-1"></i>
                      <%= program.trainer.user.full_name %>
                    </div>
                  </td>
                  <td>
                    <span class="status-badge status-<%= program.status == 'ongoing' ? 'active' : 'completed' %>">
                      <i class="bi bi-<%= program.status == 'ongoing' ? 'play-circle' : 'check-circle' %> me-1"></i>
                      <%= program.status.titleize %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>



<% content_for :styles do %>
  <style>
    .card-custom {
      border: none;
      box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }
    .card-custom .card-header {
      background-color: #f8f9fa;
      border-bottom: 1px solid rgba(0,0,0,.125);
    }
    .btn-custom-primary {
      color: var(--bs-primary);
      background-color: rgba(var(--bs-primary-rgb), 0.1);
      border: none;
    }
    .btn-custom-primary:hover {
      color: #fff;
      background-color: var(--bs-primary);
    }
    .icon-primary {
      color: var(--bs-primary);
      opacity: 0.75;
    }
    /* KPI card consistent sizing and responsive tweaks */
    .kpi-card {
      min-height: 120px;
      padding: 1rem 1.1rem 0.8rem 1.1rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    /* Export buttons on Institution Statistics header */
    .btn-export {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      padding: .35rem .6rem;
      border-radius: .45rem;
      color: #fff;
      border: none;
      box-shadow: 0 2px 6px rgba(16,24,40,0.06);
      font-weight: 600;
      transition: transform .08s ease, box-shadow .12s ease, opacity .12s ease;
    }
    .btn-export:active { transform: translateY(1px); }
    .btn-export.csv { background: linear-gradient(135deg,#10b981 0%,#059669 100%); }
    .btn-export.csv:hover { filter: brightness(.98); }
    .btn-export.pdf { background: linear-gradient(135deg,#ef4444 0%,#b91c1c 100%); }
    .btn-export.pdf:hover { filter: brightness(.98); }
    .btn-export i { font-size: 1rem; line-height: 1; }

    /* Modern Clean Chart Cards */
    @keyframes floatSoft {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-6px); }
    }
    
    @keyframes fadeInScale {
      from {
        opacity: 0;
        transform: scale(0.95);
      }
      to {
        opacity: 1;
        transform: scale(1);
      }
    }
    
    @keyframes shimmer {
      0% { background-position: -200% center; }
      100% { background-position: 200% center; }
    }
    
    .chart-card-modern {
      background: #ffffff;
      border-radius: 24px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04), 0 1px 2px rgba(0, 0, 0, 0.06);
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      animation: fadeInScale 0.5s ease-out;
      overflow: hidden;
      position: relative;
    }
    
    .chart-card-modern:hover {
      transform: translateY(-6px);
      box-shadow: 0 12px 40px rgba(102, 126, 234, 0.12), 0 4px 8px rgba(0, 0, 0, 0.08);
    }
    
    .chart-card-modern::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, #667eea, #764ba2, #f093fb, #667eea);
      background-size: 200% auto;
      animation: shimmer 3s linear infinite;
    }
    
    .chart-header-modern {
      padding: 2rem 2rem 1.25rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      position: relative;
    }
    
    .chart-icon-float {
      width: 52px;
      height: 52px;
      border-radius: 14px;
      background: linear-gradient(135deg, rgba(102, 126, 234, 0.08), rgba(118, 75, 162, 0.08));
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      animation: floatSoft 3.5s ease-in-out infinite;
      transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
      position: relative;
    }
    
    .chart-icon-float::before {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 14px;
      background: linear-gradient(135deg, #667eea, #764ba2);
      opacity: 0;
      transition: opacity 0.35s ease;
    }
    
    .chart-card-modern:hover .chart-icon-float {
      transform: scale(1.1) rotate(-5deg);
    }
    
    .chart-card-modern:hover .chart-icon-float::before {
      opacity: 1;
    }
    
    .chart-icon-float i {
      font-size: 1.4rem;
      color: #667eea;
      transition: all 0.35s ease;
      position: relative;
      z-index: 1;
    }
    
    .chart-card-modern:hover .chart-icon-float i {
      color: white;
      transform: scale(1.1);
    }
    
    .chart-title-modern {
      flex: 1;
    }
    
    .chart-title-modern h5 {
      margin: 0;
      font-size: 1.05rem;
      font-weight: 700;
      color: #1e293b;
      letter-spacing: -0.01em;
      line-height: 1.4;
    }
    
    .chart-subtitle {
      font-size: 0.8rem;
      color: #94a3b8;
      font-weight: 500;
      display: block;
      margin-top: 0.3rem;
      letter-spacing: 0.01em;
    }
    
    .chart-body-modern {
      padding: 0 2rem 2rem;
    }
    
    /* Chart sizing and polish */
    .chart-canvas { height: 360px !important; width: 100% !important; }
    .chart-canvas.small { height: 320px !important; }
    /* Taller variant for the resources and ratings charts */
    .chart-canvas.chart-tall { height: 480px !important; }
    /* Scrollable card body for lists */
    .card-body.scrollable { max-height: 360px; overflow-y: auto; padding-right: 0.5rem; }
    .card.card-custom.h-100 .card-body { padding: 1.25rem; }
    /* Subtle container background for charts */
    .card.card-custom .card-body { background: linear-gradient(180deg, #ffffff, #fbfdff); border-radius: 6px; }

    /* Modern Table Card and Other Sections */
    .modern-table-card, .activity-card, .feedback-card, .programs-card {
      background: #ffffff;
      border-radius: 24px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04), 0 1px 2px rgba(0, 0, 0, 0.06);
      overflow: hidden;
      position: relative;
    }
    .modern-table-card::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, #667eea, #764ba2, #f093fb, #667eea);
      background-size: 200% auto;
      animation: shimmer 3s linear infinite;
    }
    .activity-card::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, #11998e, #38ef7d);
    }
    .feedback-card::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, #fbbf24, #f59e0b);
    }
    .programs-card::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: linear-gradient(90deg, #a855f7, #ec4899, #f093fb, #a855f7);
      background-size: 200% auto;
      animation: shimmer 3s linear infinite;
    }
    .modern-table-header, .activity-card-header, .feedback-card-header, .programs-card-header {
      padding: 1.75rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .activity-card-header, .feedback-card-header, .programs-card-header {
      padding-bottom: 1.25rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.1);
    }
    .modern-table-header {
      border-bottom: 1px solid rgba(148, 163, 184, 0.1);
    }
    .modern-table-header .header-icon, .activity-card-header .header-icon, .feedback-card-header .header-icon, .programs-card-header .header-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
      display: flex;
      align-items: center;
      justify-content: center;
      color: #667eea;
      font-size: 1.25rem;
    }
    .modern-table-header h5, .activity-card-header h5, .feedback-card-header h5, .programs-card-header h5 {
      margin: 0;
      font-size: 1.1rem;
      font-weight: 700;
      color: #1e293b;
    }
    .header-subtitle {
      font-size: 0.75rem;
      color: #94a3b8;
      font-weight: 500;
      display: block;
      margin-top: 0.2rem;
    }
    .modern-table-body, .programs-card-body {
      padding: 0;
    }
    .modern-table thead th {
      background: linear-gradient(135deg, rgba(102, 126, 234, 0.08), rgba(118, 75, 162, 0.12), rgba(240, 147, 251, 0.08));
      border: none;
      color: #475569;
      font-weight: 600;
      font-size: 0.8rem;
      text-transform: uppercase;
