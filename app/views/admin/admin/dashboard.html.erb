            ticks: {
              color: '#94a3b8',
              font: { size: 12, weight: '500' },
              precision: 0,
              padding: 12
            }
          }
        }
      }
    });
  }
  function initProgramsChart() {
    const canvas = document.getElementById('programsChart');
