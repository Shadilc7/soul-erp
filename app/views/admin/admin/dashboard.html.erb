<script>
// CSV and Print-to-PDF helpers for Institution Statistics table
document.addEventListener('turbo:load', function() {
  function downloadTableCSV(tableId, filename) {
    const table = document.getElementById(tableId);
    if (!table) return;
    const rows = [];
    const headers = Array.from(table.querySelectorAll('thead th')).map(th => th.textContent.trim());
    rows.push(headers.map(h => '"' + h.replace(/"/g, '""') + '"').join(','));

    table.querySelectorAll('tbody tr').forEach(tr => {
      const cols = Array.from(tr.querySelectorAll('td')).map(td => td.innerText.trim());
      rows.push(cols.map(c => '"' + c.replace(/"/g, '""') + '"').join(','));
    });

    const csv = rows.join('\n');
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = filename;
    document.body.appendChild(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(link.href);
  }

  function openTablePrintWindow(tableId, title) {
    const table = document.getElementById(tableId);
    if (!table) return;
    const w = window.open('', '_blank');
    const doc = w.document.open();
    const style = `
      <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; margin: 20px; }
        h1 { font-size: 18px; margin-bottom: 12px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        th { background: #f8f9fa; }
      </style>
    `;
    const html = `<!doctype html><html><head><meta charset="utf-8"><title>${title}</title>${style}</head><body><h1>${title}</h1>${table.outerHTML}</body></html>`;
    doc.write(html);
    doc.close();
    // Give the new window a moment to render before printing
    setTimeout(() => { w.focus(); w.print(); }, 250);
  }

  const csvBtn = document.getElementById('downloadCsvBtn');
  const pdfBtn = document.getElementById('downloadPdfBtn');
  if (csvBtn) csvBtn.addEventListener('click', () => downloadTableCSV('institutions-stats-table', 'institution_statistics.csv'));
  if (pdfBtn) pdfBtn.addEventListener('click', () => openTablePrintWindow('institutions-stats-table', 'Institution Statistics'));
});
</script>