  function initRatingsChart() {
    const canvas = document.getElementById('ratingsChart');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');

    const gradient = ctx.createLinearGradient(0, 0, 0, canvas.height);
    gradient.addColorStop(0, 'rgba(251, 191, 36, 0.35)');
    gradient.addColorStop(1, 'rgba(251, 191, 36, 0.02)');

    new Chart(canvas, {
      type: 'line',
      plugins: [{
        id: 'customCanvasBackgroundStars',
        beforeDraw: (chart) => {
          const ctx = chart.ctx;
          const chartArea = chart.chartArea;
          
          // Create warm gradient background
          const gradient = ctx.createLinearGradient(chartArea.left, chartArea.top, chartArea.right, chartArea.bottom);
          gradient.addColorStop(0, 'rgba(251, 191, 36, 0.02)');
          gradient.addColorStop(0.5, 'rgba(245, 158, 11, 0.03)');
          gradient.addColorStop(1, 'rgba(251, 191, 36, 0.02)');
          
          ctx.save();
          ctx.fillStyle = gradient;
          ctx.fillRect(chartArea.left, chartArea.top, chartArea.right - chartArea.left, chartArea.bottom - chartArea.top);
          
          // Add sparkle/star pattern
          ctx.fillStyle = 'rgba(251, 191, 36, 0.08)';
          const stars = [
            { x: 0.15, y: 0.2 }, { x: 0.3, y: 0.4 }, { x: 0.5, y: 0.15 },
            { x: 0.65, y: 0.6 }, { x: 0.8, y: 0.3 }, { x: 0.9, y: 0.7 },
            { x: 0.25, y: 0.75 }, { x: 0.45, y: 0.85 }, { x: 0.7, y: 0.5 }
          ];
          
          stars.forEach(star => {
            const x = chartArea.left + (chartArea.right - chartArea.left) * star.x;
            const y = chartArea.top + (chartArea.bottom - chartArea.top) * star.y;
            const size = 3;
            
            // Draw star shape
            ctx.beginPath();
            for (let i = 0; i < 5; i++) {
              const angle = (i * 4 * Math.PI) / 5 - Math.PI / 2;
              const radius = i % 2 === 0 ? size : size / 2;
              const px = x + Math.cos(angle) * radius;
              const py = y + Math.sin(angle) * radius;
              if (i === 0) ctx.moveTo(px, py);
              else ctx.lineTo(px, py);
            }
            ctx.closePath();
            ctx.fill();
          });
          ctx.restore();
        }
      }],
      data: {
        labels: stats.labels,
        datasets: [{
          label: 'Average Rating',
          data: stats.avg_ratings,
          borderColor: '#fbbf24',
          backgroundColor: gradient,
          fill: true,
