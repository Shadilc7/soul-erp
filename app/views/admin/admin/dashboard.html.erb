            boxPadding: 6,
            borderColor: 'rgba(102, 126, 234, 0.2)',
            borderWidth: 1
          }
        },
        layout: { padding: { top: 12, right: 12, bottom: 12, left: 12 } },
        scales: {
          x: {
            grid: { display: false },
            border: { display: false },
            ticks: {
              color: '#64748b',
              font: { size: 12, weight: '500' },
              maxRotation: 0,
              padding: 8
            }
          },
          y: {
            beginAtZero: true,
            border: { display: false },
            grid: {
              color: 'rgba(148, 163, 184, 0.08)',
              lineWidth: 1.5,
              drawTicks: false
            },
            ticks: {
              color: '#94a3b8',
