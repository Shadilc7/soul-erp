    gradSections.addColorStop(0, '#a855f7');
    gradSections.addColorStop(1, '#ec4899');

    const gradAssignments = ctx.createLinearGradient(0, 0, 0, canvas.height);
    gradAssignments.addColorStop(0, '#3b82f6');
    gradAssignments.addColorStop(1, '#06b6d4');

    new Chart(canvas, {
      type: 'bar',
      plugins: [{
        id: 'customCanvasBackgroundCircles',
        beforeDraw: (chart) => {
          const ctx = chart.ctx;
          const chartArea = chart.chartArea;
          
          // Create smooth gradient background
          const gradient = ctx.createLinearGradient(chartArea.left, chartArea.top, chartArea.right, chartArea.bottom);
          gradient.addColorStop(0, 'rgba(59, 130, 246, 0.02)');
          gradient.addColorStop(0.5, 'rgba(6, 182, 212, 0.03)');
          gradient.addColorStop(1, 'rgba(168, 85, 247, 0.02)');
          
          ctx.save();
          ctx.fillStyle = gradient;
          ctx.fillRect(chartArea.left, chartArea.top, chartArea.right - chartArea.left, chartArea.bottom - chartArea.top);
          
          // Add floating circles pattern
          const circles = [
            { x: 0.2, y: 0.3, r: 40, opacity: 0.04 },
            { x: 0.6, y: 0.2, r: 30, opacity: 0.05 },
