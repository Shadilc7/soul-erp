          ctx.save();
          ctx.fillStyle = gradient;
          ctx.fillRect(chartArea.left, chartArea.top, chartArea.right - chartArea.left, chartArea.bottom - chartArea.top);
          
          // Add diagonal lines
          ctx.strokeStyle = 'rgba(240, 147, 251, 0.08)';
          ctx.lineWidth = 1;
          for (let i = chartArea.left - chartArea.bottom; i < chartArea.right; i += 40) {
            ctx.beginPath();
            ctx.moveTo(i, chartArea.bottom);
            ctx.lineTo(i + (chartArea.bottom - chartArea.top), chartArea.top);
            ctx.stroke();
