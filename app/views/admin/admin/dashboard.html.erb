      options: {
        animation: {
          duration: 1200,
          easing: 'easeInOutQuart',
          delay: (context) => context.dataIndex * 80
        },
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: {
            position: 'bottom',
            align: 'center',
            labels: {
              usePointStyle: true,
              pointStyle: 'circle',
              padding: 20,
              boxWidth: 8,
              boxHeight: 8,
              font: { size: 13, weight: '600' },
              color: '#64748b'
            }
          },
          tooltip: {
            backgroundColor: 'rgba(15, 23, 42, 0.95)',
            titleColor: '#ffffff',
            bodyColor: '#e2e8f0',
            padding: 14,
            cornerRadius: 10,
            titleFont: { size: 14, weight: '700' },
            bodyFont: { size: 13, weight: '500' },
            displayColors: true,
            boxWidth: 12,
            boxHeight: 12,
            boxPadding: 6,
            borderColor: 'rgba(102, 126, 234, 0.2)',
            borderWidth: 1
          }
        },
        layout: { padding: { top: 12, right: 12, bottom: 12, left: 12 } },
        scales: {
          x: {
            grid: { display: false },
            border: { display: false },
            ticks: {
              color: '#64748b',
              font: { size: 12, weight: '500' },
              maxRotation: 0,
              autoSkip: false,
              padding: 8
            }
          },
          y: {
            beginAtZero: true,
            border: { display: false, dash: [5, 5] },
            grid: {
              color: 'rgba(148, 163, 184, 0.08)',
              lineWidth: 1.5,
              drawTicks: false
