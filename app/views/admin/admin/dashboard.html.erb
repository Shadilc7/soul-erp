<!-- Admin Dashboard -->
<!-- Key Metrics -->
<div class="row">
  <!-- Basic Stats -->
  <div class="col-md-3 mb-4 d-flex">
    <div class="card card-custom flex-fill kpi-card">
      <div class="card-body d-flex flex-column justify-content-between">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title mb-0">Institutes</h6>
            <h2 class="mt-2 mb-0"><%= @institutes_count %></h2>
          </div>
          <i class="bi bi-building fs-1 text-primary opacity-75"></i>
        </div>
        <%= link_to "View Institutes", admin_institutes_path, class: "btn btn-custom-primary mt-3" %>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-4 d-flex">
    <div class="card card-custom flex-fill kpi-card">
      <div class="card-body d-flex flex-column justify-content-between">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title mb-0">Institute Admins</h6>
            <h2 class="mt-2 mb-0"><%= @institute_admins_count %></h2>
          </div>
          <i class="bi bi-people fs-1 text-success opacity-75"></i>
        </div>
        <%= link_to "Manage Admins", admin_users_path, class: "btn btn-custom-primary mt-3" %>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-4 d-flex">
    <div class="card card-custom flex-fill kpi-card">
      <div class="card-body d-flex flex-column justify-content-between">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title mb-0">Active Programs</h6>
            <h2 class="mt-2 mb-0"><%= @active_programs_count %></h2>
            <!-- removed 'of X' for compactness -->
          </div>
          <i class="bi bi-journal-check fs-1 text-info opacity-75"></i>
        </div>
        <%= link_to 'View Programs', '/admin/programs_by_institute', class: 'btn btn-custom-primary mt-3' %>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-4 d-flex">
    <div class="card card-custom flex-fill kpi-card">
      <div class="card-body d-flex flex-column justify-content-between">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title mb-0">Participants</h6>
            <h2 class="mt-2 mb-0"><%= @total_participants %></h2>
          </div>
          <i class="bi bi-people-fill fs-1 text-primary opacity-75"></i>
        </div>
        <%= link_to 'View Participants', '/admin/participants_by_institute', class: 'btn btn-custom-primary mt-3' %>
      </div>
    </div>
  </div>
</div>

<!-- Secondary KPIs: Questions / Assignments / Trainers -->
<div class="row mt-3">
  <div class="col-md-3 mb-4 d-flex">
    <div class="card card-custom flex-fill kpi-card">
      <div class="card-body d-flex flex-column justify-content-between">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title mb-0">Questions</h6>
            <h2 class="mt-2 mb-0"><%= @total_questions || 0 %></h2>
          </div>
          <i class="bi bi-question-circle fs-1 text-warning opacity-75"></i>
        </div>
  <%= link_to 'View', '/admin/questions', class: 'btn btn-custom-primary mt-3' %>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-4 d-flex">
    <div class="card card-custom flex-fill kpi-card">
      <div class="card-body d-flex flex-column justify-content-between">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title mb-0">Assignments</h6>
            <h2 class="mt-2 mb-0"><%= @total_assignments || 0 %></h2>
          </div>
          <i class="bi bi-journal-text fs-1 text-info opacity-75"></i>
        </div>
  <%= link_to 'View', '/admin/assignments', class: 'btn btn-custom-primary mt-3' %>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-4 d-flex">
    <div class="card card-custom flex-fill kpi-card">
      <div class="card-body d-flex flex-column justify-content-between">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title mb-0">Trainers</h6>
            <h2 class="mt-2 mb-0"><%= (@total_trainers || Trainer.count) rescue 0 %></h2>
          </div>
          <i class="bi bi-person-badge fs-1 text-primary opacity-75"></i>
        </div>
  <%= link_to 'View', '/admin/trainers', class: 'btn btn-custom-primary mt-3' %>
      </div>
    </div>
  </div>

  <div class="col-md-3 mb-4 d-flex">
    <!-- Responses KPI -->
    <div class="card card-custom flex-fill kpi-card">
      <div class="card-body d-flex flex-column justify-content-between">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="card-title mb-0">Responses</h6>
            <h2 class="mt-2 mb-0"><%= @total_responses || 0 %></h2>
            <small class="text-muted">Distinct assignment-participant pairs</small>
          </div>
          <i class="bi bi-reply-all fs-1 text-danger opacity-75"></i>
        </div>
        <%= link_to 'View Responses', admin_responses_path, class: 'btn btn-custom-primary mt-3' %>
      </div>
    </div>
  </div>
</div>

<!-- Institution Charts -->
<div class="row">
  <!-- Participants Chart -->
  <div class="col-md-6 mb-4">
    <div class="card card-custom h-100">
      <div class="card-header bg-light py-3">
        <h5 class="card-title mb-0">Institution-wise Participants</h5>
      </div>
      <div class="card-body">
        <canvas id="participantsChart" class="chart-canvas"></canvas>
      </div>
    </div>
  </div>

  <!-- Programs Chart -->
  <div class="col-md-6 mb-4">
    <div class="card card-custom h-100">
      <div class="card-header bg-light py-3">
        <h5 class="card-title mb-0">Institution-wise Programs</h5>
      </div>
      <div class="card-body">
        <canvas id="programsChart" class="chart-canvas small"></canvas>
      </div>
    </div>
  </div>
</div>


<!-- Other Statistics -->
<div class="row">
  <!-- Training Resources -->
  <div class="col-md-6 mb-4">
    <div class="card card-custom h-100">
      <div class="card-header bg-light py-3">
        <h5 class="card-title mb-0">Training Resources by Institution</h5>
      </div>
      <div class="card-body">
  <canvas id="resourcesChart" class="chart-canvas chart-tall"></canvas>
      </div>
    </div>
  </div>

  <!-- Feedback Ratings -->
  <div class="col-md-6 mb-4">
    <div class="card card-custom h-100">
      <div class="card-header bg-light py-3">
        <h5 class="card-title mb-0">Average Feedback Ratings</h5>
      </div>
      <div class="card-body">
  <canvas id="ratingsChart" class="chart-canvas chart-tall"></canvas>
      </div>
    </div>
  </div>
</div>

<!-- Institution Details Table -->
<div class="row">
  <div class="col-12 mb-4">
    <div class="card card-custom">
      <div class="card-header bg-light py-3 d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Institution Statistics</h5>
        <div class="btn-group">
          <button type="button" id="downloadCsvBtn" class="btn btn-sm btn-export csv" title="Download CSV">
            <i class="bi bi-file-earmark-spreadsheet"></i>
            <span class="d-none d-sm-inline ms-1">CSV</span>
          </button>
          <button type="button" id="downloadPdfBtn" class="btn btn-sm btn-export pdf" title="Download PDF">
            <i class="bi bi-file-earmark-pdf"></i>
            <span class="d-none d-sm-inline ms-1">PDF</span>
          </button>
        </div>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table mb-0" id="institutions-stats-table">
            <thead class="table-light">
              <tr>
                <th>Institution</th>
                <th>Programs</th>
                <th>Participants</th>
                <th>Sections</th>
                <th>Assignments</th>
                <th>Questions</th>
              </tr>
            </thead>
            <tbody>
              <% @institutes.each do |institute| %>
                <tr>
                  <td><%= institute[:name] %></td>
                  <td>
                    <span class="d-block"><%= institute[:stats][:programs][:active] %> active</span>
                    <small class="text-muted">of <%= institute[:stats][:programs][:total] %> total</small>
                  </td>
                  <td>
                    <span class="d-block"><%= institute[:stats][:participants][:active] %> active</span>
                    <small class="text-muted">of <%= institute[:stats][:participants][:total] %> total</small>
                  </td>
                  <td>
                    <span class="d-block"><%= institute[:stats][:sections][:active] %> active</span>
                    <small class="text-muted">of <%= institute[:stats][:sections][:total] %> total</small>
                  </td>
                  <td><%= institute[:stats][:assignments][:total] %></td>
                  <td><%= institute[:stats][:questions] %></td>
                  <%# Actions column removed — downloads available in header %>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Recent Activity and Recent Feedback (side-by-side) -->
<div class="row">
  <!-- Recent Activity -->
  <div class="col-md-6 mb-4">
    <div class="card card-custom h-100">
      <div class="card-header bg-light py-3">
        <h5 class="card-title mb-0">Recent Activity</h5>
      </div>
      <div class="card-body scrollable">
        <div class="list-group list-group-flush">
          <% @recent_institutes.each do |institute| %>
            <div class="list-group-item border-0 px-0">
              <div class="d-flex align-items-center">
                <div class="flex-shrink-0">
                  <div class="bg-light rounded p-2">
                    <i class="bi bi-building text-primary"></i>
                  </div>
                </div>
                <div class="flex-grow-1 ms-3">
                  <h6 class="mb-1"><%= institute.name %></h6>
                  <p class="text-muted small mb-0">Added <%= time_ago_in_words(institute.created_at) %> ago</p>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent Feedback -->
  <div class="col-md-6 mb-4">
    <div class="card card-custom h-100">
      <div class="card-header bg-light py-3">
        <h5 class="card-title mb-0">Recent Feedback</h5>
      </div>
      <div class="card-body scrollable">
        <% @recent_feedbacks.each do |feedback| %>
          <div class="border-bottom pb-3 mb-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <h6 class="mb-0"><%= feedback.training_program.title %></h6>
              <div class="text-warning">
                <% feedback.rating.times do %>
                  <i class="bi bi-star-fill"></i>
                <% end %>
              </div>
            </div>
            <p class="text-muted small mb-1"><%= truncate(feedback.content, length: 100) %></p>
            <p class="text-muted small mb-0">
              By <%= feedback.participant.user.full_name %> • 
              <%= time_ago_in_words(feedback.created_at) %> ago
            </p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<!-- Recent Training Programs (full width) -->
<div class="row">
  <div class="col-12 mb-4">
    <div class="card card-custom">
      <div class="card-header bg-light py-3">
        <h5 class="card-title mb-0">Recent Training Programs</h5>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table mb-0">
            <thead class="table-light">
              <tr>
                <th>Program</th>
                <th>Institute</th>
                <th>Trainer</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% @recent_programs.each do |program| %>
                <tr>
                  <td><%= program.title %></td>
                  <td><%= program.institute.name %></td>
                  <td><%= program.trainer.user.full_name %></td>
                  <td>
                    <span class="badge bg-<%= program.status == 'ongoing' ? 'success' : 'secondary' %>">
                      <%= program.status.titleize %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>



<% content_for :styles do %>
  <style>
    .card-custom {
      border: none;
      box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }
    .card-custom .card-header {
      background-color: #f8f9fa;
      border-bottom: 1px solid rgba(0,0,0,.125);
    }
    .btn-custom-primary {
      color: var(--bs-primary);
      background-color: rgba(var(--bs-primary-rgb), 0.1);
      border: none;
    }
    .btn-custom-primary:hover {
      color: #fff;
      background-color: var(--bs-primary);
    }
    .icon-primary {
      color: var(--bs-primary);
      opacity: 0.75;
    }
    /* KPI card consistent sizing and responsive tweaks */
    .kpi-card {
      min-height: 120px;
      padding: 1rem 1.1rem 0.8rem 1.1rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    /* Export buttons on Institution Statistics header */
    .btn-export {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      padding: .35rem .6rem;
      border-radius: .45rem;
      color: #fff;
      border: none;
      box-shadow: 0 2px 6px rgba(16,24,40,0.06);
      font-weight: 600;
      transition: transform .08s ease, box-shadow .12s ease, opacity .12s ease;
    }
    .btn-export:active { transform: translateY(1px); }
    .btn-export.csv { background: linear-gradient(135deg,#10b981 0%,#059669 100%); }
    .btn-export.csv:hover { filter: brightness(.98); }
    .btn-export.pdf { background: linear-gradient(135deg,#ef4444 0%,#b91c1c 100%); }
    .btn-export.pdf:hover { filter: brightness(.98); }
    .btn-export i { font-size: 1rem; line-height: 1; }

    /* Chart sizing and polish */
    .chart-canvas { height: 360px !important; width: 100% !important; }
    .chart-canvas.small { height: 320px !important; }
    /* Taller variant for the resources and ratings charts */
    .chart-canvas.chart-tall { height: 480px !important; }
    /* Scrollable card body for lists */
    .card-body.scrollable { max-height: 360px; overflow-y: auto; padding-right: 0.5rem; }
    .card.card-custom.h-100 .card-body { padding: 1.25rem; }
    /* Subtle container background for charts */
    .card.card-custom .card-body { background: linear-gradient(180deg, #ffffff, #fbfdff); border-radius: 6px; }

    .stat-block h3 {
      font-size: 1.5rem;
      margin-bottom: 0.125rem;
    }
    .stat-block small {
      display: block;
    }

    @media (max-width: 767.98px) {
      .kpi-card {
        min-height: 70px;
        padding: 0.75rem 0.9rem;
      }
      .stat-block h3 {
        font-size: 1.25rem;
      }
    }

    @media (max-width: 767.98px) {
      .kpi-card {
        min-height: auto;
      }
      .col-md-3.d-flex {
        display: block !important;
      }
      .d-flex.flex-column.flex-fill.gap-3 {
        gap: 0.75rem !important;
      }
    }
  </style>
<% end %>

<%= javascript_importmap_tags %>

<!-- Add Chart.js UMD CDN globally for this view -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<script>
document.addEventListener('turbo:load', function() {
  const colors = {
    primary: '#0d6efd',
    success: '#198754',
    info: '#0dcaf0',
    warning: '#ffc107'
  }
  const stats = <%= raw @institution_stats.to_json %>;

  function initParticipantsChart() {
    const canvas = document.getElementById('participantsChart');
    if (!canvas) return;
    const ctx2d = canvas.getContext('2d');

    // Create vertical gradients for nicer visuals
    const gradPrimary = ctx2d.createLinearGradient(0, 0, 0, canvas.height);
    gradPrimary.addColorStop(0, '#2f80ed');
    gradPrimary.addColorStop(1, '#2563eb');

    const gradSuccess = ctx2d.createLinearGradient(0, 0, 0, canvas.height);
    gradSuccess.addColorStop(0, '#27ae60');
    gradSuccess.addColorStop(1, '#15803d');

    new Chart(canvas, {
      type: 'bar',
      data: {
        labels: stats.labels,
        datasets: [{
          label: 'Total Participants',
          data: stats.participants,
          backgroundColor: gradPrimary,
          borderRadius: {topLeft: 8, topRight: 8, bottomLeft: 0, bottomRight: 0},
          barPercentage: 0.45,
          categoryPercentage: 0.45,
          maxBarThickness: 28
        }, {
          label: 'Active Participants',
          data: stats.active_participants,
          backgroundColor: gradSuccess,
          borderRadius: {topLeft: 8, topRight: 8, bottomLeft: 0, bottomRight: 0},
          barPercentage: 0.45,
          categoryPercentage: 0.45,
          maxBarThickness: 28
        }]
      },
      options: {
        animation: { duration: 900, easing: 'easeOutQuart' },
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { position: 'bottom', align: 'start', labels: { usePointStyle: true, padding: 16, boxWidth: 10, boxHeight: 6 } },
          tooltip: { padding: 10, backgroundColor: 'rgba(33,37,41,0.95)', titleFont: { size: 13, weight: '600' }, bodyFont: { size: 13 }, cornerRadius: 6 }
        },
        layout: { padding: { top: 8, right: 8, bottom: 8, left: 8 } },
        scales: {
          x: {
            grid: { display: false },
            ticks: { maxRotation: 0, autoSkip: false }
          },
          y: {
            beginAtZero: true,
            grid: { color: 'rgba(15, 23, 42, 0.04)' },
            ticks: { precision: 0 }
          }
        }
      }
    });
  }
  function initProgramsChart() {
    const canvas = document.getElementById('programsChart');
    if (!canvas) return;
    const ctx2 = canvas.getContext('2d');

    const gradInfo = ctx2.createLinearGradient(0, 0, 0, canvas.height);
    gradInfo.addColorStop(0, '#06b6d4');
    gradInfo.addColorStop(1, '#06b6d4');

    const gradActive = ctx2.createLinearGradient(0, 0, 0, canvas.height);
    gradActive.addColorStop(0, '#0ea5a4');
    gradActive.addColorStop(1, '#0f766e');

    new Chart(canvas, {
      type: 'bar',
      data: {
        labels: stats.labels,
        datasets: [{
          label: 'Total Programs',
          data: stats.programs,
          backgroundColor: gradInfo,
          borderRadius: {topLeft: 8, topRight: 8, bottomLeft: 0, bottomRight: 0},
          barPercentage: 0.45,
          categoryPercentage: 0.45,
          maxBarThickness: 28
        }, {
          label: 'Active Programs',
          data: stats.active_programs,
          backgroundColor: gradActive,
          borderRadius: {topLeft: 8, topRight: 8, bottomLeft: 0, bottomRight: 0},
          barPercentage: 0.45,
          categoryPercentage: 0.45,
          maxBarThickness: 28
        }]
      },
      options: {
        animation: { duration: 800, easing: 'easeOutQuart' },
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { position: 'bottom', align: 'start', labels: { usePointStyle: true, padding: 16, boxWidth: 10, boxHeight: 6 } },
          tooltip: { padding: 10, backgroundColor: 'rgba(33,37,41,0.95)', titleFont: { size: 13, weight: '600' }, bodyFont: { size: 13 }, cornerRadius: 6 }
        },
        layout: { padding: { top: 8, right: 8, bottom: 8, left: 8 } },
        scales: {
          x: { grid: { display: false }, ticks: { maxRotation: 0 } },
          y: { beginAtZero: true, grid: { color: 'rgba(15, 23, 42, 0.04)' } }
        }
      }
    });
  }
  function initResourcesChart() {
    const canvas = document.getElementById('resourcesChart');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');

    // Create gradients for modern look
    const gradSections = ctx.createLinearGradient(0, 0, 0, canvas.height);
    gradSections.addColorStop(0, '#60a5fa');
    gradSections.addColorStop(1, '#2563eb');

    const gradAssignments = ctx.createLinearGradient(0, 0, 0, canvas.height);
    gradAssignments.addColorStop(0, '#34d399');
    gradAssignments.addColorStop(1, '#059669');

    new Chart(canvas, {
      type: 'bar',
      data: {
        labels: stats.labels,
        datasets: [{
          label: 'Sections',
          data: stats.sections,
          backgroundColor: gradSections,
          borderRadius: 6,
          barPercentage: 0.6,
          categoryPercentage: 0.6,
          maxBarThickness: 36
        }, {
          label: 'Assignments',
          data: stats.assignments,
          backgroundColor: gradAssignments,
          borderRadius: 6,
          barPercentage: 0.6,
          categoryPercentage: 0.6,
          maxBarThickness: 36
        }]
      },
      options: {
        animation: { duration: 700, easing: 'easeOutQuart' },
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { position: 'bottom', align: 'start', labels: { usePointStyle: true, padding: 12, boxWidth: 10, boxHeight: 6 } },
          tooltip: { padding: 10, backgroundColor: 'rgba(33,37,41,0.95)', titleFont: { size: 13, weight: '600' }, bodyFont: { size: 13 }, cornerRadius: 6 }
        },
        layout: { padding: { top: 6, right: 8, bottom: 6, left: 8 } },
        scales: {
          x: { grid: { display: false }, ticks: { maxRotation: 0, autoSkip: true } },
          y: { beginAtZero: true, title: { display: true, text: 'Count' }, ticks: { precision: 0 }, grid: { color: 'rgba(15, 23, 42, 0.04)' } }
        }
      }
    });
  }
  function initRatingsChart() {
    const ctx = document.getElementById('ratingsChart');
    if (!ctx) return;
    new Chart(ctx, {
      type: 'line',
      data: {
        labels: stats.labels,
        datasets: [{
          label: 'Average Rating',
          data: stats.avg_ratings,
          borderColor: colors.warning,
          backgroundColor: `${colors.warning}33`,
          fill: true,
          tension: 0.4,
          pointRadius: 4,
          pointHoverRadius: 6,
          pointBackgroundColor: colors.warning
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { position: 'bottom', labels: { usePointStyle: true, pointStyle: 'circle', padding: 12, boxWidth: 10, boxHeight: 6 } }
        },
        scales: {
          y: {
            min: 0,
            max: 5,
            ticks: {
              stepSize: 1
            }
          }
        }
      }
    });
  }
  initParticipantsChart();
  initProgramsChart();
  initResourcesChart();
  initRatingsChart();
});
</script>

<script>
// CSV and Print-to-PDF helpers for Institution Statistics table
document.addEventListener('turbo:load', function() {
  function downloadTableCSV(tableId, filename) {
    const table = document.getElementById(tableId);
    if (!table) return;
    const rows = [];
    const headers = Array.from(table.querySelectorAll('thead th')).map(th => th.textContent.trim());
    rows.push(headers.map(h => '"' + h.replace(/"/g, '""') + '"').join(','));

    table.querySelectorAll('tbody tr').forEach(tr => {
      const cols = Array.from(tr.querySelectorAll('td')).map(td => td.innerText.trim());
      rows.push(cols.map(c => '"' + c.replace(/"/g, '""') + '"').join(','));
    });

    const csv = rows.join('\n');
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = filename;
    document.body.appendChild(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(link.href);
  }

  function openTablePrintWindow(tableId, title) {
    const table = document.getElementById(tableId);
    if (!table) return;
    const w = window.open('', '_blank');
    const doc = w.document.open();
    const style = `
      <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; margin: 20px; }
        h1 { font-size: 18px; margin-bottom: 12px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        th { background: #f8f9fa; }
      </style>
    `;
    const html = `<!doctype html><html><head><meta charset="utf-8"><title>${title}</title>${style}</head><body><h1>${title}</h1>${table.outerHTML}</body></html>`;
    doc.write(html);
    doc.close();
    // Give the new window a moment to render before printing
    setTimeout(() => { w.focus(); w.print(); }, 250);
  }

  const csvBtn = document.getElementById('downloadCsvBtn');
  const pdfBtn = document.getElementById('downloadPdfBtn');
  if (csvBtn) csvBtn.addEventListener('click', () => downloadTableCSV('institutions-stats-table', 'institution_statistics.csv'));
  if (pdfBtn) pdfBtn.addEventListener('click', () => openTablePrintWindow('institutions-stats-table', 'Institution Statistics'));
});
</script>