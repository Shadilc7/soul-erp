<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<script>
document.addEventListener('turbo:load', function() {
  const colors = {
    primary: '#0d6efd',
    success: '#198754',
    info: '#0dcaf0',
    warning: '#ffc107'
  }
  const stats = <%= raw @institution_stats.to_json %>;

  function initParticipantsChart() {
    const canvas = document.getElementById('participantsChart');
    if (!canvas) return;
    const ctx2d = canvas.getContext('2d');

    // Create modern gradients with multiple color stops
    const gradPrimary = ctx2d.createLinearGradient(0, 0, 0, canvas.height);
    gradPrimary.addColorStop(0, '#667eea');
    gradPrimary.addColorStop(0.5, '#764ba2');
    gradPrimary.addColorStop(1, '#667eea');

    const gradSuccess = ctx2d.createLinearGradient(0, 0, 0, canvas.height);
    gradSuccess.addColorStop(0, '#11998e');
    gradSuccess.addColorStop(1, '#38ef7d');

    new Chart(canvas, {
      type: 'bar',
      plugins: [{
        id: 'customCanvasBackgroundImage',
        beforeDraw: (chart) => {
          const ctx = chart.ctx;
          const chartArea = chart.chartArea;
          
          // Create radial gradient background
          const gradient = ctx.createRadialGradient(
            chartArea.left + (chartArea.right - chartArea.left) / 2,
            chartArea.top + (chartArea.bottom - chartArea.top) / 2,
            0,
            chartArea.left + (chartArea.right - chartArea.left) / 2,
            chartArea.top + (chartArea.bottom - chartArea.top) / 2,
            Math.max(chartArea.right - chartArea.left, chartArea.bottom - chartArea.top) / 1.5
          );
          gradient.addColorStop(0, 'rgba(102, 126, 234, 0.02)');
          gradient.addColorStop(0.5, 'rgba(118, 75, 162, 0.04)');
          gradient.addColorStop(1, 'rgba(102, 126, 234, 0.01)');
          
          ctx.save();
          ctx.fillStyle = gradient;
          ctx.fillRect(chartArea.left, chartArea.top, chartArea.right - chartArea.left, chartArea.bottom - chartArea.top);
          
          // Add decorative dots pattern
          ctx.fillStyle = 'rgba(102, 126, 234, 0.06)';
          for (let x = chartArea.left; x < chartArea.right; x += 60) {
            for (let y = chartArea.top; y < chartArea.bottom; y += 60) {
              ctx.beginPath();
              ctx.arc(x, y, 2, 0, Math.PI * 2);
              ctx.fill();
            }
          }
          ctx.restore();
        }
      }],
      data: {
        labels: stats.labels,
        datasets: [{
          label: 'Total Participants',
          data: stats.participants,
          backgroundColor: gradPrimary,
          borderRadius: 12,
          borderSkipped: false,
          barPercentage: 0.65,
          categoryPercentage: 0.7,
          maxBarThickness: 40
        }, {
          label: 'Active Participants',
          data: stats.active_participants,
          backgroundColor: gradSuccess,
          borderRadius: 12,
          borderSkipped: false,
          barPercentage: 0.65,
          categoryPercentage: 0.7,
          maxBarThickness: 40
