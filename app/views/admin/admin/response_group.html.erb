<div class="container-fluid py-4">
  <div class="card card-custom">
    <div class="card-header d-flex justify-content-between align-items-center">
      <div>
        <h5 class="card-title mb-0">Responses — <%= @assignment&.title || 'Assignment' %></h5>
        <small class="text-muted">Participant: <%= @participant&.user&.full_name || @participant&.id %></small>
      </div>
      <div>
        <%= link_to 'Back', admin_institute_responses_path(@institute), class: 'btn btn-sm btn-light' %>
      </div>
    </div>
    <div class="card-body">
        <% if @responses.present? %>
          <div class="row mb-3">
            <div class="col-sm-3">
              <div class="card p-3">
                <h6 class="mb-1">Total Responses</h6>
                <div class="h4 mb-0"><%= @stats[:total] %></div>
              </div>
            </div>
            <div class="col-sm-3">
              <div class="card p-3">
                <h6 class="mb-1">Answered</h6>
                <div class="h4 mb-0"><%= @stats[:answered] %></div>
              </div>
            </div>
            <div class="col-sm-3">
              <div class="card p-3">
                <h6 class="mb-1">Unanswered</h6>
                <div class="h4 mb-0"><%= @stats[:unanswered] %></div>
              </div>
            </div>
            <div class="col-sm-3">
              <div class="card p-3">
                <h6 class="mb-1">Date Range</h6>
                <div class="small text-muted"><%= @stats[:first_response_date] || '-' %> — <%= @stats[:last_response_date] || '-' %></div>
              </div>
            </div>
          </div>

          <div class="table-responsive">
            <table class="table table-striped table-hover">
              <thead>
                <tr>
                  <th>Question</th>
                  <th>Answer / Selected Options</th>
                  <th class="w-25">Submitted At</th>
                </tr>
              </thead>
              <tbody>
                <% @responses.each do |r| %>
                  <tr>
                    <td><%= r.question&.title || '—' %></td>
                    <td>
                      <% if r.answer.present? %>
                        <%= r.answer %>
                      <% elsif r.selected_options.present? %>
                        <%= Array(r.selected_options).join(', ') %>
                      <% else %>
                        —
                      <% end %>
                    </td>
                    <td><%= r.created_at %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="text-muted">No responses found for this assignment / participant.</div>
        <% end %>
    </div>
  </div>
</div>
