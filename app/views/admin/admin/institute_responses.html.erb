<div class="container-fluid py-4">
  <div class="card card-custom">
    <div class="card-header d-flex justify-content-between align-items-center">
      <div>
        <h5 class="card-title mb-0">Responses for <%= @institute.name %></h5>
        <small class="text-muted">Showing recent responses (assignment × participant)</small>
      </div>
      <div>
        <%= link_to 'Back', admin_responses_path, class: 'btn btn-sm btn-light' %>
      </div>
    </div>
      <div class="card-body">
            <%# Modern full-width responsive filter bar: desktop inline, mobile stacked with collapse for advanced filters %>
            <% content_for :styles do %>
              <style>
                .filter-bar { background: linear-gradient(180deg,#ffffff,#fbfdff); border-radius: .5rem; padding: .75rem; box-shadow: 0 6px 18px rgba(16,24,40,0.06); }
                /* Use standard slightly-rounded inputs instead of pill-shaped */
                .filter-bar .form-select, .filter-bar .form-control { border-radius: .375rem; padding: .35rem .6rem; }
                .filter-bar .form-label { font-size: .8rem; margin-bottom: .25rem; }
                .filter-actions { display:flex; gap:.5rem; align-items:center; }

                /* Make Filter / Clear buttons larger and aligned with inputs */
                .filter-actions .btn { min-width: 130px; padding: .45rem .9rem; font-weight: 600; }
                .filter-actions .btn.btn-primary { min-width: 150px; }

                /* On small screens keep buttons visible but allow them to share the row space */
                @media (max-width: 767px) {
                  .filter-bar { padding: .65rem; }
                  /* Stack the main row on mobile so controls are full width */
                  .filter-bar .d-flex { flex-direction: column !important; align-items: stretch !important; }
                  .filter-bar .flex-fill { width: 100% !important; }
                  .filter-bar .d-flex > div[style] { width: 100% !important; display:flex; gap:.5rem; }
                  .filter-bar label.form-label { margin-bottom: .35rem; }

                  /* Make filter buttons full width and stack them */
                  .filter-actions { justify-content: flex-start; width: 100%; display:flex; flex-direction:column; gap:.5rem; }
                  .filter-actions .btn { width: 100%; min-width: 0; }
                  .filter-actions .btn.btn-primary { order: 1; }
                  .filter-actions .btn.btn-outline-secondary { order: 2; }

                  /* Ensure collapse area spans full width */
                  #advancedFilters { width: 100%; }
                }
              </style>
            <% end %>

                <div class="filter-bar mb-3">
              <%= form_with url: admin_institute_responses_path(@institute), method: :get, local: true do |f| %>
                <div class="d-flex flex-column flex-md-row align-items-center gap-2">
                  <div class="flex-fill">
                    <label class="form-label small mb-0">Assignment</label>
                    <%= f.select :assignment_id, options_for_select([['All', '']] + @assignments.map { |a| [a.title, a.id] }, params[:assignment_id]), {}, class: 'form-select' %>
                  </div>

                    <div class="flex-fill">
                      <label class="form-label small mb-0">Participant</label>
                      <%= f.select :participant_id, options_for_select([['All', '']] + @participants.map { |id, name| [name, id] }, params[:participant_id]), {}, class: 'form-select' %>
                    </div>

                    <div class="flex-fill">
                      <label class="form-label small mb-0">Status</label>
                      <%= f.select :status, options_for_select([['Any', ''], ['Answered', 'answered'], ['Unanswered', 'unanswered']], params[:status]), {}, class: 'form-select' %>
                    </div>

                    <div class="d-flex" style="min-width:220px; gap:.5rem;">
                      <div style="flex:1">
                        <label class="form-label small mb-0">From</label>
                        <%= f.date_field :from, value: params[:from], class: 'form-control' %>
                      </div>
                      <div style="flex:1">
                        <label class="form-label small mb-0">To</label>
                        <%= f.date_field :to, value: params[:to], class: 'form-control' %>
                      </div>
                    </div>

                  <div class="filter-actions ms-auto" style="align-self: flex-end; margin-top: .25rem;">
                    <%= f.submit 'Filter', class: 'btn btn-primary btn-sm px-3' %>
                    <%= link_to 'Clear', admin_institute_responses_path(@institute), class: 'btn btn-outline-secondary btn-sm' %>
                    <button class="btn btn-light btn-sm d-md-none" type="button" data-bs-toggle="collapse" data-bs-target="#advancedFilters" aria-expanded="false" aria-controls="advancedFilters">
                      <i class="bi bi-sliders"></i>
                    </button>
                  </div>
                </div>

                <div class="collapse mt-3" id="advancedFilters">
                  <div class="row g-2">
                    <div class="col-6">
                      <label class="form-label small mb-0">Status</label>
                      <%= f.select :status, options_for_select([['Any', ''], ['Answered', 'answered'], ['Unanswered', 'unanswered']], params[:status]), {}, class: 'form-select' %>
                    </div>
                    <div class="col-3">
                      <label class="form-label small mb-0">From</label>
                      <%= f.date_field :from, value: params[:from], class: 'form-control' %>
                    </div>
                    <div class="col-3">
                      <label class="form-label small mb-0">To</label>
                      <%= f.date_field :to, value: params[:to], class: 'form-control' %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>

          <% if @grouped_responses.present? %>
          <div class="table-responsive">
            <table class="table table-hover">
              <thead>
                <tr>
                  <th>Assignment</th>
                  <th>Participant</th>
                  <th class="text-center">Responses</th>
                  <th class="text-center">Last Response</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% @grouped_responses.each do |group| %>
                  <% responses_count = group[:responses].size %>
                  <% last_date = group[:responses].map { |r| r[:response_date] }.compact.max %>
                  <tr>
                    <td><strong><%= group[:assignment_title] || '—' %></strong></td>
                    <td><%= group[:participant_name] || group[:participant_id] %></td>
                    <td class="text-center"><%= responses_count %></td>
                    <td class="text-center"><%= last_date || '—' %></td>
                    <td class="text-end">
                      <%= link_to 'Details', admin_institute_response_detail_path(@institute, group[:responses].first[:id], assignment_id: group[:assignment_id], participant_id: group[:participant_id]), class: 'btn btn-sm btn-outline-primary' %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="text-muted">No responses found for this institute.</div>
        <% end %>
      </div>
  </div>
</div>
