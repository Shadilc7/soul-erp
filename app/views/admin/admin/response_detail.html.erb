<div class="container-fluid py-4">
  <div class="card card-custom">
    <div class="card-header d-flex justify-content-between align-items-center">
      <div>
        <h5 class="card-title mb-0">Response Details</h5>
        <small class="text-muted">Institute: <%= @institute.name %></small>
      </div>
      <div>
        <%= link_to 'Back', admin_institute_responses_path(@institute), class: 'btn btn-sm btn-light' %>
      </div>
    </div>
    <div class="card-body">
      <dl class="row">
        <dt class="col-sm-3">Assignment</dt>
        <dd class="col-sm-9"><%= @response.assignment&.title || '—' %></dd>

        <dt class="col-sm-3">Participant</dt>
        <dd class="col-sm-9"><%= @response.participant.user&.full_name rescue @response.participant_id %></dd>

        <dt class="col-sm-3">Question</dt>
        <dd class="col-sm-9"><%= @response.question&.title || '—' %></dd>

        <dt class="col-sm-3">Answer</dt>
        <dd class="col-sm-9">
          <% if @response.answer.present? %>
            <%= @response.answer %>
          <% elsif @response.selected_options.present? %>
            <%= Array(@response.selected_options).join(', ') %>
          <% else %>
            —
          <% end %>
        </dd>

        <dt class="col-sm-3">Response Date</dt>
        <dd class="col-sm-9"><%= @response.response_date %></dd>

        <dt class="col-sm-3">Submitted At</dt>
        <dd class="col-sm-9"><%= @response.created_at %></dd>
      </dl>
    </div>
  </div>
</div>
