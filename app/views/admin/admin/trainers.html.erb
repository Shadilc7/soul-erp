<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0">All Trainers</h4>
  <%= link_to admin_root_path, class: 'btn btn-outline-secondary' do %>
    Back
  <% end %>
</div>

<!-- Institute Filter -->
<div class="mb-3 p-3 bg-white rounded-3 shadow-sm border">
  <%= form_with url: admin_trainers_path, method: :get, local: true, class: 'd-flex align-items-center gap-3' do |f| %>
    <label for="instituteFilter" class="mb-0 text-muted small me-2">Institute:</label>
    <%= f.select :institute_id, 
        options_for_select([['All Institutes', '']] + @institutes.map { |i| [i.name, i.id] }, params[:institute_id]), 
        {}, 
        class: 'form-select form-select-sm', 
        id: 'instituteFilter', 
        onchange: 'this.form.submit()', 
        style: 'max-width: 300px;' %>
    <%= link_to 'Clear', admin_trainers_path, class: 'btn btn-sm btn-outline-secondary ms-2' %>
  <% end %>
</div>

<div class="card card-custom">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover">
        <thead>
          <tr>
            <th>Name</th>
            <th>Institute</th>
            <th>Email</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% @trainers.each do |t| %>
            <tr>
              <td><%= t.user&.full_name || t.user&.username || '—' %></td>
              <td><%= t.institute&.name %></td>
              <td><%= t.user&.email %></td>
              <td><span class="badge <%= t.active? ? 'bg-success' : 'bg-secondary' %>"><%= t.status&.to_s&.titleize %></span></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
