 <style>
    .action-btn { width:36px; height:36px; display:inline-flex; align-items:center; justify-content:center; border-radius:8px; transition:all .3s ease; border:none; position:relative; overflow:hidden; }
    .action-btn::before { content:''; position:absolute; top:50%; left:50%; width:0; height:0; border-radius:50%; background:rgba(255,255,255,.2); transform:translate(-50%,-50%); transition:width .45s,height .45s; }
    .action-btn:hover::before { width:100px; height:100px; }
    .action-btn i { font-size:16px; position:relative; z-index:1; }
    .btn-view{ background:linear-gradient(135deg,#667eea 0%,#764ba2 100%); color:#fff; }
    .btn-edit{ background:linear-gradient(135deg,#f093fb 0%,#f5576c 100%); color:#fff; }
    .btn-delete{ background:linear-gradient(135deg,#ff6b6b 0%,#c92a2a 100%); color:#fff; }
    td:last-child{ white-space:nowrap; }
    .actions-cell { display: inline-flex; gap: .5rem; align-items: center; }
</style>

<div class="card card-custom">
  <div class="card-header card-header-custom d-flex justify-content-between align-items-center">
    <h5 class="mb-0">Institute Admins</h5>
    <%= link_to new_admin_user_path, class: "btn btn-custom-primary" do %>
      <i class="bi bi-plus-lg"></i> Add Admin
    <% end %>
  </div>

  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover">
        <thead>
          <tr>
            <th>Username</th>
            <th>Institute</th>
            <th>Status</th>
            <th>Created At</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td><%= user.username %></td>
              <td><%= user.institute&.name || 'Not Assigned' %></td>
              <td>
                <span class="badge <%= user.active? ? 'badge-success' : 'badge-danger' %>">
                  <%= user.active? ? 'Active' : 'Inactive' %>
                </span>
              </td>
              <td><%= user.created_at.strftime("%b %d, %Y") %></td>
              <td class="actions-cell">
                <%= link_to admin_user_path(user), class: "btn action-btn btn-view", title: "View" do %>
                  <i class="bi bi-eye"></i>
                <% end %>
                <%= link_to edit_admin_user_path(user), class: "btn action-btn btn-edit", title: "Edit" do %>
                  <i class="bi bi-pencil"></i>
                <% end %>
                <%= form_with url: admin_user_path(user), method: :delete, local: true, style: 'display:inline-block;' do |f| %>
                  <button type="submit" class="btn action-btn btn-delete" data-confirm="Are you sure you want to remove this administrator?">
                    <i class="bi bi-trash"></i>
                  </button>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div> 