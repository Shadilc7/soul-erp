<!DOCTYPE html>
<html>
  <head>
    <title>Participant Portal<%= " - #{current_institute.name}" if current_institute %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      :root {
        --sidebar-width: 280px;
        --sidebar-collapsed-width: 80px;
        --header-height: 70px;
        --primary-color: #6366f1;
        --primary-dark: #4f46e5;
        --primary-light: #818cf8;
        --secondary-color: #64748b;
        --success-color: #22c55e;
        --danger-color: #ef4444;
        --warning-color: #f59e0b;
        --info-color: #3b82f6;
        --sidebar-bg: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);
        --topbar-bg: #ffffff;
        --body-bg: #f8fafc;
        --text-primary: #f8fafc;
        --text-secondary: #94a3b8;
        --border-color: rgba(148, 163, 184, 0.1);
      }

      body {
        min-height: 100vh;
        background: var(--body-bg) !important;
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      }

      /* Sidebar Styles */
      .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        width: var(--sidebar-width);
        background: var(--sidebar-bg);
        border-right: 1px solid rgba(255,255,255,0.08);
        transform: translateX(0);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 1045;
        overflow-y: auto;
        overflow-x: hidden;
        display: flex;
        flex-direction: column;
        box-shadow: 4px 0 20px rgba(0, 0, 0, 0.1);
      }

      .sidebar.collapsed {
        width: var(--sidebar-collapsed-width);
      }

      .sidebar.collapsed .sidebar-header h5,
      .sidebar.collapsed .sidebar-header i.bi-book,
      .sidebar.collapsed .nav-link span,
      .sidebar.collapsed .signout-btn span {
        opacity: 0;
        visibility: hidden;
      }

      .sidebar.collapsed .nav-link {
        justify-content: center;
        padding: 0.8rem;
      }

      .sidebar.collapsed .nav-link i {
        margin-right: 0;
      }

      .sidebar.collapsed .signout-btn {
        padding: 0.8rem;
        justify-content: center;
      }

      .sidebar-header {
        height: var(--header-height);
        padding: 0 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
      }

      .sidebar-header a {
        color: var(--text-primary);
        transition: transform 0.3s ease;
      }

      .sidebar-header a:hover {
        transform: scale(1.05);
      }

      .sidebar-header h5 {
        background: linear-gradient(135deg, #6366f1 0%, #818cf8 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        font-weight: 700;
        letter-spacing: 0.5px;
        transition: opacity 0.3s ease;
      }

      .sidebar-header i {
        background: linear-gradient(135deg, #6366f1 0%, #818cf8 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .nav-link {
        padding: 0.9rem 1.2rem;
        color: var(--text-secondary);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border-radius: 12px;
        margin: 0.3rem 0.75rem;
        position: relative;
        overflow: hidden;
        font-weight: 500;
        font-size: 0.9rem;
      }

      .nav-link::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 4px;
        background: linear-gradient(135deg, #6366f1 0%, #818cf8 100%);
        transform: translateX(-4px);
        transition: transform 0.3s ease;
        border-radius: 0 4px 4px 0;
      }

      .nav-link:hover {
        color: var(--text-primary);
        background: rgba(255,255,255,0.08);
        transform: translateX(4px);
      }

      .nav-link:hover::before {
        transform: translateX(0);
      }

      .nav-link.active {
        color: var(--text-primary);
        background: linear-gradient(135deg, rgba(99, 102, 241, 0.15) 0%, rgba(129, 140, 248, 0.1) 100%);
        font-weight: 600;
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);
      }

      .nav-link.active::before {
        transform: translateX(0);
      }

      .nav-link i {
        width: 1.3rem;
        font-size: 1.1rem;
        transition: transform 0.3s ease;
      }

      .nav-link:hover i {
        transform: scale(1.1);
      }

      .nav-link span {
        transition: opacity 0.3s ease;
      }

      .signout-btn {
        border: none;
        padding: 0.9rem 1.2rem;
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.1) 0%, rgba(220, 38, 38, 0.05) 100%);
        color: #ef4444;
        font-weight: 600;
        font-size: 0.9rem;
        border-radius: 12px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        position: relative;
        overflow: hidden;
      }

      .signout-btn::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
        transition: left 0.5s ease;
      }

      .signout-btn:hover {
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.15) 0%, rgba(220, 38, 38, 0.1) 100%);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(239, 68, 68, 0.3);
        border-color: rgba(239, 68, 68, 0.4);
      }

      .signout-btn:hover::before {
        left: 100%;
      }

      .signout-btn i {
        font-size: 1.1rem;
        transition: transform 0.3s ease;
      }

      .signout-btn:hover i {
        transform: translateX(3px);
      }

      /* Main Content Styles */
      #main-content {
        margin-left: var(--sidebar-width);
        min-height: 100vh;
        transition: margin 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        background: var(--body-bg);
      }

      #main-content.expanded {
        margin-left: 0;
      }

      #main-content.collapsed {
        margin-left: var(--sidebar-collapsed-width);
      }

      .topbar {
        height: var(--header-height);
        background: var(--topbar-bg);
        border-bottom: 1px solid var(--border-color);
        padding: 0 2rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        backdrop-filter: blur(10px);
        position: relative;
      }

      .topbar::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, #6366f1 0%, #818cf8 50%, #6366f1 100%);
        background-size: 200% 100%;
        animation: gradient-shift 3s ease infinite;
      }

      @keyframes gradient-shift {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
      }

      .hamburger-btn {
        width: 44px;
        height: 44px;
        border: none;
        background: linear-gradient(135deg, rgba(99, 102, 241, 0.1) 0%, rgba(129, 140, 248, 0.05) 100%);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
        color: var(--primary-color);
        border: 1px solid rgba(99, 102, 241, 0.1);
      }

      .hamburger-btn:hover {
        background: linear-gradient(135deg, rgba(99, 102, 241, 0.15) 0%, rgba(129, 140, 248, 0.1) 100%);
        transform: scale(1.05);
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);
      }

      .hamburger-btn i {
        font-size: 1.3rem;
        transition: transform 0.3s ease;
      }

      .hamburger-btn:hover i {
        transform: rotate(90deg);
      }

      .content-wrapper {
        padding: 1.5rem;
      }

      /* Card Styles */
      .card-custom {
        border: 1px solid var(--border-color);
        border-radius: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04), 0 1px 3px rgba(0,0,0,0.02);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
        background: #ffffff;
      }

      .card-custom:hover {
        box-shadow: 0 8px 24px rgba(0,0,0,0.08), 0 4px 12px rgba(0,0,0,0.04);
        transform: translateY(-2px);
      }

      .card-header-custom {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(248, 250, 252, 0.9) 100%);
        border-bottom: 1px solid var(--border-color);
        padding: 1.5rem;
        border-radius: 16px 16px 0 0;
        backdrop-filter: blur(10px);
      }

      /* Button Styles */
      .btn-custom-primary {
        background: var(--primary-color);
        border-color: var(--primary-color);
        color: #ffffff;
        transition: all 0.3s ease;
      }

      .btn-custom-primary:hover {
        background: var(--primary-dark);
        border-color: var(--primary-dark);
        color: #ffffff;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
      }

      .btn-outline-custom {
        border-color: var(--primary-color);
        color: var(--primary-color);
        transition: all 0.3s ease;
      }

      .btn-outline-custom:hover {
        background-color: var(--primary-color);
        color: #ffffff;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
      }

      /* Badge Styles */
      .badge-success {
        background: rgba(34, 197, 94, 0.1);
        color: var(--success-color) !important;
        font-weight: 600;
      }

      .badge-warning {
        background: rgba(245, 158, 11, 0.1);
        color: var(--warning-color) !important;
        font-weight: 600;
      }

      .badge-danger {
        background: rgba(239, 68, 68, 0.1);
        color: var(--danger-color) !important;
        font-weight: 600;
      }

      /* Progress Bar */
      .progress {
        background-color: #e9ecef;
        border-radius: 0.5rem;
        height: 0.75rem;
      }

      .progress-bar {
        border-radius: 0.5rem;
        background: linear-gradient(90deg, var(--primary-color), var(--primary-light));
        transition: width 0.6s ease;
      }

      /* Custom Scrollbar */
      ::-webkit-scrollbar {
        width: 6px;
      }

      ::-webkit-scrollbar-track {
        background: transparent;
      }

      ::-webkit-scrollbar-thumb {
        background: var(--secondary-color);
        border-radius: 3px;
      }

      /* Mobile Sidebar */
      .sidebar-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(4px);
        z-index: 1040;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease-in-out;
      }

      @media (max-width: 991.98px) {
        .sidebar {
          transform: translateX(-100%);
          box-shadow: none;
        }

        .sidebar.show {
          transform: translateX(0);
          box-shadow: 8px 0 24px rgba(0,0,0,0.3);
        }

        .sidebar.collapsed {
          width: var(--sidebar-width);
        }

        .sidebar-backdrop.show {
          opacity: 1;
          visibility: visible;
        }

        #main-content {
          margin-left: 0 !important;
        }
      }
    </style>

    <%= yield :styles %>
  </head>

  <body>
    <div data-controller="sidebar">
      <!-- Sidebar -->
      <div id="sidebar" class="sidebar" data-sidebar-target="content">
        <div class="sidebar-header d-flex align-items-center">
          <%= link_to participant_portal_root_path, class: "text-decoration-none d-flex align-items-center" do %>
            <i class="bi bi-book text-white fs-4 me-2"></i>
            <h5 class="mb-0 text-white">BeYa</h5>
          <% end %>
        </div>

        <div class="py-3">
          <nav class="nav flex-column">
            <%= link_to participant_portal_root_path, class: "nav-link #{'active' if active_link?('dashboard')}" do %>
              <i class="bi bi-speedometer2"></i>
              <span>Dashboard</span>
            <% end %>

            <%= link_to participant_portal_training_programs_path, class: "nav-link #{'active' if active_link?('training_programs')}" do %>
              <i class="bi bi-mortarboard"></i>
              <span>Training Programs</span>
            <% end %>

            <%= link_to participant_portal_assignments_path, class: "nav-link #{'active' if active_link?('assignments')}" do %>
              <i class="bi bi-clipboard-check"></i>
              <span>Assignments</span>
            <% end %>

            <%= link_to participant_portal_certificates_path, class: "nav-link #{'active' if active_link?('certificates')}" do %>
              <i class="bi bi-award"></i>
              <span>Certificates</span>
            <% end %>

            <%= link_to participant_portal_profile_path, class: "nav-link #{'active' if active_link?('profile')}" do %>
              <i class="bi bi-person"></i>
              <span>My Profile</span>
            <% end %>
          </nav>
        </div>

        <div class="mt-auto p-3">
          <%= button_to destroy_user_session_path, method: :delete, 
              class: "signout-btn w-100 d-flex align-items-center justify-content-center gap-2" do %>
            <i class="bi bi-box-arrow-right"></i>
            <span>Sign Out</span>
          <% end %>
        </div>
      </div>

      <!-- Backdrop for mobile -->
      <div class="sidebar-backdrop" data-sidebar-target="backdrop" data-action="click->sidebar#hide"></div>

      <!-- Main Content -->
      <div id="main-content">
        <!-- Topbar -->
        <div class="topbar d-flex align-items-center justify-content-between">
          <button class="hamburger-btn d-lg-none" data-action="sidebar#toggle">
            <i class="bi bi-list"></i>
          </button>
          <div class="d-flex align-items-center gap-3 ms-auto">
            <span class="text-secondary small fw-500">Welcome back!</span>
          </div>
        </div>

        <!-- Content -->
        <div class="content-wrapper">
          <%= render "shared/flash" %>
          <%= yield %>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <%= yield :scripts %>
  </body>
</html>