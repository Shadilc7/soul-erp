<div class="container py-4 trainer-dashboard">
  <!-- Hero / Profile -->
  <div class="hero-card mb-4">
    <div class="hero-accent"></div>
    <div class="hero-content">
      <div class="profile-badge">
        <span><%= current_user.first_name&.first&.upcase || current_user.email.first.upcase %></span>
      </div>
      <div class="profile-meta">
        <h3 class="profile-name">
          <%= current_user.first_name.present? ? "#{current_user.first_name} #{current_user.last_name}" : current_user.email %>
        </h3>
        <div class="profile-subtitle">
          <span><i class="bi bi-building me-2"></i><%= current_institute.name %></span>
          <% if current_trainer.specialization.present? %>
            <span class="dot-divider"></span>
            <span><i class="bi bi-bookmark-star me-2"></i><%= current_trainer.specialization %></span>
          <% end %>
          <span class="dot-divider"></span>
          <span><i class="bi bi-briefcase me-2"></i><%= pluralize(current_trainer.experience_years || 0, "year") %> experience</span>
        </div>
      </div>
      <div class="hero-actions">
        <%= link_to trainer_portal_training_programs_path, class: "btn-hero" do %>
          <i class="bi bi-collection me-2"></i> View Programs
        <% end %>
      </div>
    </div>
  </div>

  <!-- Program Statistics -->
  <div class="row g-3 mb-4">
    <div class="col-12 col-sm-6 col-lg-3">
      <div class="stat-card">
        <div class="stat-icon bg-primary-soft"><i class="bi bi-collection"></i></div>
        <div>
          <p class="stat-label">Total Programs</p>
          <h4 class="stat-value"><%= @training_programs.count %></h4>
        </div>
      </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
      <div class="stat-card">
        <div class="stat-icon bg-success-soft"><i class="bi bi-play-circle"></i></div>
        <div>
          <p class="stat-label">Ongoing Programs</p>
          <h4 class="stat-value"><%= @training_programs.ongoing.count %></h4>
        </div>
      </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
      <div class="stat-card">
        <div class="stat-icon bg-info-soft"><i class="bi bi-check-circle"></i></div>
        <div>
          <p class="stat-label">Completed Programs</p>
          <h4 class="stat-value"><%= @training_programs.completed.count %></h4>
        </div>
      </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
      <div class="stat-card">
        <div class="stat-icon bg-warning-soft"><i class="bi bi-people"></i></div>
        <div>
          <p class="stat-label">Total Participants</p>
          <h4 class="stat-value"><%= @training_programs.distinct.count(:participant_id) %></h4>
        </div>
      </div>
    </div>
  </div>

  <!-- Training Programs -->
  <div class="section-header">
    <h4>My Training Programs</h4>
    <p>Track assignments, attendance, and progress at a glance.</p>
  </div>

  <div class="row g-4">
    <% @training_programs.each do |program| %>
      <div class="col-12 col-md-6 col-xl-4">
        <div class="program-card h-100">
          <div class="card-header-modern">
            <h5 class="program-title" title="<%= program.title %>"><%= program.title %></h5>
            <span class="status-badge status-<%= program.status == 'completed' ? 'completed' : 'active' %>">
              <i class="bi bi-<%= program.status == 'completed' ? 'check-circle-fill' : 'play-circle-fill' %> me-1"></i>
              <%= program.status.titleize %>
            </span>
          </div>
          <div class="card-body-modern">
            <p class="program-description"><%= truncate(program.description, length: 110) %></p>

            <div class="info-list">
              <div class="info-item">
                <div class="info-icon"><i class="bi bi-people-fill"></i></div>
                <div class="info-content">
                  <small class="info-label">Assigned To</small>
                  <span class="info-value">
                    <% if program.individual? %>
                      <% if program.participants.any? %>
                        <%= pluralize(program.participants.count, "participant") %>
                      <% else %>
                        <%= program.participant&.user&.full_name || "Unassigned" %>
                      <% end %>
                    <% else %>
                      <% if program.sections.any? %>
                        <%= pluralize(program.sections.count, "section") %>
                      <% else %>
                        <%= program.section&.name || "Unassigned" %>
                      <% end %>
                    <% end %>
                  </span>
                </div>
              </div>

              <div class="info-item">
                <div class="info-icon"><i class="bi bi-calendar-range"></i></div>
                <div class="info-content">
                  <small class="info-label">Duration</small>
                  <span class="info-value"><%= program.start_date.strftime("%b %d") %> - <%= program.end_date.strftime("%b %d, %Y") %></span>
                </div>
              </div>

              <div class="info-item">
                <div class="info-icon"><i class="bi bi-person-workspace"></i></div>
                <div class="info-content">
                  <small class="info-label">Type</small>
                  <span class="info-value"><%= program.program_type.titleize %></span>
                </div>
              </div>
            </div>

            <div class="action-buttons">
              <%= link_to trainer_portal_training_program_path(program), class: "btn-view" do %>
                <i class="bi bi-eye me-1"></i> View Details
              <% end %>
              <%= link_to edit_trainer_portal_training_program_path(program), class: "btn-secondary" do %>
                <i class="bi bi-pencil me-1"></i> Edit
              <% end %>
              <% if program.completed? %>
                <button class="btn-feedback-done" disabled>
                  <i class="bi bi-check-circle-fill me-1"></i> Completed
                </button>
              <% else %>
                <%= button_to mark_completed_trainer_portal_training_program_path(program),
                    method: :patch,
                    class: "btn-feedback",
                    form: { style: "display: inline-block" },
                    data: { turbo_confirm: "Are you sure you want to mark this program as completed?" } do %>
                  <i class="bi bi-check-circle me-1"></i> Mark Completed
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <% if @training_programs.empty? %>
      <div class="col-12">
        <div class="empty-state">
          <div class="empty-icon"><i class="bi bi-mortarboard"></i></div>
          <h5 class="empty-title">No Training Programs Found</h5>
          <p class="empty-text">You do not have any assigned programs yet.</p>
        </div>
      </div>
    <% end %>
  </div>
</div>

<% content_for :styles do %>
  <style>
    .trainer-dashboard {
      max-width: 1400px;
    }

    .hero-card {
      position: relative;
      background: #ffffff;
      border-radius: 24px;
      border: 1px solid rgba(148, 163, 184, 0.15);
      box-shadow: 0 6px 24px rgba(15, 23, 42, 0.06);
      overflow: hidden;
    }
    .hero-accent {
      position: absolute;
      inset: 0;
      background: radial-gradient(900px 260px at 10% -10%, rgba(99, 102, 241, 0.18), transparent 55%),
                  radial-gradient(800px 240px at 90% -20%, rgba(14, 165, 233, 0.15), transparent 55%);
      pointer-events: none;
    }
    .hero-content {
      position: relative;
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 1.5rem;
      align-items: center;
      padding: 2rem;
    }
    .profile-badge {
      width: 72px;
      height: 72px;
      border-radius: 18px;
      background: linear-gradient(135deg, #6366f1, #22d3ee);
      color: #ffffff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 1.75rem;
      box-shadow: 0 10px 30px rgba(99, 102, 241, 0.35);
    }
    .profile-name {
      margin: 0;
      font-weight: 700;
      font-size: 1.65rem;
      color: #0f172a;
      letter-spacing: -0.02em;
    }
    .profile-subtitle {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 0.5rem;
      color: #64748b;
      font-size: 0.95rem;
      align-items: center;
    }
    .dot-divider {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: rgba(148, 163, 184, 0.6);
      display: inline-block;
    }
    .btn-hero {
      background: #0f172a;
      color: #ffffff;
      padding: 0.75rem 1.5rem;
      border-radius: 14px;
      text-decoration: none;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      transition: all 0.3s ease;
      white-space: nowrap;
    }
    .btn-hero:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.2);
      color: #ffffff;
    }

    .stat-card {
      background: #ffffff;
      border-radius: 18px;
      border: 1px solid rgba(148, 163, 184, 0.12);
      padding: 1.25rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      box-shadow: 0 4px 18px rgba(15, 23, 42, 0.05);
      height: 100%;
    }
    .stat-icon {
      width: 48px;
      height: 48px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.25rem;
      color: #0f172a;
    }
    .bg-primary-soft { background: rgba(99, 102, 241, 0.15); color: #4f46e5; }
    .bg-success-soft { background: rgba(34, 197, 94, 0.15); color: #16a34a; }
    .bg-info-soft { background: rgba(56, 189, 248, 0.16); color: #0284c7; }
    .bg-warning-soft { background: rgba(245, 158, 11, 0.2); color: #d97706; }
    .stat-label {
      margin: 0;
      color: #64748b;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .stat-value {
      margin: 0.25rem 0 0;
      font-size: 1.5rem;
      font-weight: 700;
      color: #0f172a;
    }

    .section-header {
      margin-bottom: 1.25rem;
    }
    .section-header h4 {
      margin: 0;
      font-weight: 700;
      color: #0f172a;
    }
    .section-header p {
      margin: 0.35rem 0 0;
      color: #64748b;
    }

    .program-card {
      background: #ffffff;
      border-radius: 20px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
      border: 1px solid rgba(148, 163, 184, 0.1);
      overflow: hidden;
      transition: all 0.3s ease;
    }
    .program-card:hover {
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
      transform: translateY(-4px);
    }
    .card-header-modern {
      padding: 1.5rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.1);
      display: flex;
      justify-content: space-between;
      align-items: start;
      gap: 1rem;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.02), rgba(168, 85, 247, 0.02));
    }
    .program-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #1e293b;
      margin: 0;
      line-height: 1.4;
      overflow: hidden;
      text-overflow: ellipsis;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }
    .card-body-modern {
      padding: 1.5rem;
    }
    .program-description {
      color: #64748b;
      line-height: 1.6;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
    }

    .status-badge {
      padding: 0.5rem 1rem;
      font-size: 0.8rem;
      font-weight: 600;
      border-radius: 12px;
      display: inline-flex;
      align-items: center;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .status-completed {
      background: linear-gradient(135deg, rgba(34, 197, 94, 0.15), rgba(16, 185, 129, 0.15));
      color: #059669;
    }
    .status-active {
      background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(99, 102, 241, 0.15));
      color: #2563eb;
    }

    .info-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .info-item {
      display: flex;
      align-items: start;
      gap: 0.875rem;
      padding: 0.875rem;
      border-radius: 12px;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.02), rgba(168, 85, 247, 0.02));
      border: 1px solid rgba(148, 163, 184, 0.06);
      transition: all 0.3s ease;
    }
    .info-item:hover {
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.05), rgba(168, 85, 247, 0.05));
      border-color: rgba(99, 102, 241, 0.15);
      transform: translateX(4px);
    }
    .info-icon {
      width: 36px;
      height: 36px;
      border-radius: 10px;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(129, 140, 248, 0.1));
      display: flex;
      align-items: center;
      justify-content: center;
      color: #6366f1;
      font-size: 1rem;
      flex-shrink: 0;
    }
    .info-content {
      flex: 1;
      min-width: 0;
    }
    .info-label {
      display: block;
      color: #94a3b8;
      font-size: 0.7rem;
      font-weight: 500;
      margin-bottom: 0.25rem;
      text-transform: uppercase;
      letter-spacing: 0.3px;
    }
    .info-value {
      display: block;
      color: #1e293b;
      font-weight: 600;
      font-size: 0.9rem;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .action-buttons {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      align-items: stretch;
    }
    .btn-view {
      flex: 1 1 180px;
      min-width: 140px;
      max-width: 100%;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(129, 140, 248, 0.1));
      border: 1px solid rgba(99, 102, 241, 0.2);
      color: #6366f1;
      padding: 0.75rem 1.25rem;
      border-radius: 12px;
      font-weight: 600;
      font-size: 0.875rem;
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      text-align: center;
    }
    .btn-view:hover {
      background: linear-gradient(135deg, #6366f1, #818cf8);
      border-color: #6366f1;
      color: white;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(99, 102, 241, 0.3);
    }
    .btn-secondary {
      flex: 1 1 140px;
      min-width: 120px;
      max-width: 100%;
      background: #ffffff;
      border: 1px solid rgba(148, 163, 184, 0.5);
      color: #475569;
      padding: 0.75rem 1.25rem;
      border-radius: 12px;
      font-weight: 600;
      font-size: 0.875rem;
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      text-decoration: none;
      white-space: nowrap;
      justify-content: center;
      text-align: center;
    }
    .btn-secondary:hover {
      border-color: #6366f1;
      color: #6366f1;
      box-shadow: 0 6px 20px rgba(99, 102, 241, 0.12);
      transform: translateY(-2px);
    }
    .btn-feedback {
      flex: 1 1 200px;
      min-width: 160px;
      max-width: 100%;
      background: linear-gradient(135deg, #6366f1, #818cf8);
      border: none;
      color: white;
      padding: 0.75rem 1.25rem;
      border-radius: 12px;
      font-weight: 600;
      font-size: 0.875rem;
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      text-decoration: none;
      white-space: nowrap;
      justify-content: center;
      text-align: center;
    }
    .btn-feedback:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(99, 102, 241, 0.4);
      color: white;
    }
    .btn-feedback-done {
      flex: 1 1 200px;
      min-width: 160px;
      max-width: 100%;
      background: linear-gradient(135deg, rgba(34, 197, 94, 0.15), rgba(16, 185, 129, 0.15));
      border: 1px solid rgba(34, 197, 94, 0.2);
      color: #059669;
      padding: 0.75rem 1.25rem;
      border-radius: 12px;
      font-weight: 600;
      font-size: 0.875rem;
      display: inline-flex;
      align-items: center;
      cursor: not-allowed;
      opacity: 0.8;
      white-space: nowrap;
      justify-content: center;
      text-align: center;
    }

    .empty-state {
      background: #ffffff;
      border-radius: 20px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
      border: 1px solid rgba(148, 163, 184, 0.1);
      padding: 4rem 2rem;
      text-align: center;
    }
    .empty-icon {
      width: 96px;
      height: 96px;
      border-radius: 50%;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(168, 85, 247, 0.1));
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
    }
    .empty-icon i {
      font-size: 3rem;
      color: #94a3b8;
    }
    .empty-title {
      font-weight: 700;
      color: #1e293b;
      margin-bottom: 0.75rem;
    }
    .empty-text {
      color: #64748b;
      margin: 0;
      font-size: 0.95rem;
    }

    @media (max-width: 992px) {
      .hero-content {
        grid-template-columns: auto 1fr;
      }
      .hero-actions {
        grid-column: 1 / -1;
      }
    }
    @media (max-width: 768px) {
      .hero-content {
        grid-template-columns: 1fr;
        text-align: left;
      }
      .profile-badge {
        width: 64px;
        height: 64px;
        font-size: 1.5rem;
      }
      .profile-name {
        font-size: 1.4rem;
      }
      .action-buttons {
        flex-direction: column;
        align-items: stretch;
        gap: 0.6rem;
      }
      .btn-view,
      .btn-secondary,
      .btn-feedback,
      .btn-feedback-done {
        width: 100%;
      }
    }
  </style>
<% end %>
