<div class="container py-4 trainer-attendance-history">
  <div class="page-header-card mb-4">
    <div class="header-icon">
      <i class="bi bi-clock-history"></i>
    </div>
    <div>
      <h4 class="header-title">Attendance History</h4>
      <p class="header-subtitle"><%= @training_program.title %></p>
    </div>
    <div class="ms-auto d-flex align-items-center gap-2 flex-wrap">
      <%= link_to export_history_csv_trainer_portal_attendances_path(training_program_id: @training_program.id, format: :csv),
          class: "btn-export" do %>
        <i class="bi bi-file-earmark-excel me-1"></i> Export
      <% end %>
      <%= link_to trainer_portal_attendances_path, class: "btn-back" do %>
        <i class="bi bi-arrow-left me-1"></i> Back
      <% end %>
    </div>
  </div>

  <div class="table-card">
    <div class="table-card-header">
      <div>
        <h5>Daily Attendance Matrix</h5>
        <p class="table-subtitle">Edit any date from the column header.</p>
      </div>
      <span class="table-chip"><%= pluralize(@attendance_dates.count, "day") %></span>
    </div>

    <div class="card-body">
      <% if @attendance_dates.any? %>
        <div class="table-responsive">
          <table class="table table-bordered modern-table">
            <thead>
              <tr>
                <th>Participant</th>
                <% @attendance_dates.each do |date| %>
                  <th class="text-center">
                    <div class="date-header">
                      <span><%= date.strftime("%b %d") %></span>
                      <%= link_to edit_trainer_portal_attendance_path(@training_program, date: date),
                          class: "date-edit" do %>
                        <i class="bi bi-pencil-square"></i>
                      <% end %>
                    </div>
                  </th>
                <% end %>
                <th class="text-center">Attendance %</th>
              </tr>
            </thead>
            <tbody>
              <% @participants.each do |participant| %>
                <tr>
                  <td>
                    <div class="participant-cell">
                      <div class="participant-avatar">
                        <%= participant.user.first_name&.first&.upcase || participant.user.email.first.upcase %>
                      </div>
                      <div>
                        <div class="participant-name"><%= participant.user.full_name %></div>
                        <div class="participant-meta"><%= participant.user.email %></div>
                      </div>
                    </div>
                  </td>
                  <% @attendance_dates.each do |date| %>
                    <% attendance = @attendance_records[date]&.[](participant.id) %>
                    <td class="text-center">
                      <% if attendance %>
                        <% case attendance.status %>
                        <% when "present" %>
                          <span class="status-pill status-present">
                            <i class="bi bi-check-lg"></i> Present
                          </span>
                        <% when "absent" %>
                          <span class="status-pill status-absent">
                            <i class="bi bi-x-lg"></i> Absent
                          </span>
                        <% when "late" %>
                          <span class="status-pill status-late">
                            <i class="bi bi-clock"></i> Late
                          </span>
                        <% end %>
                      <% else %>
                        <span class="status-pill status-na">N/A</span>
                      <% end %>
                    </td>
                  <% end %>
                  <td class="text-center">
                    <% percentage = @training_program.attendance_percentage_for(participant) %>
                    <div class="d-flex align-items-center justify-content-center gap-2 flex-wrap">
                      <div class="progress slim-progress">
                        <div class="progress-bar bg-<%= percentage >= 75 ? 'success' : (percentage >= 50 ? 'warning' : 'danger') %>"
                             role="progressbar"
                             style="width: <%= percentage %>%"></div>
                      </div>
                      <span class="percentage-text"><%= percentage %>%</span>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="empty-state">
          <div class="empty-icon">
            <i class="bi bi-calendar-x"></i>
          </div>
          <h5 class="empty-title">No Attendance Records</h5>
          <p class="empty-text">No attendance records found for this training program.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<% content_for :styles do %>
  <style>
    .trainer-attendance-history {
      max-width: 1600px;
    }
    .page-header-card {
      background: #ffffff;
      border-radius: 20px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
      border: 1px solid rgba(148, 163, 184, 0.1);
      padding: 1.75rem 2rem;
      display: flex;
      align-items: center;
      gap: 1.25rem;
      flex-wrap: wrap;
    }
    .header-icon {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(129, 140, 248, 0.1));
      display: flex;
      align-items: center;
      justify-content: center;
      color: #6366f1;
      font-size: 1.75rem;
      flex-shrink: 0;
    }
    .header-title {
      font-weight: 700;
      color: #1e293b;
      margin: 0;
      font-size: 1.75rem;
      letter-spacing: -0.02em;
    }
    .header-subtitle {
      font-size: 0.95rem;
      color: #94a3b8;
      margin: 0.25rem 0 0;
    }
    .btn-back,
    .btn-export {
      background: #ffffff;
      border: 1px solid rgba(148, 163, 184, 0.4);
      color: #475569;
      padding: 0.6rem 1.1rem;
      border-radius: 12px;
      font-weight: 600;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      transition: all 0.3s ease;
      white-space: nowrap;
    }
    .btn-export {
      border-color: rgba(34, 197, 94, 0.5);
      color: #059669;
    }
    .btn-export:hover {
      background: rgba(34, 197, 94, 0.12);
      transform: translateY(-2px);
    }
    .btn-back:hover {
      border-color: #6366f1;
      color: #6366f1;
      box-shadow: 0 6px 18px rgba(99, 102, 241, 0.12);
      transform: translateY(-2px);
    }

    .table-card {
      background: #ffffff;
      border-radius: 20px;
      border: 1px solid rgba(148, 163, 184, 0.1);
      box-shadow: 0 4px 18px rgba(15, 23, 42, 0.05);
      overflow: hidden;
    }
    .table-card-header {
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.1);
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.03), rgba(168, 85, 247, 0.03));
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .table-card-header h5 {
      margin: 0;
      font-weight: 700;
      color: #1e293b;
    }
    .table-subtitle {
      margin: 0.25rem 0 0;
      color: #94a3b8;
      font-size: 0.85rem;
    }
    .table-chip {
      background: rgba(99, 102, 241, 0.12);
      color: #4f46e5;
      border-radius: 999px;
      padding: 0.3rem 0.9rem;
      font-weight: 600;
      font-size: 0.8rem;
    }

    .modern-table thead th {
      background: #f8fafc;
      color: #475569;
      font-weight: 600;
      border-bottom: 1px solid rgba(148, 163, 184, 0.2);
      padding: 1rem 1.25rem;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .modern-table tbody td {
      padding: 1rem 1.25rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.12);
      vertical-align: middle;
      color: #1e293b;
    }
    .modern-table tbody tr:hover {
      background: rgba(99, 102, 241, 0.04);
    }

    .date-header {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.35rem;
    }
    .date-edit {
      color: #6366f1;
      text-decoration: none;
      font-size: 0.85rem;
    }
    .date-edit:hover {
      color: #4f46e5;
    }

    .participant-cell {
      display: flex;
      align-items: center;
      gap: 0.9rem;
    }
    .participant-avatar {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      background: rgba(99, 102, 241, 0.12);
      color: #4f46e5;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 1rem;
      flex-shrink: 0;
    }
    .participant-name {
      font-weight: 600;
      color: #0f172a;
    }
    .participant-meta {
      color: #94a3b8;
      font-size: 0.85rem;
    }

    .status-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.35rem 0.75rem;
      border-radius: 12px;
      font-weight: 600;
      font-size: 0.78rem;
      border: 1px solid transparent;
    }
    .status-present {
      background: rgba(34, 197, 94, 0.15);
      color: #059669;
      border-color: rgba(34, 197, 94, 0.35);
    }
    .status-absent {
      background: rgba(239, 68, 68, 0.15);
      color: #dc2626;
      border-color: rgba(239, 68, 68, 0.35);
    }
    .status-late {
      background: rgba(245, 158, 11, 0.18);
      color: #b45309;
      border-color: rgba(245, 158, 11, 0.35);
    }
    .status-na {
      background: rgba(148, 163, 184, 0.2);
      color: #64748b;
      border-color: rgba(148, 163, 184, 0.35);
    }

    .progress {
      background-color: #e9ecef;
      border-radius: 999px;
      overflow: hidden;
      width: 90px;
      height: 10px;
    }
    .progress-bar {
      display: flex;
      flex-direction: column;
      justify-content: center;
      overflow: hidden;
      color: #fff;
      text-align: center;
      white-space: nowrap;
      transition: width 0.6s ease;
    }
    .percentage-text {
      font-weight: 600;
      color: #475569;
    }
    .slim-progress {
      width: 90px;
    }

    .empty-state {
      background: #ffffff;
      border-radius: 20px;
      padding: 4rem 2rem;
      text-align: center;
    }
    .empty-icon {
      width: 96px;
      height: 96px;
      border-radius: 50%;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(168, 85, 247, 0.1));
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
    }
    .empty-icon i {
      font-size: 3rem;
      color: #94a3b8;
    }
    .empty-title {
      font-weight: 700;
      color: #1e293b;
      margin-bottom: 0.75rem;
    }
    .empty-text {
      color: #64748b;
      margin: 0;
      font-size: 0.95rem;
    }

    @media (max-width: 768px) {
      .page-header-card {
        padding: 1.5rem;
        gap: 0.875rem;
      }
      .header-icon {
        width: 48px;
        height: 48px;
        font-size: 1.5rem;
      }
      .header-title {
        font-size: 1.25rem;
      }
      .btn-back,
      .btn-export {
        width: 100%;
        justify-content: center;
      }
    }
  </style>
<% end %> 
