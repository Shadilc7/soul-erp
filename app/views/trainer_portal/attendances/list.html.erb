<div class="container py-4 trainer-attendance-list" data-controller="program-filter">
  <div class="page-header-card mb-4">
    <div class="header-icon">
      <i class="bi bi-calendar-check"></i>
    </div>
    <div>
      <h4 class="header-title">Training Programs Attendance</h4>
      <p class="header-subtitle">Track daily status and manage attendance quickly</p>
    </div>
    <div class="ms-auto d-flex align-items-center gap-3 flex-wrap">
      <div class="form-check form-switch mb-0">
        <input class="form-check-input" type="checkbox" id="show-completed" checked data-program-filter-target="toggle" data-action="change->program-filter#toggleCompleted">
        <label class="form-check-label" for="show-completed">Show Completed Programs</label>
      </div>
      <%= link_to trainer_portal_attendances_path, class: "btn-back" do %>
        <i class="bi bi-calendar-check me-1"></i> Attendance Management
      <% end %>
    </div>
  </div>

  <div class="table-card">
    <div class="table-card-header">
      <h5>Programs Overview</h5>
      <span class="table-chip"><%= pluralize(@training_programs.count, "program") %></span>
    </div>

    <div class="card-body">
      <% if @training_programs.any? %>
        <div class="table-responsive">
          <table class="table table-hover modern-table">
            <thead>
              <tr>
                <th>Program</th>
                <th>Type</th>
                <th>Duration</th>
                <th>Participants</th>
                <th>Attendance Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @training_programs.each do |program| %>
                <% status = @attendance_status[program.id] %>
                <tr class="<%= !status[:active] ? 'row-muted' : (status[:marked_today] ? 'row-highlight' : '') %>" data-program-status="<%= program.completed? ? 'completed' : 'active' %>" <%= program.completed? ? 'data-program-filter-target="completedRow"' : '' %>>
                  <td>
                    <div class="program-cell">
                      <div class="program-icon"><i class="bi bi-mortarboard"></i></div>
                      <div>
                        <div class="program-name"><%= program.title %></div>
                        <div class="program-meta">
                          <% if program.completed? %>
                            <span class="status-pill status-completed">Completed</span>
                          <% elsif program.ongoing? %>
                            <span class="status-pill status-ongoing">Ongoing</span>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <% if program.individual? %>
                      <span class="type-pill type-individual">Individual</span>
                    <% else %>
                      <span class="type-pill type-section">Section</span>
                      <div class="small text-muted mt-1"><%= program.section&.name %></div>
                    <% end %>
                  </td>
                  <td>
                    <div class="duration-text">
                      <div><strong>Start:</strong> <%= program.start_date.strftime("%b %d, %Y") %></div>
                      <div><strong>End:</strong> <%= program.end_date.strftime("%b %d, %Y") %></div>
                    </div>
                  </td>
                  <td>
                    <span class="count-pill"><%= status[:total_participants] %></span>
                  </td>
                  <td>
                    <div>
                      <% if status[:marked_today] %>
                        <span class="status-pill status-marked">Marked Today</span>
                      <% else %>
                        <span class="status-pill status-not-marked">Not Marked Today</span>
                      <% end %>
                    </div>
                    <div class="small text-muted mt-1">
                      Total days marked: <%= status[:total_days_marked] %>
                    </div>
                  </td>
                  <td>
                    <div class="action-buttons">
                      <% if program.ongoing? %>
                        <%= link_to mark_trainer_portal_attendance_path(program, date: @today),
                            class: "btn-primary-cta #{'disabled' if status[:marked_today]}",
                            title: status[:marked_today] ? "Already marked today" : "Mark attendance for today" do %>
                          <i class="bi bi-plus-circle"></i> Mark
                        <% end %>

                        <% if status[:marked_today] %>
                          <%= link_to edit_trainer_portal_attendance_path(program, date: @today),
                              class: "btn-secondary-cta",
                              title: "Edit today's attendance" do %>
                            <i class="bi bi-pencil"></i> Edit
                          <% end %>
                        <% end %>
                      <% end %>

                      <%= link_to history_trainer_portal_attendance_path(program),
                          class: "btn-tertiary-cta",
                          title: "View attendance history" do %>
                        <i class="bi bi-clock-history"></i> History
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="empty-state">
          <div class="empty-icon">
            <i class="bi bi-calendar-x"></i>
          </div>
          <h5 class="empty-title">No Training Programs Found</h5>
          <p class="empty-text">You don't have any programs assigned yet.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<% content_for :styles do %>
  <style>
    .trainer-attendance-list {
      max-width: 1400px;
    }
    .page-header-card {
      background: #ffffff;
      border-radius: 20px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
      border: 1px solid rgba(148, 163, 184, 0.1);
      padding: 1.75rem 2rem;
      display: flex;
      align-items: center;
      gap: 1.25rem;
      flex-wrap: wrap;
    }
    .header-icon {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(129, 140, 248, 0.1));
      display: flex;
      align-items: center;
      justify-content: center;
      color: #6366f1;
      font-size: 1.75rem;
      flex-shrink: 0;
    }
    .header-title {
      font-weight: 700;
      color: #1e293b;
      margin: 0;
      font-size: 1.75rem;
      letter-spacing: -0.02em;
    }
    .header-subtitle {
      font-size: 0.95rem;
      color: #94a3b8;
      margin: 0.25rem 0 0;
    }
    .btn-back {
      background: #ffffff;
      border: 1px solid rgba(148, 163, 184, 0.4);
      color: #475569;
      padding: 0.6rem 1.1rem;
      border-radius: 12px;
      font-weight: 600;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      transition: all 0.3s ease;
      white-space: nowrap;
    }
    .btn-back:hover {
      border-color: #6366f1;
      color: #6366f1;
      box-shadow: 0 6px 18px rgba(99, 102, 241, 0.12);
      transform: translateY(-2px);
    }

    .table-card {
      background: #ffffff;
      border-radius: 20px;
      border: 1px solid rgba(148, 163, 184, 0.1);
      box-shadow: 0 4px 18px rgba(15, 23, 42, 0.05);
      overflow: hidden;
    }
    .table-card-header {
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.1);
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.03), rgba(168, 85, 247, 0.03));
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .table-card-header h5 {
      margin: 0;
      font-weight: 700;
      color: #1e293b;
    }
    .table-chip {
      background: rgba(99, 102, 241, 0.12);
      color: #4f46e5;
      border-radius: 999px;
      padding: 0.3rem 0.9rem;
      font-weight: 600;
      font-size: 0.8rem;
    }

    .modern-table thead th {
      background: #f8fafc;
      color: #475569;
      font-weight: 600;
      border-bottom: 1px solid rgba(148, 163, 184, 0.2);
      padding: 1rem 1.25rem;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .modern-table tbody td {
      padding: 1rem 1.25rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.12);
      vertical-align: middle;
      color: #1e293b;
    }
    .modern-table tbody tr:hover {
      background: rgba(99, 102, 241, 0.04);
    }
    .row-muted {
      background: rgba(148, 163, 184, 0.12);
    }
    .row-highlight {
      background: rgba(34, 197, 94, 0.08);
    }

    .program-cell {
      display: flex;
      align-items: center;
      gap: 0.9rem;
    }
    .program-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      background: rgba(99, 102, 241, 0.12);
      color: #4f46e5;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      flex-shrink: 0;
    }
    .program-name {
      font-weight: 600;
      color: #0f172a;
    }
    .program-meta {
      margin-top: 0.35rem;
    }
    .status-pill {
      padding: 0.3rem 0.7rem;
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.75rem;
      display: inline-flex;
      align-items: center;
      gap: 0.2rem;
    }
    .status-completed {
      background: rgba(148, 163, 184, 0.2);
      color: #475569;
    }
    .status-ongoing {
      background: rgba(34, 197, 94, 0.15);
      color: #059669;
    }
    .status-marked {
      background: rgba(34, 197, 94, 0.15);
      color: #059669;
    }
    .status-not-marked {
      background: rgba(245, 158, 11, 0.15);
      color: #b45309;
    }
    .type-pill {
      padding: 0.4rem 0.9rem;
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.75rem;
      white-space: nowrap;
    }
    .type-section {
      background: rgba(59, 130, 246, 0.15);
      color: #2563eb;
    }
    .type-individual {
      background: rgba(99, 102, 241, 0.15);
      color: #4f46e5;
    }
    .duration-text {
      color: #64748b;
      font-size: 0.9rem;
    }
    .count-pill {
      display: inline-flex;
      align-items: center;
      background: rgba(15, 23, 42, 0.08);
      color: #1e293b;
      padding: 0.35rem 0.7rem;
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.8rem;
    }
    .action-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .btn-primary-cta,
    .btn-secondary-cta,
    .btn-tertiary-cta {
      padding: 0.45rem 0.85rem;
      border-radius: 10px;
      font-weight: 600;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      transition: all 0.3s ease;
      white-space: nowrap;
      font-size: 0.85rem;
    }
    .btn-primary-cta {
      background: linear-gradient(135deg, #6366f1, #818cf8);
      color: #ffffff;
      border: none;
    }
    .btn-primary-cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(99, 102, 241, 0.35);
      color: #ffffff;
    }
    .btn-secondary-cta {
      background: #ffffff;
      border: 1px solid rgba(148, 163, 184, 0.5);
      color: #475569;
    }
    .btn-secondary-cta:hover {
      border-color: #6366f1;
      color: #6366f1;
      box-shadow: 0 6px 18px rgba(99, 102, 241, 0.12);
      transform: translateY(-2px);
    }
    .btn-tertiary-cta {
      background: rgba(59, 130, 246, 0.12);
      color: #2563eb;
      border: 1px solid rgba(59, 130, 246, 0.2);
    }
    .btn-tertiary-cta:hover {
      background: rgba(59, 130, 246, 0.2);
      transform: translateY(-2px);
      color: #2563eb;
    }

    .empty-state {
      background: #ffffff;
      border-radius: 20px;
      padding: 4rem 2rem;
      text-align: center;
    }
    .empty-icon {
      width: 96px;
      height: 96px;
      border-radius: 50%;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(168, 85, 247, 0.1));
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
    }
    .empty-icon i {
      font-size: 3rem;
      color: #94a3b8;
    }
    .empty-title {
      font-weight: 700;
      color: #1e293b;
      margin-bottom: 0.75rem;
    }
    .empty-text {
      color: #64748b;
      margin: 0;
      font-size: 0.95rem;
    }

    @media (max-width: 768px) {
      .page-header-card {
        padding: 1.5rem;
        gap: 0.875rem;
      }
      .header-icon {
        width: 48px;
        height: 48px;
        font-size: 1.5rem;
      }
      .header-title {
        font-size: 1.25rem;
      }
      .btn-back {
        width: 100%;
        justify-content: center;
      }
      .action-buttons {
        flex-direction: column;
      }
      .btn-primary-cta,
      .btn-secondary-cta,
      .btn-tertiary-cta {
        width: 100%;
        justify-content: center;
      }
    }
  </style>
<% end %> 
