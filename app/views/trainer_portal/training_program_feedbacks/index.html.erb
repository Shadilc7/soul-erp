<div class="container py-4 trainer-feedbacks">
  <div class="page-header-card mb-4">
    <div class="header-icon">
      <i class="bi bi-chat-square-text"></i>
    </div>
    <div>
      <h4 class="header-title">Training Program Feedbacks</h4>
      <p class="header-subtitle">Review ratings and insights from your programs</p>
    </div>
  </div>

  <div class="table-card">
    <div class="table-card-header">
      <h5>Programs & Ratings</h5>
      <span class="table-chip"><%= pluralize(@training_programs.count, "program") %></span>
    </div>

    <div class="table-responsive">
      <table class="table table-hover modern-table">
        <thead>
          <tr>
            <th>Program</th>
            <th>Type</th>
            <th>Duration</th>
            <th>Feedbacks</th>
            <th>Average Rating</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @training_programs.each do |program| %>
            <tr>
              <td>
                <div class="program-cell">
                  <div class="program-icon"><i class="bi bi-mortarboard"></i></div>
                  <div>
                    <div class="program-name"><%= program.title %></div>
                    <div class="program-meta">
                      <%= program.section ? "Section: #{program.section.name}" : "Individual" %>
                    </div>
                  </div>
                </div>
              </td>
              <td>
                <span class="type-pill type-<%= program.program_type == "section" ? "section" : "individual" %>">
                  <%= program.program_type.titleize %>
                </span>
              </td>
              <td>
                <span class="duration-text"><%= program.start_date.strftime("%b %d") %> - <%= program.end_date.strftime("%b %d, %Y") %></span>
              </td>
              <td>
                <span class="count-pill">
                  <i class="bi bi-chat-dots me-1"></i>
                  <%= pluralize(program.training_program_feedbacks.count, "feedback") %>
                </span>
              </td>
              <td>
                <% if program.training_program_feedbacks.any? %>
                  <% avg_rating = program.training_program_feedbacks.average(:rating).to_f.round(1) %>
                  <div class="rating-inline">
                    <span class="rating-score"><%= avg_rating %>/5</span>
                    <span class="rating-stars">
                      <% avg_rating.floor.times do %>
                        <i class="bi bi-star-fill"></i>
                      <% end %>
                      <% if avg_rating - avg_rating.floor >= 0.5 %>
                        <i class="bi bi-star-half"></i>
                        <% (4 - avg_rating.floor).times do %>
                          <i class="bi bi-star"></i>
                        <% end %>
                      <% else %>
                        <% (5 - avg_rating.floor).times do %>
                          <i class="bi bi-star"></i>
                        <% end %>
                      <% end %>
                    </span>
                  </div>
                <% else %>
                  <span class="rating-empty">No ratings yet</span>
                <% end %>
              </td>
              <td>
                <%= link_to trainer_portal_training_program_feedback_path(program), class: "btn-view" do %>
                  <i class="bi bi-eye me-1"></i> View
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @training_programs.empty? %>
      <div class="empty-state">
        <div class="empty-icon">
          <i class="bi bi-chat-square-text"></i>
        </div>
        <h5 class="empty-title">No Training Programs Found</h5>
        <p class="empty-text">Feedbacks will appear once programs receive ratings.</p>
      </div>
    <% end %>
  </div>
</div>

<% content_for :styles do %>
  <style>
    .trainer-feedbacks {
      max-width: 1400px;
    }

    .page-header-card {
      background: #ffffff;
      border-radius: 20px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
      border: 1px solid rgba(148, 163, 184, 0.1);
      padding: 1.75rem 2rem;
      display: flex;
      align-items: center;
      gap: 1.25rem;
    }
    .header-icon {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(129, 140, 248, 0.1));
      display: flex;
      align-items: center;
      justify-content: center;
      color: #6366f1;
      font-size: 1.75rem;
      flex-shrink: 0;
    }
    .header-title {
      font-weight: 700;
      color: #1e293b;
      margin: 0;
      font-size: 1.75rem;
      letter-spacing: -0.02em;
    }
    .header-subtitle {
      font-size: 0.95rem;
      color: #94a3b8;
      margin: 0.25rem 0 0;
    }

    .type-pill {
      padding: 0.4rem 0.9rem;
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.75rem;
      white-space: nowrap;
    }
    .type-section {
      background: rgba(59, 130, 246, 0.15);
      color: #2563eb;
    }
    .type-individual {
      background: rgba(99, 102, 241, 0.15);
      color: #4f46e5;
    }

    .table-card {
      background: #ffffff;
      border-radius: 20px;
      border: 1px solid rgba(148, 163, 184, 0.1);
      box-shadow: 0 4px 18px rgba(15, 23, 42, 0.05);
      overflow: hidden;
    }
    .table-card-header {
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.1);
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.03), rgba(168, 85, 247, 0.03));
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .table-card-header h5 {
      margin: 0;
      font-weight: 700;
      color: #1e293b;
    }
    .table-chip {
      background: rgba(99, 102, 241, 0.12);
      color: #4f46e5;
      border-radius: 999px;
      padding: 0.3rem 0.9rem;
      font-weight: 600;
      font-size: 0.8rem;
    }
    .modern-table thead th {
      background: #f8fafc;
      color: #475569;
      font-weight: 600;
      border-bottom: 1px solid rgba(148, 163, 184, 0.2);
      padding: 1rem 1.25rem;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .modern-table tbody td {
      padding: 1rem 1.25rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.12);
      vertical-align: middle;
      color: #1e293b;
    }
    .modern-table tbody tr:hover {
      background: rgba(99, 102, 241, 0.04);
    }

    .program-cell {
      display: flex;
      align-items: center;
      gap: 0.9rem;
    }
    .program-icon {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      background: rgba(99, 102, 241, 0.12);
      color: #4f46e5;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      flex-shrink: 0;
    }
    .program-name {
      font-weight: 600;
      color: #0f172a;
    }
    .program-meta {
      color: #94a3b8;
      font-size: 0.85rem;
    }
    .duration-text {
      color: #64748b;
      font-weight: 500;
      font-size: 0.9rem;
    }
    .count-pill {
      display: inline-flex;
      align-items: center;
      background: rgba(59, 130, 246, 0.12);
      color: #2563eb;
      padding: 0.35rem 0.7rem;
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.8rem;
      gap: 0.25rem;
    }
    .rating-inline {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      flex-wrap: wrap;
    }
    .rating-score {
      font-weight: 600;
      color: #0f172a;
    }
    .rating-stars {
      display: inline-flex;
      gap: 0.15rem;
      color: #f59e0b;
      font-size: 0.95rem;
    }
    .rating-stars .bi-star {
      color: #cbd5f5;
    }
    .rating-empty {
      color: #94a3b8;
      font-weight: 500;
      font-size: 0.9rem;
    }

    .btn-view {
      flex: 1 1 180px;
      min-width: 140px;
      max-width: 100%;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(129, 140, 248, 0.1));
      border: 1px solid rgba(99, 102, 241, 0.2);
      color: #6366f1;
      padding: 0.75rem 1.25rem;
      border-radius: 12px;
      font-weight: 600;
      font-size: 0.875rem;
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      text-align: center;
    }
    .btn-view:hover {
      background: linear-gradient(135deg, #6366f1, #818cf8);
      border-color: #6366f1;
      color: white;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(99, 102, 241, 0.3);
    }

    .empty-state {
      background: #ffffff;
      border-radius: 20px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
      border: 1px solid rgba(148, 163, 184, 0.1);
      padding: 4rem 2rem;
      text-align: center;
    }
    .empty-icon {
      width: 96px;
      height: 96px;
      border-radius: 50%;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(168, 85, 247, 0.1));
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
    }
    .empty-icon i {
      font-size: 3rem;
      color: #94a3b8;
    }
    .empty-title {
      font-weight: 700;
      color: #1e293b;
      margin-bottom: 0.75rem;
    }
    .empty-text {
      color: #64748b;
      margin: 0;
      font-size: 0.95rem;
    }

    @media (max-width: 768px) {
      .page-header-card {
        padding: 1.5rem;
        gap: 0.875rem;
      }
      .header-icon {
        width: 48px;
        height: 48px;
        font-size: 1.5rem;
      }
      .header-title {
        font-size: 1.25rem;
      }
      .action-buttons {
        flex-direction: column;
      }
      .btn-view {
        width: 100%;
      }
    }
  </style>
<% end %>
