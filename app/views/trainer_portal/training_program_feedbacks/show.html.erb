<div class="container py-4 trainer-feedbacks-show">
  <div class="page-header-card mb-4">
    <div class="header-icon">
      <i class="bi bi-chat-square-text"></i>
    </div>
    <div>
      <h4 class="header-title">Feedbacks</h4>
      <p class="header-subtitle"><%= @training_program.title %></p>
    </div>
    <div class="ms-auto">
      <%= link_to trainer_portal_training_program_feedbacks_path, class: "btn-back" do %>
        <i class="bi bi-arrow-left"></i> Back to Programs
      <% end %>
    </div>
  </div>

  <div class="table-card">
    <div class="table-card-header">
      <div>
        <h5>Participant Feedbacks</h5>
        <p class="table-subtitle">All feedback submissions for this program</p>
      </div>
      <span class="table-chip"><%= pluralize(@feedbacks.count, "feedback") %></span>
    </div>

    <% if @feedbacks.any? %>
      <div class="table-responsive">
        <table class="table table-hover modern-table">
          <thead>
            <tr>
              <th>Participant</th>
              <th>Rating</th>
              <th>Feedback</th>
              <th>Submitted On</th>
            </tr>
          </thead>
          <tbody>
            <% @feedbacks.each do |feedback| %>
              <tr>
                <td>
                  <div class="participant-cell">
                    <div class="participant-avatar">
                      <%= feedback.participant.user.first_name&.first&.upcase || feedback.participant.user.email.first.upcase %>
                    </div>
                    <div>
                      <div class="participant-name"><%= feedback.participant.user.full_name %></div>
                      <div class="participant-meta"><%= feedback.participant.user.email %></div>
                    </div>
                  </div>
                </td>
                <td>
                  <div class="rating-inline">
                    <span class="rating-score"><%= feedback.rating %>/5</span>
                    <span class="rating-stars">
                      <% feedback.rating.times do %>
                        <i class="bi bi-star-fill"></i>
                      <% end %>
                      <% (5 - feedback.rating).times do %>
                        <i class="bi bi-star"></i>
                      <% end %>
                    </span>
                  </div>
                </td>
                <td>
                  <span class="feedback-text"><%= feedback.content %></span>
                </td>
                <td>
                  <span class="date-text"><%= feedback.created_at.strftime("%b %d, %Y %I:%M %p") %></span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="empty-state">
        <div class="empty-icon">
          <i class="bi bi-chat-square-text"></i>
        </div>
        <h5 class="empty-title">No Feedbacks Yet</h5>
        <p class="empty-text">Feedback submissions will appear here once participants respond.</p>
      </div>
    <% end %>
  </div>
</div>

<% content_for :styles do %>
  <style>
    .trainer-feedbacks-show {
      max-width: 1400px;
    }
    .page-header-card {
      background: #ffffff;
      border-radius: 20px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
      border: 1px solid rgba(148, 163, 184, 0.1);
      padding: 1.75rem 2rem;
      display: flex;
      align-items: center;
      gap: 1.25rem;
      flex-wrap: wrap;
    }
    .header-icon {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(129, 140, 248, 0.1));
      display: flex;
      align-items: center;
      justify-content: center;
      color: #6366f1;
      font-size: 1.75rem;
      flex-shrink: 0;
    }
    .header-title {
      font-weight: 700;
      color: #1e293b;
      margin: 0;
      font-size: 1.75rem;
      letter-spacing: -0.02em;
    }
    .header-subtitle {
      font-size: 0.95rem;
      color: #94a3b8;
      margin: 0.25rem 0 0;
    }
    .btn-back {
      background: #ffffff;
      border: 1px solid rgba(148, 163, 184, 0.4);
      color: #475569;
      padding: 0.6rem 1.1rem;
      border-radius: 12px;
      font-weight: 600;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      transition: all 0.3s ease;
      white-space: nowrap;
    }
    .btn-back:hover {
      border-color: #6366f1;
      color: #6366f1;
      box-shadow: 0 6px 18px rgba(99, 102, 241, 0.12);
      transform: translateY(-2px);
    }

    .table-card {
      background: #ffffff;
      border-radius: 20px;
      border: 1px solid rgba(148, 163, 184, 0.1);
      box-shadow: 0 4px 18px rgba(15, 23, 42, 0.05);
      overflow: hidden;
    }
    .table-card-header {
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.1);
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.03), rgba(168, 85, 247, 0.03));
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .table-card-header h5 {
      margin: 0;
      font-weight: 700;
      color: #1e293b;
    }
    .table-subtitle {
      margin: 0.25rem 0 0;
      color: #94a3b8;
      font-size: 0.85rem;
    }
    .table-chip {
      background: rgba(99, 102, 241, 0.12);
      color: #4f46e5;
      border-radius: 999px;
      padding: 0.3rem 0.9rem;
      font-weight: 600;
      font-size: 0.8rem;
    }

    .modern-table thead th {
      background: #f8fafc;
      color: #475569;
      font-weight: 600;
      border-bottom: 1px solid rgba(148, 163, 184, 0.2);
      padding: 1rem 1.25rem;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .modern-table tbody td {
      padding: 1rem 1.25rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.12);
      vertical-align: middle;
      color: #1e293b;
    }
    .modern-table tbody tr:hover {
      background: rgba(99, 102, 241, 0.04);
    }

    .participant-cell {
      display: flex;
      align-items: center;
      gap: 0.9rem;
    }
    .participant-avatar {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      background: rgba(99, 102, 241, 0.12);
      color: #4f46e5;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 1rem;
      flex-shrink: 0;
    }
    .participant-name {
      font-weight: 600;
      color: #0f172a;
    }
    .participant-meta {
      color: #94a3b8;
      font-size: 0.85rem;
    }
    .rating-inline {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      flex-wrap: wrap;
    }
    .rating-score {
      font-weight: 600;
      color: #0f172a;
    }
    .rating-stars {
      display: inline-flex;
      gap: 0.15rem;
      color: #f59e0b;
      font-size: 0.95rem;
    }
    .rating-stars .bi-star {
      color: #cbd5f5;
    }
    .feedback-text {
      color: #475569;
      display: block;
      max-width: 420px;
      white-space: normal;
    }
    .date-text {
      color: #64748b;
      font-size: 0.9rem;
    }

    .empty-state {
      background: #ffffff;
      border-radius: 20px;
      padding: 4rem 2rem;
      text-align: center;
    }
    .empty-icon {
      width: 96px;
      height: 96px;
      border-radius: 50%;
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(168, 85, 247, 0.1));
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
    }
    .empty-icon i {
      font-size: 3rem;
      color: #94a3b8;
    }
    .empty-title {
      font-weight: 700;
      color: #1e293b;
      margin-bottom: 0.75rem;
    }
    .empty-text {
      color: #64748b;
      margin: 0;
      font-size: 0.95rem;
    }

    @media (max-width: 768px) {
      .page-header-card {
        padding: 1.5rem;
        gap: 0.875rem;
      }
      .header-icon {
        width: 48px;
        height: 48px;
        font-size: 1.5rem;
      }
      .header-title {
        font-size: 1.25rem;
      }
      .btn-back {
        width: 100%;
        justify-content: center;
      }
    }
  </style>
<% end %>
