<div class="container-fluid py-4">
  <!-- Breadcrumb -->
  <div class="breadcrumb-wrapper d-flex justify-content-between align-items-center mb-4">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb breadcrumb-custom mb-0">
        <li class="breadcrumb-item"><%= link_to institute_admin_root_path do %><i class="bi bi-house-door"></i><% end %></li>
        <li class="breadcrumb-item"><%= link_to "Settings", institute_admin_settings_path %></li>
        <li class="breadcrumb-item active" aria-current="page">General Settings</li>
      </ol>
    </nav>
    <%= link_to institute_admin_settings_path, class: "btn btn-sm btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i> Back
    <% end %>
  </div>

  <div class="card card-custom">
    <div class="card-header card-header-custom py-3">
      <div class="d-flex justify-content-between align-items-center">
        <h5 class="mb-0">General Settings</h5>
        <div></div>
      </div>
    </div>
    <div class="card-body">
      <%= form_with(model: @institute, url: institute_admin_general_settings_path, method: :patch, multipart: true, class: "needs-validation") do |form| %>
        <% if @institute.errors.any? %>
          <div class="alert alert-danger mb-4">
            <h6 class="alert-heading mb-2"><%= pluralize(@institute.errors.count, "error") %> prohibited this institute from being saved:</h6>
            <ul class="mb-0">
              <% @institute.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="form-group mb-3">
          <%= form.label :name, class: "form-label" %>
          <%= form.text_field :name, class: "form-control" %>
        </div>

        <div class="form-group mb-3">
          <%= form.label :code, class: "form-label" %>
          <%= form.text_field :code, class: "form-control" %>
        </div>

        <div class="form-group mb-3">
          <%= form.label :description, class: "form-label" %>
          <%= form.text_area :description, rows: 3, class: "form-control" %>
        </div>

        <div class="form-group mb-3">
          <%= form.label :address, class: "form-label" %>
          <%= form.text_area :address, rows: 3, class: "form-control" %>
        </div>

        <div class="form-group mb-3">
          <%= form.label :contact_number, class: "form-label" %>
          <%= form.text_field :contact_number, class: "form-control" %>
        </div>

        <div class="form-group mb-3">
          <%= form.label :email, class: "form-label" %>
          <%= form.email_field :email, class: "form-control" %>
        </div>

        <div class="form-group mb-3">
          <%= form.label :registered_poc, "Registered Point of Contact", class: "form-label" %>
          <%= form.text_field :registered_poc, class: "form-control" %>
        </div>

        <div class="form-group mb-3">
          <%= form.label :owner_name, class: "form-label" %>
          <%= form.text_field :owner_name, class: "form-control" %>
        </div>

        <div class="form-group mb-3">
          <%= form.label :service_started_on, class: "form-label" %>
          <%= form.date_field :service_started_on, class: "form-control" %>
        </div>

        <div class="form-group mb-3">
          <%= form.label :expiry_date, class: "form-label" %>
          <%= form.date_field :expiry_date, class: "form-control" %>
        </div>

        <div class="form-group mb-3">
          <%= form.label :age_of_service, class: "form-label" %>
          <%= form.number_field :age_of_service, class: "form-control" %>
        </div>

        <div class="form-group mb-3">
          <%= form.label :billing_type, class: "form-label" %>
          <%= form.select :billing_type, 
            [['Monthly', 'monthly'], ['Yearly', 'yearly'], ['One-time', 'one_time']], 
            { include_blank: 'Select billing type' }, 
            { class: "form-select" } %>
        </div>

        <div class="form-group mb-3">
          <%= form.label :other_details, class: "form-label" %>
          <%= form.text_area :other_details, rows: 3, class: "form-control" %>
        </div>

        <!-- Institute Logo -->
        <div class="form-group mb-4">
          <label class="form-label fw-semibold">Institute Logo</label>
          <% if @institute.logo.attached? %>
            <div class="mb-2 d-flex align-items-center gap-3">
              <%= image_tag url_for(@institute.logo), alt: "Current logo",
                    style: "max-height:80px;max-width:200px;object-fit:contain;border:1px solid #dee2e6;border-radius:6px;padding:6px;background:#fafafa;" %>
              <div>
                <p class="mb-1 text-muted small">Current logo</p>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" name="institute[remove_logo]" value="1" id="remove_logo">
                  <label class="form-check-label text-danger small" for="remove_logo">Remove logo</label>
                </div>
              </div>
            </div>
          <% end %>
          <%= form.file_field :logo, class: "form-control",
                accept: "image/png,image/jpeg,image/gif,image/webp",
                id: "logo_upload" %>
          <small class="text-muted">PNG, JPG or GIF · max 2 MB · Recommended: transparent background</small>
          <div class="mt-2" id="logo_preview_container" style="display:none;">
            <img id="logo_preview" src="#" alt="Preview"
                 style="max-height:80px;max-width:200px;object-fit:contain;border:1px solid #dee2e6;border-radius:6px;padding:6px;background:#fafafa;">
          </div>
        </div>

        <div class="d-flex justify-content-end">
          <%= form.submit "Update Settings", class: "btn btn-primary px-4" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  document.getElementById('logo_upload')?.addEventListener('change', function() {
    const file = this.files[0];
    const container = document.getElementById('logo_preview_container');
    const preview = document.getElementById('logo_preview');
    if (file) {
      preview.src = URL.createObjectURL(file);
      container.style.display = 'block';
    } else {
      container.style.display = 'none';
    }
  });
</script>

<style>
  /* Modern Breadcrumb Styling */
  .breadcrumb-wrapper {
    background-color: #f8f9fa;
    border-radius: 8px;
    padding: 0.75rem 1rem;
  }
  
  .breadcrumb-custom {
    margin-bottom: 0;
    padding: 0;
    background: transparent;
  }
  
  .breadcrumb-custom .breadcrumb-item {
    font-size: 0.875rem;
    font-weight: 500;
  }
  
  .breadcrumb-custom .breadcrumb-item a {
    color: #6c757d;
    text-decoration: none;
    transition: color 0.2s;
  }
  
  .breadcrumb-custom .breadcrumb-item a:hover {
    color: var(--bs-primary);
  }
  
  .breadcrumb-custom .breadcrumb-item.active {
    color: var(--bs-primary);
    font-weight: 600;
  }
  
  .breadcrumb-custom .breadcrumb-item+.breadcrumb-item::before {
    content: "›";
    color: #adb5bd;
    font-size: 1rem;
    line-height: 1;
    padding: 0 0.5rem;
  }
</style>