<%= form_with(model: [:institute_admin, certificate_configuration], local: true) do |form| %>
  <% if certificate_configuration.errors.any? %>
    <div class="alert alert-danger">
      <h6>Please fix the following errors:</h6>
      <ul class="mb-0">
        <% certificate_configuration.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :name, "Certificate Name", class: "form-label" %>
    <%= form.text_field :name, class: "form-control", placeholder: "Enter certificate name" %>
    <small class="form-text text-muted">Example: Course Completion Certificate, Achievement Certificate</small>
  </div>

  <div class="mb-3">
    <%= form.label :details, "Certificate Details", class: "form-label" %>
    <%= form.text_area :details, class: "form-control", rows: 3, placeholder: "Enter certificate details (optional)" %>
    <small class="form-text text-muted">Enter a description of when this certificate is awarded</small>
  </div>

  <div class="mb-3">
    <%= form.label :duration_period, "Interval Period (days)", class: "form-label" %>
    <%= form.number_field :duration_period, class: "form-control", min: 5, max: 30, placeholder: "Enter interval period in days (5-30)" %>
    <small class="form-text text-muted">Number of days for each result interval on the certificate. Must be between 5 and 30 days (e.g., 5 for 1st-5th day, 6th-10th day, etc.)</small>
  </div>

  <div class="mb-3">
    <%= form.label :eligible_criteria, "Eligible Criteria (%)", class: "form-label" %>
    <div class="input-group">
      <%= form.number_field :eligible_criteria, class: "form-control", min: 0, max: 100, step: 0.01, placeholder: "Enter percentage (e.g., 75.00)" %>
      <span class="input-group-text">%</span>
    </div>
    <small class="form-text text-muted">Minimum percentage required to be eligible for this certificate (0-100)</small>
  </div>

  <div class="mb-3">
    <%= form.label :certificate_left_footer, "Certificate Left Footer", class: "form-label" %>
    <%= form.text_field :certificate_left_footer, class: "form-control", placeholder: "Enter left footer text (optional)" %>
    <small class="form-text text-muted">Text to appear at the bottom left of the certificate</small>
  </div>

  <div class="mb-3">
    <%= form.label :certificate_right_footer, "Certificate Right Footer", class: "form-label" %>
    <%= form.text_field :certificate_right_footer, class: "form-control", placeholder: "Enter right footer text (optional)" %>
    <small class="form-text text-muted">Text to appear at the bottom right of the certificate</small>
  </div>

  <div class="mb-3">
    <%= form.label :status, "Status", class: "form-label" %>
    <%= form.select :status, 
      CertificateConfiguration.statuses.keys.map { |status| [status.titleize, status] },
      {}, { class: "form-select" } %>
  </div>

  <div class="form-actions mt-4">
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", institute_admin_certificate_configurations_path, class: "btn btn-secondary ms-2" %>
  </div>
<% end %> 