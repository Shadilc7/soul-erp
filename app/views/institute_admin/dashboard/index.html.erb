<!-- Institute Admin Dashboard -->
<div class="container-fluid py-4">
  <!-- KPI Cards Row 1 -->
  <div class="row g-4 mb-4">
    <!-- Total Participants -->
    <div class="col-xl-3 col-md-6">
      <div class="card card-custom h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="card-title text-muted mb-2">Total Participants</h6>
              <h2 class="mb-0"><%= @total_participants %></h2>
            </div>
            <div class="icon-box bg-opacity-10">
              <i class="bi bi-people fs-1 text-primary"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Total Questions -->
    <div class="col-xl-3 col-md-6">
      <div class="card card-custom h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="card-title text-muted mb-2">Total Questions</h6>
              <h2 class="mb-0"><%= @total_questions %></h2>
            </div>
            <div class="icon-box bg-opacity-10">
              <i class="bi bi-question-circle fs-1 text-success"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Total Assignments -->
    <div class="col-xl-3 col-md-6">
      <div class="card card-custom h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="card-title text-muted mb-2">Total Assignments</h6>
              <h2 class="mb-0"><%= @total_assignments %></h2>
            </div>
            <div class="icon-box bg-opacity-10">
              <i class="bi bi-clipboard-check fs-1 text-warning"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Total Sections -->
    <div class="col-xl-3 col-md-6">
      <div class="card card-custom h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="card-title text-muted mb-2">Total Sections</h6>
              <h2 class="mb-0"><%= @total_sections %></h2>
            </div>
            <div class="icon-box  bg-opacity-10">
              <i class="bi bi-grid fs-1 text-danger"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Submissions Over Time (14 days) -->
  <div class="row g-4 mb-4">
    <div class="col-12">
      <div class="card card-custom h-100">
        <div class="card-header border-0 pt-3 d-flex justify-content-between align-items-center">
          <h5 class="card-title mb-0">Submissions Over Time (14 days)</h5>
          <small class="text-muted">Distinct submissions per assignment & participant</small>
        </div>
        <div class="card-body">
          <div id="submissions-over-time-chart" style="height: 320px;"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Submissions by Assignment (Today) -->
  <div class="row g-4 mb-4">
    <div class="col-xl-6">
      <div class="card card-custom h-100">
        <div class="card-header border-0 pt-3 d-flex justify-content-between align-items-center">
          <h5 class="card-title mb-0">Submissions by Assignment (Today)</h5>
          <small class="text-muted">Top 10 assignments by participants submitted</small>
        </div>
        <div class="card-body">
          <div id="submissions-by-assignment-chart" style="height: 360px;"></div>
          <!-- Chart UI cleaned: debug block removed -->
        </div>
      </div>
    </div>
    <div class="col-xl-6">
      <div class="card card-custom h-100">
        <div class="card-header border-0 pt-3 d-flex justify-content-between align-items-center">
          <h5 class="card-title mb-0">Submissions by Section (Today)</h5>
          <small class="text-muted">Top sections by distinct submissions</small>
        </div>
        <div class="card-body">
          <div id="submissions-by-section-chart" style="height:360px;"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- KPI Cards Row 2 -->
  <!-- Charts: Not-submitted (full width), Pending by Section (full width), Backlog Trend (full width) -->
  <div class="row g-4 mb-4">
    <div class="col-xl-6">
      <div class="card card-custom h-100">
        <div class="card-header border-0 pt-3">
          <h5 class="card-title mb-0">Not Submitted by Assignment (Top 10)</h5>
        </div>
        <div class="card-body">
          <div id="not-submitted-assignment-chart" style="height:320px;"></div>
        </div>
      </div>
    </div>
    <div class="col-xl-6">
      <div class="card card-custom h-100">
        <div class="card-header border-0 pt-3">
          <h5 class="card-title mb-0">Pending by Section (Top 10)</h5>
        </div>
        <div class="card-body">
          <div id="pending-section-chart" style="height:320px;"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-4 mb-4">
    <div class="col-12">
      <div class="card card-custom h-100">
        <div class="card-header border-0 pt-3">
          <h5 class="card-title mb-0">Backlog Trend (14 days)</h5>
        </div>
        <div class="card-body">
          <div id="backlog-trend-chart" style="height:320px;"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-4 mb-4">
    <!-- Today Responses (moved to row 2 first column) -->
    <div class="col-xl-3 col-md-6">
      <div class="card card-custom h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="card-title text-muted mb-2">Today Responses</h6>
              <h2 class="mb-0"><%= @today_responses_count || 0 %></h2>
            </div>
            <div class="icon-box bg-opacity-10">
              <i class="bi bi-file-earmark-check fs-1 text-success"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Total Trainers -->
    <div class="col-xl-3 col-md-6">
      <div class="card card-custom h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="card-title text-muted mb-2">Total Trainers</h6>
              <h2 class="mb-0"><%= @total_trainers %></h2>
            </div>
            <div class="icon-box bg-opacity-10">
              <i class="bi bi-person-workspace fs-1 text-primary"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Training Programs -->
    <div class="col-xl-3 col-md-6">
      <div class="card card-custom h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="card-title text-muted mb-2">Training Programs</h6>
              <h2 class="mb-0"><%= @total_training_programs %></h2>
            </div>
            <div class="icon-box bg-opacity-10">
              <i class="bi bi-mortarboard fs-1 text-success"></i>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Feedback Received -->
    <div class="col-xl-3 col-md-6">
      <div class="card card-custom h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h6 class="card-title text-muted mb-2">Feedback Received</h6>
              <h2 class="mb-0"><%= @total_feedback_received || 0 %></h2>
            </div>
            <div class="icon-box bg-opacity-10">
              <i class="bi bi-chat-square-text fs-1 text-info"></i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Charts Row -->
  <div class="row g-4 mb-4">
    <!-- Participants by Section -->
    <div class="col-xl-6">
      <div class="card card-custom h-100">
        <div class="card-header border-0 pt-3">
          <h5 class="card-title mb-0">Participants by Section</h5>
        </div>
        <div class="card-body">
          <!-- Participants by Section Chart Container -->
          <div id="participants-section-chart"></div>
        </div>
      </div>
    </div>

    <!-- Participants by Type -->
    <div class="col-xl-6">
      <div class="card card-custom h-100">
        <div class="card-header border-0 pt-3">
          <h5 class="card-title mb-0">Participants by Type</h5>
        </div>
        <div class="card-body">
          <!-- Participants by Type Chart Container -->
          <div id="participants-type-chart"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Feedback: Overview (left) and Training Program Chart (right) -->
  <div class="row g-4 mb-4 align-items-stretch">
    <div class="col-xl-4 col-md-6">
      <div class="card card-custom h-100">
        <div class="card-header border-0 pt-3">
          <h5 class="card-title mb-0">Feedback Overview</h5>
        </div>
  <div class="card-body d-flex flex-column justify-content-center h-100">
          <div class="mb-3">
            <h6 class="text-muted mb-2">Feedback Received</h6>
            <div class="progress" style="height: 25px; background: #f1f5f9;">
              <div class="progress-bar" role="progressbar"
                   style="width: <%= @feedback_received_percentage || 0 %>%; background: linear-gradient(90deg, #8b5cf6 0%, #06b6d4 100%); color: #04263a; font-weight:600;"
                   aria-valuenow="<%= @feedback_received_percentage || 0 %>"
                   aria-valuemin="0" aria-valuemax="100">
                <%= @feedback_received_percentage || 0 %>%
              </div>
            </div>
            <div class="d-flex justify-content-between mt-2">
              <small class="text-muted">Total: <%= @total_feedback_received || 0 %></small>
              <small class="text-muted">Target: 100%</small>
            </div>
          </div>
          <div class="mb-3">
            <h6 class="text-muted mb-2">Feedback Pending</h6>
            <div class="progress" style="height: 25px; background: #f1f5f9;">
              <div class="progress-bar" role="progressbar"
                   style="width: <%= @feedback_pending_percentage || 0 %>%; background: linear-gradient(90deg, #fb7185 0%, #fb923c 100%); color: #4a2b00; font-weight:600;"
                   aria-valuenow="<%= @feedback_pending_percentage || 0 %>"
                   aria-valuemin="0" aria-valuemax="100">
                <%= @feedback_pending_percentage || 0 %>%
              </div>
            </div>
            <div class="d-flex justify-content-between mt-2">
              <small class="text-muted">Total: <%= @total_feedback_pending || 0 %></small>
              <small class="text-muted">Target: 0%</small>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-8 col-md-6">
      <div class="card card-custom h-100">
        <div class="card-header border-0 pt-3">
          <h5 class="card-title mb-0">Feedback by Training Program</h5>
        </div>
        <div class="card-body">
          <!-- Feedback by Training Program Chart Container -->
          <div id="feedback-training-chart" style="min-height:320px;"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent Training Programs Table -->
  <div class="card card-custom">
    <div class="card-header border-0 pt-3">
      <div class="d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">Recent Training Programs</h5>
        <%= link_to "View All", institute_admin_training_programs_path, class: "btn btn-sm btn-primary" %>
      </div>
    </div>
    <div class="card-body">
      <div class="table-responsive">
        <% if @recent_programs.present? %>
          <table class="table table-hover">
            <thead>
              <tr>
                <th>Program</th>
                <th>Participants</th>
                <th>Feedback Rate</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @recent_programs.each do |program| %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center">
                      <div class="program-icon me-2">
                        <i class="bi bi-book text-primary"></i>
                      </div>
                      <div>
                        <%= program.title %>
                        <br>
                        <small class="text-muted"><%= program.start_date&.strftime("%b %d, %Y") %></small>
                      </div>
                    </div>
                  </td>
                  <td><%= program.participants_count %></td>
                  <td>
                    <div class="progress" style="height: 6px; width: 120px;">
                      <div class="progress-bar bg-success" role="progressbar" 
                           style="width: <%= program.feedback_percentage %>%" 
                           aria-valuenow="<%= program.feedback_percentage %>" 
                           aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <small class="text-muted"><%= program.feedback_percentage %>%</small>
                  </td>
                  <td>
                    <span class="badge bg-<%= program.status == 'ongoing' ? 'success' : 'secondary' %>">
                      <%= program.status %>
                    </span>
                  </td>
                  <td>
                    <%= link_to institute_admin_training_program_path(program), class: "btn btn-sm btn-light" do %>
                      <i class="bi bi-eye"></i>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="alert alert-info">No recent training programs found</div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  // Track if we're on the dashboard page
  let isDashboardPage = true;
  
  // Function to initialize dashboard charts
  function initializeDashboardCharts() {
    if (!isDashboardPage) return;
    
  // initializing dashboard charts
    
    // Check if chart containers exist before initializing
    var sectionChartContainer = document.querySelector("#participants-section-chart");
    var typeChartContainer = document.querySelector("#participants-type-chart");
    var feedbackChartContainer = document.querySelector("#feedback-training-chart");

    // Only destroy and recreate charts if we're on the dashboard page
    if (window.sectionChart) {
  // destroying existing section chart
      window.sectionChart.destroy();
    }
    if (window.typeChart) {
  // destroying existing type chart
      window.typeChart.destroy();
    }
    if (window.feedbackChart) {
  // destroying existing feedback chart
      window.feedbackChart.destroy();
    }

    if (sectionChartContainer) {
  // initializing Participants by Section Chart
      var sectionChartOptions = {
        chart: { 
          type: 'bar', 
          height: 350,
          toolbar: {
            show: true,
            tools: {
              download: true,
              selection: false,
              zoom: false,
              zoomin: false,
              zoomout: false,
              pan: false,
              reset: false
            }
          },
          animations: {
            enabled: true,
            easing: 'easeinout',
            speed: 800,
            animateGradually: {
              enabled: true,
              delay: 150
            },
            dynamicAnimation: {
              enabled: true,
              speed: 350
            }
          }
        },
        series: [{
          name: 'Participants',
          data: <%= @section_data[:participants] %>
        }, {
          name: 'Capacity',
          data: <%= @section_data[:capacity] %>
        }],
        plotOptions: {
          bar: {
            horizontal: false,
            columnWidth: '70%',
            borderRadius: 0,
            dataLabels: {
              position: 'top'
            }
          }
        },
        dataLabels: {
          enabled: true,
          offsetY: -25,
          style: {
            fontSize: '12px',
            fontWeight: 600,
            colors: ['#4f46e5', '#818cf8']
          },
          background: {
            enabled: false
          }
        },
        stroke: {
          show: true,
          width: 2,
          colors: ['transparent']
        },
        xaxis: { 
          categories: <%= raw @section_labels.to_json %>,
          labels: {
            style: {
              colors: '#64748b',
              fontSize: '12px',
              fontWeight: 500
            }
          },
          axisBorder: {
            show: true,
            color: '#e2e8f0'
          },
          axisTicks: {
            show: true,
            color: '#e2e8f0'
          }
        },
        yaxis: {
          title: {
            text: 'Count',
            style: {
              color: '#64748b',
              fontSize: '13px',
              fontWeight: 600
            }
          },
          labels: {
            style: {
              colors: '#64748b',
              fontSize: '12px'
            }
          }
        },
        colors: ['#6366f1', '#a5b4fc'],
        fill: {
          opacity: 1,
          type: 'gradient',
          gradient: {
            shade: 'light',
            type: 'vertical',
            shadeIntensity: 0.3,
            gradientToColors: ['#4f46e5', '#c7d2fe'],
            inverseColors: false,
            opacityFrom: 1,
            opacityTo: 0.85,
            stops: [0, 100]
          }
        },
        legend: {
          position: 'bottom',
          horizontalAlign: 'left',
          fontSize: '13px',
          fontWeight: 500,
          offsetY: 20,
          labels: {
            colors: '#475569'
          },
          markers: {
            width: 12,
            height: 12,
            radius: 3
          },
          itemMargin: {
            horizontal: 10,
            vertical: 5
          }
        },
        grid: {
          borderColor: '#f1f5f9',
          strokeDashArray: 3,
          xaxis: {
            lines: {
              show: false
            }
          },
          yaxis: {
            lines: {
              show: true
            }
          },
          padding: {
            top: 0,
            right: 10,
            bottom: 0,
            left: 10
          }
        },
        tooltip: {
          theme: 'light',
          shared: true,
          intersect: false,
          style: {
            fontSize: '13px',
            fontFamily: 'inherit'
          },
          x: {
            show: true,
            formatter: function(val) {
              return val;
            }
          },
          y: {
            formatter: function(val, opts) {
              var seriesName = opts.w.globals.seriesNames[opts.seriesIndex];
              return seriesName + ': ' + val;
            },
            title: {
              formatter: function() {
                return '';
              }
            }
          },
          marker: {
            show: true
          },
          custom: undefined
        },
        responsive: [{
          breakpoint: 768,
          options: {
            plotOptions: {
              bar: {
                columnWidth: '80%'
              }
            },
            dataLabels: {
              style: {
                fontSize: '10px'
              }
            }
          }
        }]
      };
      window.sectionChart = new ApexCharts(sectionChartContainer, sectionChartOptions);
      window.sectionChart.render();
    }
      // Submissions over time chart (Apex)
      var submissionsContainer = document.querySelector('#submissions-over-time-chart');
      if (window.submissionsChart) {
        try { window.submissionsChart.destroy(); } catch(e) { /* ignore */ }
      }
      if (submissionsContainer) {
  // initializing Submissions Over Time Chart
        var submissionsOptions = {
          chart: { type: 'area', height: 320, toolbar: { show: true }, animations: { enabled: true, easing: 'easeinout', speed: 700 } },
          series: [{ name: 'Submissions', data: <%= @submissions_time_data.to_json.html_safe %> }],
          stroke: { curve: 'smooth', width: 3 },
          markers: { size: 4, strokeColors: '#ffffff', hover: { sizeOffset: 2 } },
          colors: ['#0d6efd'],
          fill: { type: 'gradient', gradient: { shade: 'light', type: 'vertical', shadeIntensity: 1, opacityFrom: 0.45, opacityTo: 0.04 } },
          xaxis: { categories: <%= raw @submissions_time_labels.to_json %>, labels: { rotate: -35, style: { fontSize: '12px' } } },
          yaxis: { title: { text: 'Submissions' }, min: 0 },
          tooltip: { x: { format: 'dd MMM' }, y: { formatter: function(val){ return val + ' submissions'; } } },
          legend: { show: false },
          grid: { borderColor: '#eef2f6' },
          responsive: [{
            breakpoint: 768,
            options: { chart: { height: 260 }, xaxis: { labels: { rotate: -20 } } }
          }]
        };

        window.submissionsChart = new ApexCharts(submissionsContainer, submissionsOptions);
        window.submissionsChart.render();
      }

      // Submissions by Assignment (bar)
      var byAssignmentContainer = document.querySelector('#submissions-by-assignment-chart');
      if (window.byAssignmentChart) { try { window.byAssignmentChart.destroy(); } catch(e) {} }
  if (byAssignmentContainer) {
        // nicer visuals: gradient fill, rounded bars, adaptive label truncation
        var assignOptions = {
          chart: { type: 'bar', height: 360, toolbar: { show: true } },
          series: [{ name: 'Participants', data: <%= raw @assignment_data.to_json %> }],
          plotOptions: { 
            bar: { 
              horizontal: false, 
              columnWidth: '55%', 
              borderRadius: 0, 
              distributed: false 
            } 
          },
          dataLabels: { enabled: true, formatter: function(val){ return val; }, style: { fontSize: '12px', colors: ['#243b53'] } },
          xaxis: { 
            categories: <%= raw @assignment_labels.to_json %>, 
            labels: { 
              rotate: -35, 
              style: { fontSize: '12px' },
              formatter: function(val) { return val.length > 24 ? val.substring(0,21) + '...' : val; }
            } 
          },
          yaxis: { title: { text: 'Participants' }, min: 0 },
          colors: [function({ value, seriesIndex, w }){ return '#06b6d4' }],
          fill: { type: 'gradient', gradient: { shade: 'light', type: 'vertical', shadeIntensity: 0.6, gradientToColors: ['#06b6d4'], inverseColors: false, opacityFrom: 0.95, opacityTo: 0.6, stops: [0, 100] } },
          tooltip: { y: { formatter: function(val){ return val + ' participants'; } }, x: { formatter: function(val){ return val; } } },
          legend: { show: false },
          responsive: [{
            breakpoint: 768,
            options: {
              chart: { height: 300 },
              plotOptions: { bar: { columnWidth: '70%' } },
              xaxis: { labels: { rotate: -20 } }
            }
          }]
        };

        window.byAssignmentChart = new ApexCharts(byAssignmentContainer, assignOptions);
        window.byAssignmentChart.render();
      }

      // Submissions by Section (today) - placed beside assignments
      var bySectionContainer = document.querySelector('#submissions-by-section-chart');
      if (window.bySectionChart) { try { window.bySectionChart.destroy(); } catch(e) {} }
      if (bySectionContainer) {
        var sectionOptions = {
          chart: { type: 'bar', height: 360, toolbar: { show: true } },
          series: [{ name: 'Submissions', data: <%= raw @submissions_section_data.to_json %> }],
          plotOptions: { bar: { horizontal: false, columnWidth: '55%', borderRadius: 0 } },
          dataLabels: { enabled: true, style: { fontSize: '12px' }, formatter: function(val){ return val; } },
          xaxis: { categories: <%= raw @submissions_section_labels.to_json %>, labels: { rotate: -35, style: { fontSize: '12px' }, formatter: function(val){ return val.length > 24 ? val.substring(0,21) + '...' : val; } } },
          yaxis: { title: { text: 'Submissions' }, min: 0 },
          colors: ['#f97316'],
          fill: { type: 'gradient', gradient: { shade: 'light', type: 'vertical', shadeIntensity: 0.6, gradientToColors: ['#fb923c'], inverseColors: false, opacityFrom: 0.95, opacityTo: 0.6, stops: [0, 100] } },
          tooltip: { y: { formatter: function(val){ return val + ' submissions'; } } },
          legend: { show: false },
          responsive: [{ breakpoint: 768, options: { chart: { height: 300 }, xaxis: { labels: { rotate: -20 } } } }]
        };

        window.bySectionChart = new ApexCharts(bySectionContainer, sectionOptions);
        window.bySectionChart.render();
      }

    if (typeChartContainer) {
  // initializing Participants by Type Pie Chart
      var optionsType = {
        chart: { 
          type: 'pie', 
          height: 350,
          animations: {
            enabled: true,
            easing: 'easeinout',
            speed: 800,
            animateGradually: {
              enabled: true,
              delay: 150
            },
            dynamicAnimation: {
              enabled: true,
              speed: 350
            }
          }
        },
        series: <%= @type_data %>,
        labels: <%= raw @type_labels.to_json %>,
        colors: ['#10b981', '#ec4899', '#8b5cf6'],
        fill: {
          type: 'gradient',
          gradient: {
            shade: 'dark',
            type: 'vertical',
            shadeIntensity: 0.5,
            gradientToColors: ['#059669', '#db2777', '#7c3aed'],
            inverseColors: false,
            opacityFrom: 1,
            opacityTo: 0.9,
            stops: [0, 100]
          }
        },
        stroke: {
          show: true,
          width: 2,
          colors: ['#ffffff']
        },
        dataLabels: {
          enabled: true,
          formatter: function(val) {
            return val.toFixed(1) + '%';
          },
          style: {
            fontSize: '14px',
            fontWeight: 600,
            colors: ['#ffffff']
          },
          dropShadow: {
            enabled: true,
            top: 1,
            left: 1,
            blur: 1,
            opacity: 0.5
          }
        },
        legend: {
          position: 'right',
          fontSize: '13px',
          fontWeight: 500,
          labels: {
            colors: '#475569'
          },
          markers: {
            width: 12,
            height: 12,
            radius: 3
          },
          itemMargin: {
            horizontal: 5,
            vertical: 5
          }
        },
        plotOptions: {
          pie: {
            expandOnClick: true,
            donut: {
              size: '0%'
            }
          }
        },
        tooltip: {
          theme: 'light',
          y: {
            formatter: function(val) {
              return val;
            }
          },
          style: {
            fontSize: '13px',
            fontFamily: 'inherit'
          }
        },
        responsive: [{
          breakpoint: 768,
          options: {
            chart: {
              height: 300
            },
            legend: {
              position: 'bottom'
            }
          }
        }]
      };
      window.typeChart = new ApexCharts(typeChartContainer, optionsType);
      window.typeChart.render();
    }

    if (feedbackChartContainer) {
  // initializing Feedback by Training Program Chart
      var feedbackChartOptions = {
        chart: { type: 'bar', height: 300 },
        series: [{
          name: 'Received',
          data: <%= @program_feedback_data.map { |d| d[:received].to_i } %>
        }, {
          name: 'Pending',
          data: <%= @program_feedback_data.map { |d| d[:pending].to_i } %>
        }],
        xaxis: { categories: <%= raw @program_feedback_data.map { |d| d[:name] }.to_json %> },
        colors: ['#8b5cf6', '#fb7185'],
        fill: { type: 'gradient', gradient: { shade: 'light', type: 'vertical', shadeIntensity: 0.6, gradientToColors: ['#06b6d4', '#fb923c'], inverseColors: false, opacityFrom: 0.95, opacityTo: 0.6, stops: [0, 100] } },
        tooltip: { y: { formatter: function(val){ return val + ' responses'; } } }
      };
      window.feedbackChart = new ApexCharts(feedbackChartContainer, feedbackChartOptions);
      window.feedbackChart.render();
    }

  // Completion chart removed

    // Not-submitted by Assignment (Top 10) - bar
    var notSubmittedContainer = document.querySelector('#not-submitted-assignment-chart');
    if (window.notSubmittedChart) { try { window.notSubmittedChart.destroy(); } catch(e) {} }
    if (notSubmittedContainer) {
      var notSubmittedOptions = {
        chart: { type: 'bar', height: 320 },
        series: [{ name: 'Pending', data: <%= raw @not_submitted_assignment_data.to_json %> }],
        xaxis: { categories: <%= raw @not_submitted_assignment_labels.to_json %>, labels: { rotate: -30, style: { fontSize: '12px' } } },
        plotOptions: { bar: { horizontal: false, columnWidth: '60%', borderRadius: 4 } },
        dataLabels: { enabled: true, style: { fontSize: '12px' } },
  colors: ['#FF5E62'],
  fill: { type: 'gradient', gradient: { shade: 'light', type: 'vertical', shadeIntensity: 0.6, gradientToColors: ['#FF2D95'], inverseColors: false, opacityFrom: 0.95, opacityTo: 0.6, stops: [0,100] } },
        tooltip: { y: { formatter: function(val){ return val + ' pending'; } } },
        legend: { show: false }
      };
      window.notSubmittedChart = new ApexCharts(notSubmittedContainer, notSubmittedOptions);
      window.notSubmittedChart.render();
    }

    // Pending by Section (Top 10) - bar
    var pendingSectionContainer = document.querySelector('#pending-section-chart');
    if (window.pendingSectionChart) { try { window.pendingSectionChart.destroy(); } catch(e) {} }
    if (pendingSectionContainer) {
      var pendingSectionOptions = {
        chart: { type: 'bar', height: 320 },
        series: [{ name: 'Pending', data: <%= raw @pending_section_data.to_json %> }],
        xaxis: { categories: <%= raw @pending_section_labels.to_json %>, labels: { rotate: -30, style: { fontSize: '12px' } } },
        plotOptions: { bar: { horizontal: false, columnWidth: '60%', borderRadius: 4 } },
        dataLabels: { enabled: true, style: { fontSize: '12px' } },
        colors: ['#8b5cf6'],
        fill: { type: 'gradient', gradient: { shade: 'light', type: 'vertical', shadeIntensity: 0.6, gradientToColors: ['#ec4899'], inverseColors: false, opacityFrom: 0.95, opacityTo: 0.6, stops: [0,100] } },
        tooltip: { y: { formatter: function(val){ return val + ' pending'; } } },
        legend: { show: false }
      };
      window.pendingSectionChart = new ApexCharts(pendingSectionContainer, pendingSectionOptions);
      window.pendingSectionChart.render();
    }

    // Backlog Trend (14 days)
    var backlogContainer = document.querySelector('#backlog-trend-chart');
    if (window.backlogChart) { try { window.backlogChart.destroy(); } catch(e) {} }
    if (backlogContainer) {
      var backlogOptions = {
        chart: { type: 'area', height: 220 },
        series: [{ name: 'Backlog', data: <%= raw @backlog_data.to_json %> }],
        xaxis: { categories: <%= raw @backlog_labels.to_json %>, labels: { rotate: -35, style: { fontSize: '11px' } } },
        stroke: { curve: 'smooth', width: 2 },
        colors: ['#ef4444'],
        fill: { type: 'gradient', gradient: { shade: 'light', type: 'vertical', opacityFrom: 0.45, opacityTo: 0.04 } },
        tooltip: { y: { formatter: function(val){ return val + ' pending'; } } },
        grid: { borderColor: '#eef2f6' }
      };
      window.backlogChart = new ApexCharts(backlogContainer, backlogOptions);
      window.backlogChart.render();
    }
  }

  // Initialize on first load
  document.addEventListener('DOMContentLoaded', initializeDashboardCharts);
  
  // Handle navigation to/from dashboard page
  document.addEventListener('turbo:load', function() {
    // Check if we're on the dashboard page by looking for chart containers
    isDashboardPage = document.querySelector("#participants-section-chart") !== null;
    
    if (isDashboardPage) {
  // dashboard page detected, initializing charts
      initializeDashboardCharts();
    } else {
  // not on dashboard page, skipping chart initialization
    }
  });

  // Clean up only when leaving dashboard page
  document.addEventListener('turbo:before-visit', function() {
    if (isDashboardPage) {
  // leaving dashboard page, cleaning up charts
      if (window.sectionChart) {
        window.sectionChart.destroy();
        window.sectionChart = null;
      }
      if (window.typeChart) {
        window.typeChart.destroy();
        window.typeChart = null;
      }
      if (window.feedbackChart) {
        window.feedbackChart.destroy();
        window.feedbackChart = null;
      }
    }
  });
</script>
