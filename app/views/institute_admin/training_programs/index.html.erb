<div class="card card-custom">
  <div class="card-header card-header-custom py-3">
    <div class="d-flex justify-content-between align-items-center">
      <h5 class="mb-0">Training Programs</h5>
      <%= link_to new_institute_admin_training_program_path, class: "btn btn-primary" do %>
        <i class="bi bi-plus-lg"></i> New Program
      <% end %>
    </div>
  </div>

<style>
  .action-btn {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    transition: all 0.3s ease;
    border: none;
    position: relative;
    overflow: hidden;
  }
  
  .action-btn::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
  }
  
  .action-btn:hover::before {
    width: 100px;
    height: 100px;
  }
  
  .action-btn i {
    font-size: 16px;
    position: relative;
    z-index: 1;
  }
  
  .btn-view {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    box-shadow: 0 4px 6px rgba(102, 126, 234, 0.3);
  }
  
  .btn-view:hover {
    background: linear-gradient(135deg, #5568d3 0%, #5a3a7f 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(102, 126, 234, 0.4);
    color: white;
  }
  
  .btn-edit {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    color: white;
    box-shadow: 0 4px 6px rgba(245, 87, 108, 0.3);
  }
  
  .btn-edit:hover {
    background: linear-gradient(135deg, #e082ea 0%, #e4465b 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(245, 87, 108, 0.4);
    color: white;
  }
  
  .btn-delete {
    background: linear-gradient(135deg, #ff6b6b 0%, #c92a2a 100%);
    color: white;
    box-shadow: 0 4px 6px rgba(255, 107, 107, 0.3);
  }
  
  .btn-delete:hover {
    background: linear-gradient(135deg, #ee5a5a 0%, #b81919 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(255, 107, 107, 0.4);
    color: white;
  }
  
  .btn-complete {
    background: linear-gradient(135deg, #4ade80 0%, #16a34a 100%);
    color: white;
    box-shadow: 0 4px 6px rgba(74, 222, 128, 0.3);
  }
  
  .btn-complete:hover {
    background: linear-gradient(135deg, #22c55e 0%, #15803d 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(74, 222, 128, 0.4);
    color: white;
  }
  
  .btn-completed {
    background: linear-gradient(135deg, #94a3b8 0%, #64748b 100%);
    color: white;
    box-shadow: 0 4px 6px rgba(148, 163, 184, 0.3);
    cursor: default;
  }
  
  .btn-completed:hover {
    background: linear-gradient(135deg, #94a3b8 0%, #64748b 100%);
    transform: none;
    color: white;
  }
  
  .action-btn:active {
    transform: translateY(0);
  }
  
  /* Mobile optimization */
  @media (max-width: 768px) {
    .action-btn {
      width: 32px;
      height: 32px;
      margin: 2px;
    }
    
    .action-btn i {
      font-size: 14px;
    }
  }
  
  /* Ensure buttons don't wrap */
  td:last-child {
    white-space: nowrap;
  }
</style>

  <div class="card-body">
    <% if @training_programs.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Title</th>
              <th>Type</th>
              <th>Trainer</th>
              <th>Assigned To</th>
              <th>Duration</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @training_programs.each do |program| %>
              <tr>
                <td><%= program.title %></td>
                <td><%= program.program_type.titleize %></td>
                <td><%= program.trainer.user.full_name %></td>
                <td>
                  <% if program.individual? %>
                    <% if program.participants.any? %>
                      <span class="badge bg-info">
                        <%= pluralize(program.participants.count, "participant") %>
                      </span>
                    <% else %>
                      <%= program.participant&.user&.full_name %>
                    <% end %>
                  <% else %>
                    <% if program.sections.any? %>
                      <span class="badge bg-success">
                        <%= pluralize(program.sections.count, "section") %>
                      </span>
                    <% else %>
                      <%= program.section&.name %>
                    <% end %>
                  <% end %>
                </td>
                <td>
                  <%= program.start_date.strftime("%b %d") %> - 
                  <%= program.end_date.strftime("%b %d, %Y") %>
                </td>
                <td>
                  <span class="badge badge-<%= program.status == 'completed' ? 'success' : 
                    program.status == 'cancelled' ? 'danger' : 'warning' %>">
                    <%= program.status.titleize %>
                  </span>
                </td>
                <td>
                  <div class="d-flex align-items-center">
                    <%= link_to institute_admin_training_program_path(program), 
                        class: "btn action-btn btn-view me-2", title: "View" do %>
                      <i class="bi bi-eye"></i>
                    <% end %>
                    <%= link_to edit_institute_admin_training_program_path(program), 
                        class: "btn action-btn btn-edit me-2", title: "Edit" do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                    <% if program.completed? %>
                      <span class="btn action-btn btn-completed me-2" title="Program Completed">
                        <i class="bi bi-check-circle-fill"></i>
                      </span>
                    <% else %>
                      <%= button_to mark_completed_institute_admin_training_program_path(program),
                          method: :patch,
                          class: "btn action-btn btn-complete me-2",
                          form: { style: 'display: inline-block' },
                          title: "Mark as Complete",
                          data: { turbo_confirm: "Are you sure you want to mark this program as completed?" } do %>
                        <i class="bi bi-check-circle"></i>
                      <% end %>
                    <% end %>
                    <%= button_to institute_admin_training_program_path(program),
                        method: :delete,
                        class: "btn action-btn btn-delete",
                        form: { style: 'display: inline-block' },
                        title: "Delete",
                        data: { turbo_confirm: "Are you sure?" } do %>
                      <i class="bi bi-trash"></i>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-4">
        <i class="bi bi-mortarboard fs-1 text-muted mb-3"></i>
        <p class="text-muted mb-0">No training programs found</p>
      </div>
    <% end %>
  </div>
</div> 