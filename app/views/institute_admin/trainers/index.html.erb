<div class="card card-custom">
  <div class="card-header card-header-custom py-3">
    <div class="d-flex justify-content-between align-items-center">
      <h5 class="mb-0">Trainers</h5>
      <%= link_to new_institute_admin_trainer_path, class: "btn btn-primary" do %>
        <i class="bi bi-plus-lg"></i> Add Trainer
      <% end %>
    </div>
  </div>

<style>
  .action-btn {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    transition: all 0.3s ease;
    border: none;
    position: relative;
    overflow: hidden;
  }
  
  .action-btn::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
  }
  
  .action-btn:hover::before {
    width: 100px;
    height: 100px;
  }
  
  .action-btn i {
    font-size: 16px;
    position: relative;
    z-index: 1;
  }
  
  .btn-view {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    box-shadow: 0 4px 6px rgba(102, 126, 234, 0.3);
  }
  
  .btn-view:hover {
    background: linear-gradient(135deg, #5568d3 0%, #5a3a7f 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(102, 126, 234, 0.4);
    color: white;
  }
  
  .btn-edit {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    color: white;
    box-shadow: 0 4px 6px rgba(245, 87, 108, 0.3);
  }
  
  .btn-edit:hover {
    background: linear-gradient(135deg, #e082ea 0%, #e4465b 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(245, 87, 108, 0.4);
    color: white;
  }
  
  .btn-delete {
    background: linear-gradient(135deg, #ff6b6b 0%, #c92a2a 100%);
    color: white;
    box-shadow: 0 4px 6px rgba(255, 107, 107, 0.3);
  }
  
  .btn-delete:hover {
    background: linear-gradient(135deg, #ee5a5a 0%, #b81919 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(255, 107, 107, 0.4);
    color: white;
  }
  
  .action-btn:active {
    transform: translateY(0);
  }
  
  /* Mobile optimization */
  @media (max-width: 768px) {
    .action-btn {
      width: 32px;
      height: 32px;
      margin: 2px;
    }
    
    .action-btn i {
      font-size: 14px;
    }
  }
  
  /* Ensure buttons don't wrap */
  td:last-child {
    white-space: nowrap;
  }
</style>

  <div class="card-body">
    <% if @trainers.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Specialization</th>
              <th>Experience</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @trainers.each do |trainer| %>
              <tr>
                <td><%= trainer.user.full_name %></td>
                <td><%= trainer.user.email %></td>
                <td><%= trainer.specialization %></td>
                <td><%= trainer.experience_years %> years</td>
                <td>
                  <span class="badge badge-<%= trainer.status == 'active' ? 'success' : 'warning' %>">
                    <%= trainer.status.titleize %>
                  </span>
                </td>
                <td>
                  <%= link_to institute_admin_trainer_path(trainer), class: "btn action-btn btn-view me-2", title: "View" do %>
                    <i class="bi bi-eye"></i>
                  <% end %>
                  <%= link_to edit_institute_admin_trainer_path(trainer), class: "btn action-btn btn-edit me-2", title: "Edit" do %>
                    <i class="bi bi-pencil"></i>
                  <% end %>
                  <%= button_to institute_admin_trainer_path(trainer), 
                      method: :delete, 
                      class: "btn action-btn btn-delete",
                      form: { style: 'display: inline-block' },
                      title: "Delete",
                      data: { turbo_confirm: "Are you sure you want to delete this trainer?" } do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-4">
        <i class="bi bi-person-workspace fs-1 text-muted mb-3"></i>
        <p class="text-muted mb-0">No trainers found</p>
      </div>
    <% end %>
  </div>
</div> 