<div class="card card-custom">
  <div class="card-header card-header-custom py-3">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <h5 class="mb-0">
          <% if params[:approved] == 'false' %>
            Not Approved Participants
          <% else %>
            Approved Participants
          <% end %>
        </h5>
      </div>
      <% if params[:approved] == 'false' %>
        <% if @participants.any? %>
          <div class="d-flex gap-2">
            <button type="button" class="btn btn-approve" id="approveSelectedBtn" onclick="approveSelected()" style="display: none;">
              <i class="bi bi-check-circle-fill me-2"></i><span id="selectedCount">0</span> Selected - Approve
            </button>
            <button type="button" class="btn btn-approve" onclick="showApproveAllModal()">
              <i class="bi bi-check-circle"></i> Approve All
            </button>
          </div>
        <% end %>
      <% else %>
        <%= link_to new_institute_admin_participant_path, class: "btn btn-primary" do %>
          <i class="bi bi-plus-lg"></i> Add Participant
        <% end %>
      <% end %>
    </div>
  </div>

<style>
  .action-btn {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    transition: all 0.3s ease;
    border: none;
    position: relative;
    overflow: hidden;
  }
  
  .action-btn::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
  }
  
  .action-btn:hover::before {
    width: 100px;
    height: 100px;
  }
  
  .action-btn i {
    font-size: 16px;
    position: relative;
    z-index: 1;
  }
  
  .btn-view {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    box-shadow: 0 4px 6px rgba(102, 126, 234, 0.3);
  }
  
  .btn-view:hover {
    background: linear-gradient(135deg, #5568d3 0%, #5a3a7f 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(102, 126, 234, 0.4);
    color: white;
  }
  
  .btn-edit {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    color: white;
    box-shadow: 0 4px 6px rgba(245, 87, 108, 0.3);
  }
  
  .btn-edit:hover {
    background: linear-gradient(135deg, #e082ea 0%, #e4465b 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(245, 87, 108, 0.4);
    color: white;
  }
  
  .btn-delete {
    background: linear-gradient(135deg, #ff6b6b 0%, #c92a2a 100%);
    color: white;
    box-shadow: 0 4px 6px rgba(255, 107, 107, 0.3);
  }
  
  .btn-delete:hover {
    background: linear-gradient(135deg, #ee5a5a 0%, #b81919 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(255, 107, 107, 0.4);
    color: white;
  }
  
  .btn-approve {
    background: linear-gradient(135deg, #4ade80 0%, #16a34a 100%);
    color: white;
    padding: 8px 16px;
    border-radius: 8px;
    transition: all 0.3s ease;
    border: none;
    box-shadow: 0 4px 6px rgba(74, 222, 128, 0.3);
    position: relative;
    overflow: hidden;
  }
  
  .btn-approve::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
  }
  
  .btn-approve:hover::before {
    width: 200px;
    height: 200px;
  }
  
  .btn-approve:hover {
    background: linear-gradient(135deg, #22c55e 0%, #15803d 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(74, 222, 128, 0.4);
    color: white;
  }
  
  .btn-approve i {
    position: relative;
    z-index: 1;
  }
  
  .action-btn:active {
    transform: translateY(0);
  }
  
  /* Mobile optimization */
  @media (max-width: 768px) {
    .action-btn {
      width: 32px;
      height: 32px;
      margin: 2px;
    }
    
    .action-btn i {
      font-size: 14px;
    }
    
    .btn-approve {
      padding: 6px 12px;
      font-size: 14px;
    }
  }
  
  /* Ensure buttons don't wrap */
  td:last-child {
    white-space: nowrap;
  }
  
  /* Filter Section Styling */
  .filter-section {
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
    border-radius: 12px;
    padding: 1.5rem;
    border: 1px solid #e2e8f0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }
  
  .filter-header h6 {
    color: #475569;
    font-weight: 600;
  }
  
  .filter-form .form-floating > label {
    color: #64748b;
  }
  
  .filter-form .filter-input {
    height: 38px;
    border-radius: 8px;
    border: 1px solid #cbd5e1;
    transition: all 0.3s ease;
    font-size: 14px;
    padding: 0.375rem 0.75rem;
    background-color: #ffffff;
  }
  
  .filter-form .form-select.filter-input {
    padding: 0.375rem 2.25rem 0.375rem 0.75rem;
    background-position: right 0.75rem center;
    background-size: 16px 12px;
  }
  
  .filter-form .filter-input:focus {
    border-color: #6366f1;
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
    outline: 0;
  }
  
  .filter-form .filter-btn {
    height: 38px;
    border-radius: 8px;
    font-size: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.375rem 1rem;
  }
  
  /* Mobile optimization for filters */
  @media (max-width: 768px) {
    .filter-section {
      padding: 1rem;
    }
    
    .filter-header {
      flex-direction: column;
      align-items: flex-start !important;
      gap: 0.75rem;
    }
    
    .filter-header button {
      align-self: flex-end;
    }
  }
</style>

  <% if params[:approved] == 'false' %>
    <!-- Not Approved Participants Section -->
    <div class="card-body">
      <!-- Filter Section -->
      <div class="filter-section mb-4">
        <div class="filter-header d-flex justify-content-between align-items-center mb-3">
          <h6 class="mb-0"><i class="bi bi-funnel me-2"></i>Filter Participants</h6>
          <button type="button" class="btn btn-sm btn-outline-secondary" onclick="clearFilters()">
            <i class="bi bi-x-circle me-1"></i>Clear Filters
          </button>
        </div>
        
        <%= form_with url: institute_admin_participants_path, method: :get, local: true, class: "filter-form" do |f| %>
          <%= hidden_field_tag :approved, params[:approved] %>
          
          <div class="row g-3 align-items-center">
            <!-- Search by Name -->
            <div class="col-lg-3 col-md-6">
              <%= text_field_tag :search, params[:search], class: "form-control filter-input", placeholder: "Search by name..." %>
            </div>
            
            <!-- Filter by Type -->
            <div class="col-lg-2 col-md-6">
              <%= select_tag :participant_type, 
                  options_for_select([
                    ['All Types', ''],
                    ['Student', 'student'],
                    ['Guardian', 'guardian'],
                    ['Employee', 'employee']
                  ], params[:participant_type]), 
                  class: "form-select filter-input" %>
            </div>
            
            <!-- Filter by Section -->
            <div class="col-lg-3 col-md-6">
              <%= select_tag :section_id, 
                  options_for_select([['All Sections', '']] + @sections.map { |s| [s.name, s.id] }, params[:section_id]), 
                  class: "form-select filter-input" %>
            </div>
            
            <!-- Action Buttons -->
            <div class="col-lg-4 col-md-6">
              <div class="d-flex gap-2">
                <%= button_tag type: 'submit', class: 'btn btn-primary flex-grow-1 filter-btn' do %>
                  <i class="bi bi-funnel-fill me-2"></i>Apply Filters
                <% end %>
                <%= link_to institute_admin_participants_path(approved: params[:approved]), class: 'btn btn-outline-secondary flex-grow-1 filter-btn' do %>
                  <i class="bi bi-arrow-clockwise me-2"></i>Reset
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      
      <% if @participants.any? %>
        <div class="table-responsive">
          <table class="table table-hover">
            <thead>
              <tr>
                <th style="width: 40px;">
                  <input type="checkbox" id="selectAll" class="form-check-input" onchange="toggleSelectAll(this)">
                </th>
                <th>Name</th>
                <th>Type</th>
                <th>Section</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @participants.each do |participant| %>
                <tr>
                  <td>
                    <input type="checkbox" class="form-check-input participant-checkbox" 
                           value="<%= participant.user.id %>" 
                           onchange="updateSelectedCount()">
                  </td>
                  <td><%= participant.user.full_name %></td>
                  <td>
                    <span class="badge bg-primary">
                      <%= participant.participant_type&.titleize || "Student" %>
                    </span>
                  </td>
                  <td>
                    <% if participant.student? || participant.participant_type.nil? %>
                      <%= participant.section&.name || 'Not Assigned' %>
                    <% elsif participant.employee? %>
                      <%= participant.section&.name || 'Not Assigned' %>
                    <% elsif participant.guardian? %>
                      <% if participant.guardian_for_participant&.section %>
                        <%= participant.guardian_for_participant.section.name %>
                      <% else %>
                        <span class="text-muted">Student's Section</span>
                      <% end %>
                    <% end %>
                  </td>
                  <td>
                    <%= link_to institute_admin_participant_path(participant.user), class: "btn action-btn btn-view me-2", title: "View" do %>
                      <i class="bi bi-eye"></i>
                    <% end %>
                    <%= link_to edit_institute_admin_participant_path(participant.user), class: "btn action-btn btn-edit me-2", title: "Edit" do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                    <button type="button" class="btn action-btn btn-delete me-2" title="Delete" 
                            onclick="showDeleteModal('<%= participant.user.full_name %>', '<%= institute_admin_participant_path(participant.user) %>')">
                      <i class="bi bi-trash"></i>
                    </button>
                    <button type="button" class="btn btn-approve" 
                            onclick="showApproveModal('<%= participant.user.full_name %>', '<%= toggle_status_institute_admin_participant_path(participant.user) %>')">
                      <i class="bi bi-check-circle"></i> Approve
                    </button>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        
        <!-- Pagination for Not Approved -->
        <% if @participants.total_pages > 1 %>
          <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="text-muted">
              Showing <%= @participants.offset_value + 1 %> to <%= [@participants.offset_value + @participants.limit_value, @participants.total_count].min %> of <%= @participants.total_count %> participants
            </div>
            <div>
              <%= paginate @participants, params: { approved: 'false', search: params[:search], participant_type: params[:participant_type], section_id: params[:section_id] } %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-4">
          <i class="bi bi-people fs-1 text-muted mb-3"></i>
          <p class="text-muted mb-0">No pending approval participants found</p>
        </div>
      <% end %>
    </div>
  <% else %>
    <!-- Approved Participants Section -->
    <div class="card-body">
      <!-- Filter Section -->
      <div class="filter-section mb-4">
        <div class="filter-header d-flex justify-content-between align-items-center mb-3">
          <h6 class="mb-0"><i class="bi bi-funnel me-2"></i>Filter Participants</h6>
          <button type="button" class="btn btn-sm btn-outline-secondary" onclick="clearFilters()">
            <i class="bi bi-x-circle me-1"></i>Clear Filters
          </button>
        </div>
        
        <%= form_with url: institute_admin_participants_path, method: :get, local: true, class: "filter-form" do |f| %>
          <%= hidden_field_tag :approved, params[:approved] %>
          
          <div class="row g-3 align-items-center">
            <!-- Search by Name -->
            <div class="col-lg-3 col-md-6">
              <%= text_field_tag :search, params[:search], class: "form-control filter-input", placeholder: "Search by name..." %>
            </div>
            
            <!-- Filter by Type -->
            <div class="col-lg-2 col-md-6">
              <%= select_tag :participant_type, 
                  options_for_select([
                    ['All Types', ''],
                    ['Student', 'student'],
                    ['Guardian', 'guardian'],
                    ['Employee', 'employee']
                  ], params[:participant_type]), 
                  class: "form-select filter-input" %>
            </div>
            
            <!-- Filter by Section -->
            <div class="col-lg-3 col-md-6">
              <%= select_tag :section_id, 
                  options_for_select([['All Sections', '']] + @sections.map { |s| [s.name, s.id] }, params[:section_id]), 
                  class: "form-select filter-input" %>
            </div>
            
            <!-- Action Buttons -->
            <div class="col-lg-4 col-md-6">
              <div class="d-flex gap-2">
                <%= button_tag type: 'submit', class: 'btn btn-primary flex-grow-1 filter-btn' do %>
                  <i class="bi bi-funnel-fill me-2"></i>Apply Filters
                <% end %>
                <%= link_to institute_admin_participants_path(approved: params[:approved]), class: 'btn btn-outline-secondary flex-grow-1 filter-btn' do %>
                  <i class="bi bi-arrow-clockwise me-2"></i>Reset
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      
      <% if @participants.any? %>
        <div class="table-responsive">
          <table class="table table-hover">
            <thead>
              <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Section</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @participants.each do |participant| %>
                <tr>
                  <td><%= participant.user.full_name %></td>
                  <td>
                    <span class="badge bg-primary">
                      <%= participant.participant_type&.titleize || "Student" %>
                    </span>
                  </td>
                  <td>
                    <% if participant.student? || participant.participant_type.nil? %>
                      <%= participant.section&.name || 'Not Assigned' %>
                    <% elsif participant.employee? %>
                      <%= participant.section&.name || 'Not Assigned' %>
                    <% elsif participant.guardian? %>
                      <% if participant.guardian_for_participant&.section %>
                        <%= participant.guardian_for_participant.section.name %>
                      <% else %>
                        <span class="text-muted">Student's Section</span>
                      <% end %>
                    <% end %>
                  </td>
                  <td>
                    <%= link_to institute_admin_participant_path(participant.user), class: "btn action-btn btn-view me-2", title: "View" do %>
                      <i class="bi bi-eye"></i>
                    <% end %>
                    <%= link_to edit_institute_admin_participant_path(participant.user), class: "btn action-btn btn-edit me-2", title: "Edit" do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                    <button type="button" class="btn action-btn btn-delete" title="Delete" 
                            onclick="showDeleteModal('<%= participant.user.full_name %>', '<%= institute_admin_participant_path(participant.user) %>')">
                      <i class="bi bi-trash"></i>
                    </button>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        
        <!-- Pagination for Approved -->
        <% if @participants.total_pages > 1 %>
          <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="text-muted">
              Showing <%= @participants.offset_value + 1 %> to <%= [@participants.offset_value + @participants.limit_value, @participants.total_count].min %> of <%= @participants.total_count %> participants
            </div>
            <div>
              <%= paginate @participants, params: { approved: 'true', search: params[:search], participant_type: params[:participant_type], section_id: params[:section_id] } %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-4">
          <i class="bi bi-people fs-1 text-muted mb-3"></i>
          <p class="text-muted mb-0">No approved participants found</p>
        </div>
            <% end %>
    </div>
  <% end %>
</div>

<!-- Beautiful Delete Confirmation Modal -->
<div id="deleteModal" class="custom-modal" style="display: none;">
  <div class="modal-overlay"></div>
  <div class="modal-container">
    <div class="modal-content">
      <!-- Icon -->
      <div class="modal-icon">
        <div class="icon-circle">
          <i class="bi bi-exclamation-triangle"></i>
        </div>
      </div>
      
      <!-- Content -->
      <h3 class="modal-title">Delete Participant?</h3>
      <p class="modal-message">
        Are you sure you want to delete <strong id="participantName"></strong>? 
        This action cannot be undone and all associated data will be permanently removed.
      </p>
      
      <!-- Actions -->
      <div class="modal-actions">
        <button type="button" class="btn-modal btn-cancel" onclick="closeDeleteModal()">
          <i class="bi bi-x-circle me-2"></i>Cancel
        </button>
        <form id="deleteForm" method="post" style="display: inline-block;">
          <input type="hidden" name="_method" value="delete">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <button type="submit" class="btn-modal btn-delete-confirm">
            <i class="bi bi-trash me-2"></i>Yes, Delete
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Beautiful Approve Confirmation Modal -->
<div id="approveModal" class="custom-modal" style="display: none;">
  <div class="modal-overlay"></div>
  <div class="modal-container">
    <div class="modal-content">
      <!-- Icon -->
      <div class="modal-icon">
        <div class="icon-circle-approve">
          <i class="bi bi-check-circle"></i>
        </div>
      </div>
      
      <!-- Content -->
      <h3 class="modal-title">Approve Participant?</h3>
      <p class="modal-message">
        Are you sure you want to approve <strong id="approveParticipantName"></strong>? 
        They will be granted access to the system immediately.
      </p>
      
      <!-- Actions -->
      <div class="modal-actions">
        <button type="button" class="btn-modal btn-cancel" onclick="closeApproveModal()">
          <i class="bi bi-x-circle me-2"></i>Cancel
        </button>
        <form id="approveForm" method="post" style="display: inline-block;">
          <input type="hidden" name="_method" value="patch">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <button type="submit" class="btn-modal btn-approve-confirm">
            <i class="bi bi-check-circle me-2"></i>Yes, Approve
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Beautiful Approve All Confirmation Modal -->
<div id="approveAllModal" class="custom-modal" style="display: none;">
  <div class="modal-overlay"></div>
  <div class="modal-container">
    <div class="modal-content">
      <!-- Icon -->
      <div class="modal-icon">
        <div class="icon-circle-approve">
          <i class="bi bi-people-fill"></i>
        </div>
      </div>
      
      <!-- Content -->
      <h3 class="modal-title">Approve All Participants?</h3>
      <p class="modal-message">
        Are you sure you want to approve <strong>all pending participants</strong>? 
        All participants will be granted access to the system immediately.
      </p>
      
      <!-- Actions -->
      <div class="modal-actions">
        <button type="button" class="btn-modal btn-cancel" onclick="closeApproveAllModal()">
          <i class="bi bi-x-circle me-2"></i>Cancel
        </button>
        <form action="<%= approve_all_institute_admin_participants_path %>" method="post" style="display: inline-block;">
          <input type="hidden" name="_method" value="patch">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <button type="submit" class="btn-modal btn-approve-confirm">
            <i class="bi bi-check-circle me-2"></i>Yes, Approve All
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Approve Selected Confirmation Modal -->
<div id="approveSelectedModal" class="custom-modal" style="display: none;">
  <div class="modal-overlay"></div>
  <div class="modal-container">
    <div class="modal-content">
      <div class="modal-icon">
        <div class="icon-circle-approve">
          <i class="bi bi-check2-all"></i>
        </div>
      </div>

      <h3 class="modal-title">Approve Selected Participants</h3>
      <p class="modal-message">
        Are you sure you want to approve <strong id="approveSelectedCount">0</strong> <span id="approveSelectedCountText">participants</span>?
        They will be granted access to the system immediately.
      </p>

      <div class="modal-actions">
        <button type="button" class="btn-modal btn-cancel" onclick="closeApproveSelectedModal()">
          <i class="bi bi-x-circle me-2"></i>Cancel
        </button>
        <form id="approveSelectedForm" action="<%= approve_selected_institute_admin_participants_path %>" method="post" style="display: inline-block;">
          <input type="hidden" name="_method" value="patch">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <input type="hidden" id="selectedParticipantIds" name="selected_ids" value="">
          <button type="submit" class="btn-modal btn-approve-confirm">
            <i class="bi bi-check-circle me-2"></i>Yes, Approve Selected
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<style>
  .custom-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    animation: fadeIn 0.3s ease-out;
  }
  
  .modal-container {
    position: relative;
    width: 90%;
    max-width: 420px;
    animation: slideUp 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  }
  
  .modal-content {
    background: linear-gradient(to bottom, #ffffff 0%, #f8fafc 100%);
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    text-align: center;
  }
  
  .modal-icon {
    margin-bottom: 1rem;
  }
  
  .icon-circle {
    width: 64px;
    height: 64px;
    margin: 0 auto;
    border-radius: 50%;
    background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: pulse 2s infinite;
  }
  
  .icon-circle i {
    font-size: 2rem;
    color: #dc2626;
  }
  
  .icon-circle-approve {
    width: 64px;
    height: 64px;
    margin: 0 auto;
    border-radius: 50%;
    background: linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: pulse 2s infinite;
  }
  
  .icon-circle-approve i {
    font-size: 2rem;
    color: #16a34a;
  }
  
  .modal-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1f2937;
    margin-bottom: 0.75rem;
  }
  
  .modal-message {
    font-size: 0.9rem;
    color: #6b7280;
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }
  
  .modal-message strong {
    color: #dc2626;
    font-weight: 600;
  }
  
  #approveModal .modal-message strong,
  #approveAllModal .modal-message strong {
    color: #16a34a;
    font-weight: 600;
  }
  
  .modal-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  
  .btn-modal {
    padding: 0.65rem 1.75rem;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 130px;
  }
  
  .btn-cancel {
    background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
    color: #4b5563;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }
  
  .btn-cancel:hover {
    background: linear-gradient(135deg, #e5e7eb 0%, #d1d5db 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
  }
  
  .btn-delete-confirm {
    background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    color: white;
    box-shadow: 0 4px 6px rgba(239, 68, 68, 0.3);
  }
  
  .btn-delete-confirm:hover {
    background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(239, 68, 68, 0.4);
  }
  
  .btn-approve-confirm {
    background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
    color: white;
    box-shadow: 0 4px 6px rgba(34, 197, 94, 0.3);
  }
  
  .btn-approve-confirm:hover {
    background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(34, 197, 94, 0.4);
  }
  
  .btn-modal:active {
    transform: translateY(0);
  }
  
  /* Animations */
  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
  
  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(50px) scale(0.9);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  
  @keyframes pulse {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.05);
    }
  }
  
  /* Mobile optimization */
  @media (max-width: 768px) {
    .modal-content {
      padding: 1.25rem;
    }
    
    .icon-circle {
      width: 56px;
      height: 56px;
    }
    
    .icon-circle i {
      font-size: 1.75rem;
    }
    
    .icon-circle-approve {
      width: 56px;
      height: 56px;
    }
    
    .icon-circle-approve i {
      font-size: 1.75rem;
    }
    
    .modal-title {
      font-size: 1.1rem;
    }
    
    .modal-message {
      font-size: 0.85rem;
    }
    
    .modal-actions {
      flex-direction: column;
    }
    
    .btn-modal {
      width: 100%;
      min-width: auto;
      padding: 0.6rem 1.5rem;
    }
  }
</style>

<script>
  function clearFilters() {
    const form = document.querySelector('.filter-form');
    const searchInput = form.querySelector('input[name="search"]');
    const typeSelect = form.querySelector('select[name="participant_type"]');
    const sectionSelect = form.querySelector('select[name="section_id"]');
    
    if (searchInput) searchInput.value = '';
    if (typeSelect) typeSelect.value = '';
    if (sectionSelect) sectionSelect.value = '';
  }
  
  // Multi-select functions
  function toggleSelectAll(checkbox) {
    const checkboxes = document.querySelectorAll('.participant-checkbox');
    checkboxes.forEach(cb => {
      cb.checked = checkbox.checked;
    });
    updateSelectedCount();
  }
  
  function updateSelectedCount() {
    const checkboxes = document.querySelectorAll('.participant-checkbox:checked');
    const count = checkboxes.length;
    const approveBtn = document.getElementById('approveSelectedBtn');
    const countSpan = document.getElementById('selectedCount');
    const selectAllCheckbox = document.getElementById('selectAll');
    
    if (count > 0) {
      approveBtn.style.display = 'block';
      countSpan.textContent = count;
    } else {
      approveBtn.style.display = 'none';
    }
    
    // Update "select all" checkbox state
    const allCheckboxes = document.querySelectorAll('.participant-checkbox');
    if (selectAllCheckbox) {
      selectAllCheckbox.checked = allCheckboxes.length > 0 && count === allCheckboxes.length;
    }
  }
  
  function approveSelected() {
    const checkboxes = document.querySelectorAll('.participant-checkbox:checked');
    const ids = Array.from(checkboxes).map(cb => cb.value);
    
    if (ids.length === 0) {
      alert('Please select at least one participant to approve.');
      return;
    }
    
    showApproveSelectedModal(ids);
  }
  
  function showApproveSelectedModal(ids) {
    const count = ids.length;
    document.getElementById('approveSelectedCount').textContent = count;
    document.getElementById('approveSelectedCountText').textContent = count > 1 ? 'participants' : 'participant';
    document.getElementById('selectedParticipantIds').value = ids.join(',');
    document.getElementById('approveSelectedModal').style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  
  function closeApproveSelectedModal() {
    document.getElementById('approveSelectedModal').style.display = 'none';
    document.body.style.overflow = 'auto';
  }
  
  function showDeleteModal(participantName, deleteUrl) {
    document.getElementById('participantName').textContent = participantName;
    document.getElementById('deleteForm').action = deleteUrl;
    document.getElementById('deleteModal').style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  
  function closeDeleteModal() {
    document.getElementById('deleteModal').style.display = 'none';
    document.body.style.overflow = 'auto';
  }
  
  function showApproveModal(participantName, approveUrl) {
    document.getElementById('approveParticipantName').textContent = participantName;
    document.getElementById('approveForm').action = approveUrl;
    document.getElementById('approveModal').style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  
  function closeApproveModal() {
    document.getElementById('approveModal').style.display = 'none';
    document.body.style.overflow = 'auto';
  }
  
  function showApproveAllModal() {
    document.getElementById('approveAllModal').style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  
  function closeApproveAllModal() {
    document.getElementById('approveAllModal').style.display = 'none';
    document.body.style.overflow = 'auto';
  }
  
  // Close modal when clicking overlay
  document.addEventListener('DOMContentLoaded', function() {
    const deleteModal = document.getElementById('deleteModal');
    const approveModal = document.getElementById('approveModal');
    const approveAllModal = document.getElementById('approveAllModal');
    const approveSelectedModal = document.getElementById('approveSelectedModal');
    
    if (deleteModal) {
      const overlay = deleteModal.querySelector('.modal-overlay');
      if (overlay) overlay.addEventListener('click', closeDeleteModal);
    }
    
    if (approveModal) {
      const overlay = approveModal.querySelector('.modal-overlay');
      if (overlay) overlay.addEventListener('click', closeApproveModal);
    }
    
    if (approveAllModal) {
      const overlay = approveAllModal.querySelector('.modal-overlay');
      if (overlay) overlay.addEventListener('click', closeApproveAllModal);
    }

    if (approveSelectedModal) {
      const overlay = approveSelectedModal.querySelector('.modal-overlay');
      if (overlay) overlay.addEventListener('click', closeApproveSelectedModal);
    }
  });
  
  // Close modal with Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closeDeleteModal();
      closeApproveModal();
      closeApproveAllModal();
      closeApproveSelectedModal();
    }
  });
</script>
 