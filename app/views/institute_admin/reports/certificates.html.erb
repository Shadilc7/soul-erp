<% content_for :styles do %>
<style>
  .certificates-menu-page {
    min-height: 100vh;
    padding-top: 0;
    padding-bottom: 2rem;
  }
  
  /* Full Width Header */
  .certificates-menu-header {
    background: linear-gradient(135deg, #059669 0%, #0891b2 50%, #4f46e5 100%);
    padding: 2rem 2.5rem;
    margin-bottom: 0;
    box-shadow: 0 4px 20px rgba(102, 126, 234, 0.2);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    
    /* Break out of .content-wrapper padding */
    margin-top: -2.1rem; /* Adjusted to close gap */
    margin-left: -2rem; /* Pull left */
    margin-right: -2rem; /* Pull right */
    width: auto; /* Fill available space */
    border-radius: 0;
  }
  
  .certificates-menu-header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
    border-radius: 50%;
  }
  
  .certificates-menu-header h3 {
    color: white;
    font-weight: 700;
    font-size: 1.5rem;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  /* Breadcrumb Styling Override */
  .breadcrumb-container {
    padding: 1rem 1.5rem;
    background: #fff;
    border-bottom: 1px solid #e2e8f0;
    margin-bottom: 2rem;
    
    /* Break out to match header */
    margin-left: -2rem;
    margin-right: -2rem;
  }
  
  /* Card Styles (Restored) */
  .certificate-action-card {
    position: relative;
    background: white;
    border-radius: 18px;
    padding: 2rem;
    box-shadow: 0 6px 25px rgba(0, 0, 0, 0.08);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    overflow: hidden;
    height: 100%;
    border: 1px solid rgba(0, 0, 0, 0.05);
    display: flex;
    flex-direction: column;
  }

  .certificate-action-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--gradient-start), var(--gradient-end));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .certificate-action-card:hover::before {
    transform: scaleX(1);
  }

  .certificate-action-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
  }

  .certificate-action-card.generate-card { --gradient-start: #667eea; --gradient-end: #764ba2; }
  .certificate-action-card.section-card { --gradient-start: #f093fb; --gradient-end: #f5576c; }
  .certificate-action-card.view-card { --gradient-start: #11998e; --gradient-end: #38ef7d; }
  .certificate-action-card.stats-card { --gradient-start: #ffd89b; --gradient-end: #19547b; }
  .certificate-action-card.config-card { --gradient-start: #a8edea; --gradient-end: #fed6e3; }

  .action-icon-container {
    width: 70px;
    height: 70px;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    position: relative;
    transition: all 0.3s ease;
  }

  .certificate-action-card:hover .action-icon-container {
    transform: scale(1.15) rotate(-5deg);
  }

  .generate-card .action-icon-container { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); box-shadow: 0 6px 18px rgba(102, 126, 234, 0.4); }
  .section-card .action-icon-container { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); box-shadow: 0 6px 18px rgba(240, 147, 251, 0.4); }
  .view-card .action-icon-container { background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); box-shadow: 0 6px 18px rgba(17, 153, 142, 0.4); }
  .stats-card .action-icon-container { background: linear-gradient(135deg, #ffd89b 0%, #19547b 100%); box-shadow: 0 6px 18px rgba(255, 216, 155, 0.4); }
  .config-card .action-icon-container { background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); box-shadow: 0 6px 18px rgba(168, 237, 234, 0.4); }

  .action-icon-container i {
    font-size: 2rem;
    color: white;
  }

  .certificate-action-card h6 {
    font-weight: 700;
    font-size: 1.2rem;
    color: #2c3e50;
    margin-bottom: 0.75rem;
  }

  .certificate-action-card .card-description {
    color: #6c757d;
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .action-arrow {
    color: #667eea;
    font-size: 1.5rem;
    transition: all 0.3s ease;
    align-self: flex-end;
    opacity: 0.7;
  }

  .certificate-action-card:hover .action-arrow {
    transform: translateX(8px);
    opacity: 1;
  }

  .card-link {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 1;
  }

  .certificates-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.75rem;
    padding: 0 0.5rem; /* Add small padding for box shadows */
  }

  @media (max-width: 768px) {
    .certificates-menu-header { padding: 1.5rem; margin-top: -1rem; margin-left: -1rem; margin-right: -1rem; }
    .breadcrumb-container { margin-left: -1rem; margin-right: -1rem; }
    .certificates-grid { grid-template-columns: 1fr; }
  }
</style>
<% end %>

<div class="certificates-menu-page">
  <!-- Full Width Header -->
  <div class="certificates-menu-header">
    <div class="container-fluid">
      <h3><i class="bi bi-award me-3"></i>Certificate Management</h3>
    </div>
  </div>

  <!-- Breadcrumb Section -->
  <div class="breadcrumb-container">
    <div class="container-fluid">
      <%= render 'certificate_breadcrumb', current_page: nil %>
    </div>
  </div>

  <div class="container-fluid px-4">
    <!-- Certificates Grid -->
    <div class="certificates-grid">
      <!-- Generate Individual Certificate Card -->
      <div class="certificate-action-card generate-card">
        <div class="action-icon-container">
          <i class="bi bi-plus-circle-fill"></i>
        </div>
        <h6>Generate Individual Certificate</h6>
        <p class="card-description">Create certificates for individual participants based on their assignment performance and scores.</p>
        <i class="bi bi-arrow-right-circle-fill action-arrow"></i>
        <%= link_to generate_certificate_institute_admin_reports_path, class: "card-link" do %>
          <span class="visually-hidden">Generate Individual Certificate</span>
        <% end %>
      </div>

      <!-- Generate Section-Wise Certificate Card -->
      <div class="certificate-action-card section-card">
        <div class="action-icon-container">
          <i class="bi bi-file-earmark-medical"></i>
        </div>
        <h6>Generate Section-Wise Certificate</h6>
        <p class="card-description">Bulk generate certificates for all participants within a specific section or group.</p>
        <i class="bi bi-arrow-right-circle-fill action-arrow"></i>
        <%= link_to generate_section_certificate_institute_admin_reports_path, class: "card-link" do %>
          <span class="visually-hidden">Generate Section-Wise Certificate</span>
        <% end %>
      </div>

      <!-- View Certificates Card -->
      <div class="certificate-action-card view-card">
        <div class="action-icon-container">
          <i class="bi bi-eye-fill"></i>
        </div>
        <h6>View Certificates</h6>
        <p class="card-description">Browse, filter, and manage all generated certificates. Publish or regenerate as needed.</p>
        <i class="bi bi-arrow-right-circle-fill action-arrow"></i>
        <%= link_to view_certificates_institute_admin_reports_path, class: "card-link" do %>
          <span class="visually-hidden">View Certificates</span>
        <% end %>
      </div>
      
      <!-- Certificate Statistics Card -->
      <div class="certificate-action-card stats-card">
        <div class="action-icon-container">
          <i class="bi bi-bar-chart-fill"></i>
        </div>
        <h6>Certificate Statistics</h6>
        <p class="card-description">View comprehensive statistics and analytics about certificate generation and distribution.</p>
        <i class="bi bi-arrow-right-circle-fill action-arrow"></i>
        <%= link_to certificate_stats_institute_admin_reports_path, class: "card-link" do %>
          <span class="visually-hidden">Certificate Statistics</span>
        <% end %>
      </div>

      <!-- Certificate Configurations Card -->
      <div class="certificate-action-card config-card">
        <div class="action-icon-container">
          <i class="bi bi-gear-fill"></i>
        </div>
        <h6>Certificate Configurations</h6>
        <p class="card-description">Manage certificate templates, layouts, and configuration settings for different certificate types.</p>
        <i class="bi bi-arrow-right-circle-fill action-arrow"></i>
        <%= link_to institute_admin_certificate_configurations_path, class: "card-link" do %>
          <span class="visually-hidden">Certificate Configurations</span>
        <% end %>
      </div>
    </div>
  </div>
</div>