<div class="card card-custom">
  <div class="card-header card-header-custom d-flex justify-content-between align-items-center">
    <h5 class="mb-0">View Responses</h5>
    <%= link_to institute_admin_root_path, class: "btn btn-outline-secondary" do %>
      <i class="bi bi-arrow-left"></i> Back
    <% end %>
  </div>

  <div class="card-body">
    <div class="row mb-4">
      <div class="col-md-12">
        <div class="card">
          <div class="card-header bg-light">
            <h6 class="mb-0">Filter Responses</h6>
          </div>
          <div class="card-body">
            <%= form_tag institute_admin_responses_path, method: :get, class: "row g-3", data: { controller: "participant-select date-range" } do %>
              
              <!-- Date Range Selection -->
              <div class="col-md-12">
                <div class="row align-items-center">
                  <div class="col-md-3">
                    <label for="date_filter" class="form-label mb-0">Date Filter</label>
                  </div>
                  <div class="col-md-9">
                    <%= select_tag :date_filter,
                        options_for_select([
                          ['Today', 'today'],
                          ['Yesterday', 'yesterday'],
                          ['Last 7 Days', 'last_7_days'],
                          ['Last Month', 'last_month'],
                          ['Custom', 'custom']
                        ], params[:date_filter] || 'today'),
                        class: "form-select",
                        id: "date_filter_select",
                        onchange: "toggleCustomDateFields(this.value)",
                        data: { 
                          date_range_target: "filter",
                          action: "change->date-range#toggleCustomDates"
                        },
                        required: true %>
                  </div>
                </div>
              </div>
              
              <!-- Custom Date Range (Hidden by default) -->
              <div class="col-md-12" id="custom_date_fields" data-date-range-target="customDates" style="display: none;">
                <div class="row align-items-center">
                  <div class="col-md-3">
                    <!-- Empty space to align with dropdown -->
                  </div>
                  <div class="col-md-9">
                    <div class="row g-3">
                      <div class="col-md-6">
                        <label for="start_date" class="form-label mb-1">Start Date</label>
                        <%= date_field_tag :start_date, params[:start_date], 
                            class: "form-control",
                            id: "start_date_field",
                            data: { date_range_target: "startDate" } %>
                      </div>
                      <div class="col-md-6">
                        <label for="end_date" class="form-label mb-1">End Date</label>
                        <%= date_field_tag :end_date, params[:end_date], 
                            class: "form-control",
                            id: "end_date_field",
                            data: { date_range_target: "endDate" } %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <script>
                function toggleCustomDateFields(filterValue) {
                  const customFields = document.getElementById('custom_date_fields');
                  const startDateField = document.getElementById('start_date_field');
                  const endDateField = document.getElementById('end_date_field');
                  
                  if (filterValue === 'custom') {
                    customFields.style.display = 'block';
                    startDateField.required = true;
                    endDateField.required = true;
                  } else {
                    customFields.style.display = 'none';
                    startDateField.required = false;
                    endDateField.required = false;
                  }
                }
                
                // Call on page load to set initial state
                document.addEventListener('DOMContentLoaded', function() {
                  const filterSelect = document.getElementById('date_filter_select');
                  if (filterSelect) {
                    toggleCustomDateFields(filterSelect.value);
                  }
                });
              </script>
              
              <!-- Section Selection -->
              <div class="col-md-12">
                <div class="row align-items-center">
                  <div class="col-md-3">
                    <label for="section_id" class="form-label mb-0">Select Section</label>
                  </div>
                  <div class="col-md-9">
                    <%= select_tag :section_id, 
                        options_from_collection_for_select(current_institute.sections.active, :id, :name, params[:section_id]),
                        prompt: "Choose a section",
                        class: "form-select",
                        data: { 
                          participant_select_target: "section",
                          action: "change->participant-select#sectionChanged"
                        },
                        required: true %>
                  </div>
                </div>
              </div>
              
              <!-- Participant Selection -->
              <div class="col-md-12">
                <div class="row align-items-center">
                  <div class="col-md-3">
                    <label for="participant_id" class="form-label mb-0">Select Participant</label>
                  </div>
                  <div class="col-md-9">
                    <% if @participants&.any? %>
                      <%= select_tag :participant_id,
                          options_from_collection_for_select(@participants, :id, :full_name, params[:participant_id]),
                          prompt: "Choose a participant",
                          class: "form-select", 
                          data: { participant_select_target: "participant" },
                          required: true %>
                    <% else %>
                      <%= select_tag :participant_id,
                          options_for_select([]),
                          prompt: "First select a section",
                          class: "form-select",
                          data: { participant_select_target: "participant" },
                          disabled: params[:section_id].blank?,
                          required: true %>
                      <% if params[:section_id].present? && @participants.nil? %>
                        <small class="text-muted">Loading participants for this section...</small>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              </div>
              
              <!-- Submit Button -->
              <div class="col-md-12 mt-4">
                <div class="row align-items-center">
                  <div class="col-md-3">
                  </div>
                  <div class="col-md-9">
                    <%= submit_tag "View Responses", class: "btn btn-primary" %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Responses Display - Only show after form submission -->
    <% if params[:commit].present? && params[:participant_id].present? %>
      <% if @assignments.present? %>
        <div class="row mb-4">
          <div class="col-12">
            <div class="card">
              <div class="card-header bg-light">
                <h6 class="mb-0">Select Assignment</h6>
              </div>
              <div class="card-body">
                <div class="list-group">
                  <% @assignments.each do |assignment| %>
                    <%= link_to institute_admin_responses_path(
                          date_filter: @date_filter,
                          start_date: @start_date,
                          end_date: @end_date,
                          section_id: @section.id,
                          participant_id: @participant.id,
                          assignment_id: assignment.id,
                          commit: "View Responses"
                        ),
                        class: "list-group-item list-group-item-action #{'active' if @assignment == assignment}" do %>
                      <div class="d-flex justify-content-between align-items-center">
                        <div>
                          <h6 class="mb-1"><%= assignment.title %></h6>
                          <small><%= pluralize(assignment.questions.count, 'question') %></small>
                        </div>
                        <span class="badge bg-primary rounded-pill">
                          <%= assignment.assignment_responses.where(participant: @participant, response_date: @start_date..@end_date).count %> responses
                        </span>
                      </div>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% elsif @participant.present? && @selected_date.present? %>
        <div class="alert alert-info">
          No assignments found for this participant on the selected date.
        </div>
      <% end %>
      
      <!-- Responses Data Display -->
      <% if @responses&.any? %>
        <div class="card" id="responses-table">
          <div class="card-header bg-light">
            <h6 class="mb-0">
              Responses for <%= @assignment.title %> by <%= @participant.full_name %>
              <br>
              <small class="text-muted">
                <%= @start_date == @end_date ? @start_date.strftime('%B %d, %Y') : "#{@start_date.strftime('%B %d, %Y')} - #{@end_date.strftime('%B %d, %Y')}" %>
              </small>
            </h6>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>SI.No</th>
                    <th>Date</th>
                    <th>Question</th>
                    <th>Response</th>
                    <th>Submitted At</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% @responses.each_with_index do |response, index| %>
                    <tr>
                      <td>
                        <strong><%= @responses.offset_value + index + 1 %></strong>
                      </td>
                      <td>
                        <small><%= response.response_date.strftime('%b %d, %Y') %></small>
                      </td>
                      <td>
                        <div class="fw-medium"><%= response.question.title %></div>
                      </td>
                      <td>
                        <% if response.answer.present? %>
                          <%= truncate(response.answer, length: 100) %>
                        <% elsif response.selected_options.present? %>
                          <%= response.selected_options.join(", ") %>
                        <% else %>
                          <span class="text-muted">No response</span>
                        <% end %>
                      </td>
                      <td><%= response.created_at&.strftime("%I:%M %p") || "Not submitted" %></td>
                      <td>
                        <span class="badge bg-<%= response.answer.present? ? 'success' : 'warning' %>">
                          <%= response.answer.present? ? 'Submitted' : 'Pending' %>
                        </span>
                      </td>
                      <td>
                        <%= link_to institute_admin_response_path(response), 
                            class: "btn btn-sm btn-outline-primary" do %>
                          <i class="bi bi-eye"></i>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
            
            <!-- Pagination -->
            <% if @responses.total_pages > 1 %>
              <div class="d-flex justify-content-between align-items-center mt-3">
                <div class="text-muted">
                  Showing <%= @responses.offset_value + 1 %> to <%= [@responses.offset_value + @responses.limit_value, @responses.total_count].min %> of <%= @responses.total_count %> responses
                </div>
                <div>
                  <%= paginate @responses, 
                      params: { 
                        date_filter: @date_filter,
                        start_date: @start_date,
                        end_date: @end_date,
                        section_id: @section&.id,
                        participant_id: @participant&.id,
                        assignment_id: @assignment&.id,
                        commit: "View Responses",
                        anchor: "responses-table"
                      } %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% elsif @assignment.present? %>
        <div class="alert alert-warning">
          No responses found for this assignment and participant in the selected date range.
        </div>
      <% end %>
    <% end %>
  </div>
</div>

<% content_for :scripts do %>
  <script>
    // Scroll to responses table on page load if page parameter exists
    document.addEventListener('DOMContentLoaded', function() {
      const urlParams = new URLSearchParams(window.location.search);
      const responsesTable = document.getElementById('responses-table');
      
      // If page parameter exists and responses table is visible, scroll to it
      if (urlParams.has('page') && responsesTable) {
        setTimeout(function() {
          responsesTable.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 100);
      }
      
      // Add click event to all pagination links
      const paginationLinks = document.querySelectorAll('.pagination a');
      paginationLinks.forEach(function(link) {
        link.addEventListener('click', function(e) {
          // Let the link navigate normally, but add a flag
          sessionStorage.setItem('scrollToResponses', 'true');
        });
      });
      
      // Check if we should scroll after navigation
      if (sessionStorage.getItem('scrollToResponses') === 'true' && responsesTable) {
        sessionStorage.removeItem('scrollToResponses');
        setTimeout(function() {
          responsesTable.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 100);
      }
    });
  </script>
<% end %>

<% content_for :styles do %>
  <style>
    .list-group-item {
      transition: all 0.2s ease;
    }

    .list-group-item:hover {
      background-color: #f8f9fa;
      transform: translateX(5px);
    }

    /* Keep active item blue on hover */
    .list-group-item.active:hover {
      background-color: #0d6efd !important;
      border-color: #0d6efd !important;
      color: white !important;
    }

    .badge {
      transition: all 0.2s ease;
    }

    .list-group-item:hover .badge {
      transform: scale(1.1);
    }

    /* Kaminari Pagination Styling */
    .pagination {
      margin: 0;
    }
    
    .pagination a,
    .pagination .page,
    .pagination .current,
    .pagination .gap {
      display: inline-block;
      padding: 0.375rem 0.75rem;
      margin: 0 2px;
      line-height: 1.5;
      color: #0d6efd;
      text-decoration: none;
      background-color: #fff;
      border: 1px solid #dee2e6;
      border-radius: 0.25rem;
    }
    
    .pagination a:hover {
      color: #0a58ca;
      background-color: #e9ecef;
      border-color: #dee2e6;
    }
    
    .pagination .current {
      color: #fff;
      background-color: #0d6efd;
      border-color: #0d6efd;
    }
    
    .pagination .disabled {
      color: #6c757d;
      pointer-events: none;
      background-color: #fff;
      border-color: #dee2e6;
    }
    
    .pagination .first a,
    .pagination .prev a,
    .pagination .next a,
    .pagination .last a {
      font-weight: 500;
    }
  </style>
<% end %> 