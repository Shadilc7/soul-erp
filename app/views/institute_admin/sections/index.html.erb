<div class="container-fluid py-4">
  <!-- Breadcrumb -->
  <div class="breadcrumb-wrapper d-flex justify-content-between align-items-center mb-4">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb breadcrumb-custom mb-0">
        <li class="breadcrumb-item"><%= link_to institute_admin_root_path do %><i class="bi bi-house-door"></i><% end %></li>
        <li class="breadcrumb-item"><%= link_to "Settings", institute_admin_settings_path %></li>
        <li class="breadcrumb-item active" aria-current="page">Sections</li>
      </ol>
    </nav>
    <%= link_to institute_admin_settings_path, class: "btn btn-sm btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i> Back
    <% end %>
  </div>

  <div class="card card-custom">
    <div class="card-header card-header-custom py-3">
      <div class="d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Sections</h5>
        <div class="d-flex">
          <%= link_to new_institute_admin_section_path, class: "btn btn-primary me-2" do %>
            <i class="bi bi-plus-lg"></i> Add Section
          <% end %>
        </div>
      </div>
    </div>

<style>
  .action-btn {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    transition: all 0.3s ease;
    border: none;
    position: relative;
    overflow: hidden;
  }
  
  .action-btn::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
  }
  
  .action-btn:hover::before {
    width: 100px;
    height: 100px;
  }
  
  .action-btn i {
    font-size: 16px;
    position: relative;
    z-index: 1;
  }
  
  .btn-view {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    box-shadow: 0 4px 6px rgba(102, 126, 234, 0.3);
  }
  
  .btn-view:hover {
    background: linear-gradient(135deg, #5568d3 0%, #5a3a7f 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(102, 126, 234, 0.4);
    color: white;
  }
  
  .btn-edit {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    color: white;
    box-shadow: 0 4px 6px rgba(245, 87, 108, 0.3);
  }
  
  .btn-edit:hover {
    background: linear-gradient(135deg, #e082ea 0%, #e4465b 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(245, 87, 108, 0.4);
    color: white;
  }
  
  .btn-reassign {
    background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
    color: white;
    box-shadow: 0 4px 6px rgba(251, 191, 36, 0.3);
  }
  
  .btn-reassign:hover {
    background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(251, 191, 36, 0.4);
    color: white;
  }
  
  .btn-delete {
    background: linear-gradient(135deg, #ff6b6b 0%, #c92a2a 100%);
    color: white;
    box-shadow: 0 4px 6px rgba(255, 107, 107, 0.3);
  }
  
  .btn-delete:hover {
    background: linear-gradient(135deg, #ee5a5a 0%, #b81919 100%);
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(255, 107, 107, 0.4);
    color: white;
  }
  
  .action-btn:active {
    transform: translateY(0);
  }
  
  /* Mobile optimization */
  @media (max-width: 768px) {
    .action-btn {
      width: 32px;
      height: 32px;
      margin: 2px;
    }
    
    .action-btn i {
      font-size: 14px;
    }
  }
  
  /* Ensure buttons don't wrap */
  td:last-child {
    white-space: nowrap;
  }
</style>

  <div class="card-body">
    <% if @sections.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Code</th>
              <th>Name</th>
              <th>Capacity</th>
              <th>Participants</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @sections.each do |section| %>
              <tr>
                <td><%= section.code %></td>
                <td><%= section.name %></td>
                <td><%= section.capacity %></td>
                <td>
                  <span class="badge bg-info">
                    <%= section.participants_count %>
                  </span>
                </td>
                <td>
                  <span class="badge <%= section.active? ? 'badge-success' : 'badge-warning' %>">
                    <%= section.status.titleize %>
                  </span>
                </td>
                <td>
                  <%= link_to institute_admin_section_path(section), class: "btn action-btn btn-view me-2", title: "View" do %>
                    <i class="bi bi-eye"></i>
                  <% end %>
                  <%= link_to edit_institute_admin_section_path(section), class: "btn action-btn btn-edit me-2", title: "Edit" do %>
                    <i class="bi bi-pencil"></i>
                  <% end %>
                  <% if section.participants_count > 0 %>
                    <%= link_to reassign_users_institute_admin_section_path(section), 
                        class: "btn action-btn btn-reassign me-2",
                        title: "Reassign Users" do %>
                      <i class="bi bi-people-fill"></i>
                    <% end %>
                  <% end %>
                  <%= button_to institute_admin_section_path(section),
                      method: :delete,
                      class: "btn action-btn btn-delete",
                      form: { style: 'display: inline-block' },
                      title: "Delete",
                      data: { turbo_confirm: "Are you sure you want to delete this section?" } do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-4">
        <i class="bi bi-grid-3x3 fs-1 text-muted mb-3"></i>
        <p class="text-muted mb-0">No sections found</p>
      </div>
    <% end %>
  </div>
</div>
</div>

<style>
  /* Modern Breadcrumb Styling */
  .breadcrumb-wrapper {
    background-color: #f8f9fa;
    border-radius: 8px;
    padding: 0.75rem 1rem;
  }
  
  .breadcrumb-custom {
    margin-bottom: 0;
    padding: 0;
    background: transparent;
  }
  
  .breadcrumb-custom .breadcrumb-item {
    font-size: 0.875rem;
    font-weight: 500;
  }
  
  .breadcrumb-custom .breadcrumb-item a {
    color: #6c757d;
    text-decoration: none;
    transition: color 0.2s;
  }
  
  .breadcrumb-custom .breadcrumb-item a:hover {
    color: var(--bs-primary);
  }
  
  .breadcrumb-custom .breadcrumb-item.active {
    color: var(--bs-primary);
    font-weight: 600;
  }
  
  .breadcrumb-custom .breadcrumb-item+.breadcrumb-item::before {
    content: "›";
    color: #adb5bd;
    font-size: 1rem;
    line-height: 1;
    padding: 0 0.5rem;
  }
</style> 