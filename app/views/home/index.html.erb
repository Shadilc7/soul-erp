      overflow: hidden;
    }

    .register-btn::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
      transition: left 0.5s;
    }

    .register-btn:hover::before {
      left: 100%;
    }

    .register-btn:hover {
      transform: translateY(-3px) scale(1.05);
      box-shadow: 0 8px 30px rgba(0, 182, 122, 0.6);
      color: white;
    }

    .register-btn i {
      font-size: 1.2rem;
    }

    .login-link {
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1rem 2.5rem;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      text-decoration: none;
      border-radius: 50px;
      font-weight: 600;
      font-size: 1rem;
      letter-spacing: 1.5px;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 4px 20px rgba(102, 126, 234, 0.4);
      margin-top: 1rem;
      position: relative;
      overflow: hidden;
    }

    .login-link::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
      transition: left 0.5s;
    }

    .login-link:hover::before {
      left: 100%;
    }

    .login-link:hover {
      transform: translateY(-3px) scale(1.05);
      box-shadow: 0 8px 30px rgba(102, 126, 234, 0.6);
      color: white;
    }

    .login-link i {
      font-size: 1.2rem;
    }

    /* Right Panel */
    .right-panel {
      position: relative;
      z-index: 1;
      background: transparent !important;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 3rem 2rem;
    }

    .login-form-container {
      width: 100%;
      max-width: 450px;
      background: linear-gradient(145deg, 
                  rgba(230, 255, 245, 0.95) 0%, 
                  rgba(255, 255, 255, 0.98) 30%,
                  rgba(240, 255, 250, 0.95) 70%,
                  rgba(220, 255, 240, 0.95) 100%);
      padding: 3rem;
      border-radius: 24px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3),
                  0 0 0 1px rgba(0, 182, 122, 0.2),
                  inset 0 1px 0 rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(10px);
      border: 2px solid rgba(0, 182, 122, 0.25);
      position: relative;
      overflow: hidden;
    }

    .login-form-container::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 6px;
      background: linear-gradient(90deg, #00B67A 0%, #00d68f 50%, #98D8AA 100%);
      border-radius: 24px 24px 0 0;
      box-shadow: 0 2px 10px rgba(0, 182, 122, 0.5);
    }

    .login-form-container::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 150px;
      background: radial-gradient(ellipse at bottom, rgba(0, 182, 122, 0.08) 0%, transparent 70%);
      pointer-events: none;
    }

    .form-header {
      text-align: center;
      margin-bottom: 2.5rem;
    }

    .form-header h2 {
      color: #1a1f36;
      font-size: 2rem;
      margin-bottom: 0.5rem;
      font-weight: 700;
      letter-spacing: -0.5px;
    }

    .form-header p {
      color: #8898aa;
      font-size: 0.95rem;
      margin: 0;
      font-weight: 500;
    }

    .form-group {
      margin-bottom: 1.8rem;
    }

    .form-label {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      color: #1a1f36;
      font-weight: 600;
      font-size: 0.875rem;
