    }

    .login-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(0, 182, 122, 0.4),
                  0 4px 8px rgba(0, 0, 0, 0.15);
    }

    .login-btn:active {
      transform: translateY(0);
      box-shadow: 0 2px 8px rgba(0, 182, 122, 0.3);
    }

    .form-footer {
      margin-top: 1.5rem;
      text-align: center;
    }

    .forgot-password {
      color: #8898aa;
      text-decoration: none;
      font-size: 0.875rem;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      transition: all 0.3s ease;
      font-weight: 600;
      padding: 0.5rem 0;
    }

    .forgot-password:hover {
      color: #00B67A;
      text-decoration: none;
      transform: translateX(2px);
    }

    .forgot-password i {
      font-size: 0.9rem;
      transition: transform 0.3s ease;
    }

    .forgot-password:hover i {
      transform: translateX(2px);
    }

    @media (max-width: 768px) {
      .login-container {
        flex-direction: column;
      }

      .left-panel {
        min-height: 100vh;
        padding: 2rem 1rem;
      }

      .right-panel {
        min-height: 100vh;
        padding-top: 2rem;
      }

      .login-form-container {
        padding: 2rem 1.5rem;
        max-width: 100%;
      }

      .welcome-title {
        font-size: 2.5rem;
      }

      .logo-icon {
        width: 100px;
        height: 100px;
      }

      .welcome-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
      }
    }

    @media (max-width: 480px) {
      .login-form-container {
        padding: 1.5rem 1rem;
        border-radius: 16px;
      }

      .form-header h2 {
        font-size: 1.8rem;
      }

      .register-btn {
        padding: 1rem 2rem;
        font-size: 0.9rem;
      }
    }
  </style>
<% end %>