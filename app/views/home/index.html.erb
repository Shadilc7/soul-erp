  <div class="container py-5 reveal text-center position-relative z-1">
    <h6 class="text-uppercase text-white opacity-75 fw-bold mb-3 text-tracking-2">Our Impact</h6>
    <h2 class="fw-bold text-white mb-5 display-5">Impact That Speaks</h2>
    <div class="row justify-content-center g-4">
