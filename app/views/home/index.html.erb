  <meta property="og:site_name" content="BeYa">
  <meta property="og:title" content="BeYa — Where Habit Becomes Character">
  <meta property="og:description" content="BeYa is a behavioral life-skills organization from Kerala, India, transforming families, schools, corporates, and hospitals through structured daily practice.">
  <meta property="og:url" content="https://beya.in/">
  <meta property="og:image" content="https://beya.in/assets/beya_logo_color.png">
  <meta property="og:locale" content="en_IN">

  <%# ── SEO: Twitter Card ── %>
