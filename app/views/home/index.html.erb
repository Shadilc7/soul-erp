<div class="login-container" style="background: linear-gradient(135deg, #0a0f0d 0%, #1a3d2e 50%, #0a0f0d 100%) !important;">
  <!-- Animated Background -->
  <div class="animated-bg">
    <div class="geometric-shape shape-1"></div>
    <div class="geometric-shape shape-2"></div>
    <div class="geometric-shape shape-3"></div>
    <div class="geometric-shape shape-4"></div>
    <div class="light-beam beam-1"></div>
    <div class="light-beam beam-2"></div>
    <div class="particle particle-1"></div>
    <div class="particle particle-2"></div>
    <div class="particle particle-3"></div>
    <div class="particle particle-4"></div>
    <div class="particle particle-5"></div>
    <div class="particle particle-6"></div>
  </div>

  <!-- Left Panel -->
  <div class="left-panel" style="background: transparent !important; background-color: transparent !important;">
    <div class="logo-container">
      <h1 class="logo-text">
        <span class="gradient-text">BeYa</span>
      </h1>
    </div>
    
    <div class="welcome-content">
      <p class="welcome-subtitle">
        <i class="bi bi-mortarboard-fill"></i>
         Enriching Lives
      </p>
      <%= link_to new_user_registration_path, class: "register-btn" do %>
        <i class="bi bi-person-plus-fill"></i>
        <span>REGISTER HERE</span>
      <% end %>
      <a href="#login-section" class="login-link d-md-none">
        <i class="bi bi-box-arrow-in-right"></i>
        <span>LOGIN</span>
      </a>
    </div>
  </div>

  <!-- Right Panel -->
  <div class="right-panel" id="login-section" style="background: transparent !important; background-color: transparent !important;">
    <div class="login-form-container">
      <div class="form-header">
        <h2>Welcome Back</h2>
        <p>Sign in to continue to your dashboard</p>
      </div>
      
      <%= form_for(:user, url: session_path(:user), html: { class: "login-form" }) do |f| %>
        <div class="form-group">
          <label class="form-label">
            <i class="bi bi-person-circle"></i>
            Username or Email
          </label>
          <%= f.text_field :login, class: "form-input", placeholder: "Enter your username or email", required: true %>
        </div>

        <div class="form-group">
          <label class="form-label">
            <i class="bi bi-lock-fill"></i>
            Password
          </label>
          <div class="password-input-wrapper">
            <%= f.password_field :password, class: "form-input", placeholder: "Enter your password", required: true, id: "password-field" %>
            <button type="button" class="password-toggle" onclick="togglePassword()">
              <i class="bi bi-eye-fill" id="toggle-icon"></i>
            </button>
          </div>
        </div>

        <%= f.submit "LOGIN", class: "login-btn" %>
        
        <div class="form-footer">
          <%= link_to new_user_password_path, class: "forgot-password" do %>
            <i class="bi bi-key"></i>
            Forgot Password?
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
function togglePassword() {
  const passwordField = document.getElementById('password-field');
  const toggleIcon = document.getElementById('toggle-icon');
  
  if (passwordField.type === 'password') {
    passwordField.type = 'text';
    toggleIcon.classList.remove('bi-eye-fill');
    toggleIcon.classList.add('bi-eye-slash-fill');
  } else {
    passwordField.type = 'password';
    toggleIcon.classList.remove('bi-eye-slash-fill');
    toggleIcon.classList.add('bi-eye-fill');
  }
}
</script>

<% content_for :styles do %>
  <style>
    /* Animated Background */
    .animated-bg {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 0;
      overflow: hidden;
      pointer-events: none;
    }

    /* Geometric Shapes */
    .geometric-shape {
      position: absolute;
      opacity: 0.15;
      filter: blur(1px);
      animation: drift 25s infinite ease-in-out;
    }

    .shape-1 {
      width: 0;
      height: 0;
      border-left: 60px solid transparent;
      border-right: 60px solid transparent;
      border-bottom: 100px solid rgba(0, 214, 143, 0.3);
      top: 10%;
      left: 5%;
      animation: drift1 20s infinite ease-in-out;
    }

    .shape-2 {
      width: 80px;
      height: 80px;
      background: linear-gradient(135deg, rgba(0, 182, 122, 0.25), rgba(152, 216, 170, 0.15));
      transform: rotate(45deg);
      top: 60%;
      right: 10%;
      animation: drift2 24s infinite ease-in-out, rotate 30s infinite linear;
    }

    .shape-3 {
      width: 100px;
      height: 100px;
      clip-path: polygon(50% 0%, 100% 38%, 82% 100%, 18% 100%, 0% 38%);
      background: linear-gradient(135deg, rgba(0, 214, 143, 0.3), rgba(0, 182, 122, 0.15));
      bottom: 15%;
      left: 15%;
      animation: drift3 28s infinite ease-in-out;
    }

    .shape-4 {
      width: 70px;
      height: 70px;
      background: linear-gradient(135deg, rgba(152, 216, 170, 0.25), rgba(0, 182, 122, 0.2));
      clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%);
      top: 35%;
      left: 45%;
      animation: drift4 22s infinite ease-in-out, rotate 25s infinite linear reverse;
    }

    /* Light Beams */
    .light-beam {
      position: absolute;
      width: 2px;
      height: 200px;
      background: linear-gradient(to bottom, transparent, rgba(0, 214, 143, 0.4), transparent);
      filter: blur(2px);
      opacity: 0;
    }

    .beam-1 {
      top: -200px;
      left: 30%;
      animation: beam-fall1 12s infinite ease-in;
      animation-delay: 2s;
    }

    .beam-2 {
      top: -200px;
      right: 25%;
      animation: beam-fall2 15s infinite ease-in;
      animation-delay: 7s;
    }

    /* Particles */
    .particle {
      position: absolute;
      width: 4px;
      height: 4px;
      background: rgba(0, 214, 143, 0.6);
      border-radius: 50%;
      box-shadow: 0 0 10px rgba(0, 214, 143, 0.5);
      animation: particle-float 15s infinite ease-in-out;
    }

    .particle-1 {
      top: 20%;
      left: 10%;
      animation: particle-float1 18s infinite ease-in-out;
    }

    .particle-2 {
      top: 50%;
      right: 15%;
      animation: particle-float2 22s infinite ease-in-out;
      animation-delay: 3s;
    }

    .particle-3 {
      bottom: 25%;
      left: 25%;
      animation: particle-float3 20s infinite ease-in-out;
      animation-delay: 5s;
    }

    .particle-4 {
      top: 70%;
      right: 30%;
      animation: particle-float4 24s infinite ease-in-out;
      animation-delay: 2s;
    }

    .particle-5 {
      top: 40%;
      left: 60%;
      animation: particle-float5 19s infinite ease-in-out;
      animation-delay: 6s;
    }

    .particle-6 {
      bottom: 35%;
      right: 45%;
      animation: particle-float6 21s infinite ease-in-out;
      animation-delay: 4s;
    }

    /* Animations */
    @keyframes drift1 {
      0%, 100% {
        transform: translate(0, 0) rotate(0deg);
        opacity: 0.15;
      }
      50% {
        transform: translate(100px, 80px) rotate(180deg);
        opacity: 0.25;
      }
    }

    @keyframes drift2 {
      0%, 100% {
        transform: translate(0, 0) rotate(45deg);
        opacity: 0.12;
      }
      50% {
        transform: translate(-80px, -70px) rotate(225deg);
        opacity: 0.22;
      }
    }

    @keyframes drift3 {
      0%, 100% {
        transform: translate(0, 0) scale(1);
        opacity: 0.18;
      }
      50% {
        transform: translate(70px, -90px) scale(1.2);
        opacity: 0.28;
      }
    }

    @keyframes drift4 {
      0%, 100% {
        transform: translate(0, 0) scale(1);
        opacity: 0.14;
      }
      50% {
        transform: translate(-60px, 100px) scale(0.8);
        opacity: 0.24;
      }
    }

    @keyframes rotate {
      from {
        transform: rotate(0deg);
      }
      to {
        transform: rotate(360deg);
      }
    }

    @keyframes beam-fall1 {
      0% {
        top: -200px;
        opacity: 0;
      }
      10% {
        opacity: 1;
      }
      90% {
        opacity: 1;
      }
      100% {
        top: 100%;
        opacity: 0;
      }
    }

    @keyframes beam-fall2 {
      0% {
        top: -200px;
        opacity: 0;
      }
      10% {
        opacity: 1;
      }
      90% {
        opacity: 1;
      }
      100% {
        top: 100%;
        opacity: 0;
      }
    }

    @keyframes particle-float1 {
      0%, 100% {
        transform: translate(0, 0);
        opacity: 0.3;
      }
      25% {
        transform: translate(50px, -80px);
        opacity: 0.8;
      }
      50% {
        transform: translate(100px, -40px);
        opacity: 0.5;
      }
      75% {
        transform: translate(70px, -120px);
        opacity: 0.9;
      }
    }

    @keyframes particle-float2 {
      0%, 100% {
        transform: translate(0, 0);
        opacity: 0.4;
      }
      25% {
        transform: translate(-60px, 70px);
        opacity: 0.7;
      }
      50% {
        transform: translate(-110px, 30px);
        opacity: 0.6;
      }
      75% {
        transform: translate(-80px, 100px);
        opacity: 0.8;
      }
    }

    @keyframes particle-float3 {
      0%, 100% {
        transform: translate(0, 0);
        opacity: 0.35;
      }
      25% {
        transform: translate(80px, -60px);
        opacity: 0.75;
      }
      50% {
        transform: translate(40px, -110px);
        opacity: 0.55;
      }
      75% {
        transform: translate(100px, -80px);
        opacity: 0.85;
      }
    }

    @keyframes particle-float4 {
      0%, 100% {
        transform: translate(0, 0);
        opacity: 0.32;
      }
      25% {
        transform: translate(-70px, -50px);
        opacity: 0.72;
      }
      50% {
        transform: translate(-40px, -100px);
        opacity: 0.52;
      }
      75% {
        transform: translate(-90px, -70px);
        opacity: 0.82;
      }
    }

    @keyframes particle-float5 {
      0%, 100% {
        transform: translate(0, 0);
        opacity: 0.38;
      }
      25% {
        transform: translate(60px, 80px);
        opacity: 0.78;
      }
      50% {
        transform: translate(30px, 120px);
        opacity: 0.58;
      }
      75% {
        transform: translate(90px, 100px);
        opacity: 0.88;
      }
    }

    @keyframes particle-float6 {
      0%, 100% {
        transform: translate(0, 0);
        opacity: 0.36;
      }
      25% {
        transform: translate(-50px, -70px);
        opacity: 0.76;
      }
      50% {
        transform: translate(-90px, -50px);
        opacity: 0.56;
      }
      75% {
        transform: translate(-70px, -90px);
        opacity: 0.86;
      }
    }

    /* Left Panel */
    .left-panel {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 3rem 2rem;
      padding-top: 25vh;
      background: transparent !important;
    }

    .logo-container {
      margin-bottom: 3rem;
      text-align: center;
    }

    .logo-text {
      font-size: clamp(4rem, 8vw, 6rem);
      font-weight: 800;
      margin: 0;
      text-shadow: 0 8px 40px rgba(0, 182, 122, 0.4),
                   0 0 30px rgba(0, 182, 122, 0.3);
      animation: logo-float 3s ease-in-out infinite;
    }

    @keyframes logo-float {
      0%, 100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-10px);
      }
    }

    .welcome-content {
      max-width: 500px;
      margin: 0 auto;
    }

    .welcome-title {
      font-size: clamp(2.5rem, 5vw, 4rem);
      margin-bottom: 1rem;
      font-weight: 700;
      color: #ffffff;
      line-height: 1.2;
    }

    .gradient-text {
      background: linear-gradient(135deg, #00B67A 0%, #00d68f 50%, #98D8AA 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: gradient-shift 3s ease infinite;
      background-size: 200% 200%;
    }

    @keyframes gradient-shift {
      0%, 100% {
        background-position: 0% 50%;
      }
      50% {
        background-position: 100% 50%;
      }
    }

    .welcome-subtitle {
      font-size: 1.2rem;
      color: #b8bcc4;
      margin-bottom: 3rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }

    .welcome-subtitle i {
      font-size: 1.4rem;
      color: #00B67A;
    }

    .register-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.7rem;
      background: linear-gradient(135deg, #00B67A 0%, #00d68f 100%);
      color: white;
