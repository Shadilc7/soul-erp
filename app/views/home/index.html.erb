<!-- 1. HERO SECTION -->
<section id="hero" class="hero-section d-flex align-items-center text-center">
  <div class="container reveal">
    <div class="hero-tagline-wrap mb-2">
      <span class="hero-tagline">Built from a Mother's Dream</span>
    </div>
    <h1 class="hero-title fw-bolder mb-4 mx-auto">
      Where Habit Becomes<br/><span class="gradient-text-2">Character</span>
    </h1>
