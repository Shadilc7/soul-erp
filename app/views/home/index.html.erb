<% content_for :head do %>
  <%# ── SEO: Primary Meta Tags ── %>
  <title>BeYa — Where Habit Becomes Character | Behavioral Life-Skills, Kerala</title>
  <meta name="description" content="BeYa is a behavioral life-skills organization from Kerala, India. Two programs — BeYa Trainings and BeYa MediBuk — transforming families, schools, corporates, and hospitals through structured daily practice.">
  <meta name="keywords" content="BeYa, life skills training, behavioral development, Kerala, MediBuk, family program, schools program, corporate training, hospital patient flow, Sabith Ali, Wayanad">
  <meta name="author" content="BeYa — Sabith Ali">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://beya.in/">

  <%# ── SEO: Open Graph (Facebook / WhatsApp / LinkedIn) ── %>
