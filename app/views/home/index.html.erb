  <meta name="twitter:title" content="BeYa — Where Habit Becomes Character">
  <meta name="twitter:description" content="Behavioral life-skills training for families, schools, corporates, and hospitals across Kerala, India.">
  <meta name="twitter:image" content="https://beya.in/assets/beya_logo_color.png">

