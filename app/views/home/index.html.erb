<!-- Theme toggle functionality & Animations -->
<script>
  // Theme Toggle Logic
  const toggleBtn = document.getElementById('themeToggleBtn');
  
  toggleBtn.addEventListener('click', () => {
    const currentTheme = document.documentElement.getAttribute('data-theme');
    const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
    
    document.documentElement.setAttribute('data-theme', newTheme);
    localStorage.setItem('beyaTheme', newTheme);
  });

  // Scroll Reveal Logic
  function reveal() {
    var reveals = document.querySelectorAll(".reveal");
    for (var i = 0; i < reveals.length; i++) {
        var windowHeight = window.innerHeight;
        var elementTop = reveals[i].getBoundingClientRect().top;
        var elementVisible = 100;
        if (elementTop < windowHeight - elementVisible) {
            reveals[i].classList.add("active");
        }
    }
  }
  window.addEventListener("scroll", reveal);
  // Initial check
  document.addEventListener("DOMContentLoaded", reveal);

  // FAQ Accordion Logic
  document.querySelectorAll('.faq-question').forEach(button => {
    button.addEventListener('click', () => {
      const faqItem = button.parentElement;
      
      // Close all other items
      document.querySelectorAll('.faq-item').forEach(item => {
        if (item !== faqItem) item.classList.remove('active');
      });
      
      // Toggle current item
      faqItem.classList.toggle('active');
    });
  });

  // Scroll Tracker Logic
  window.addEventListener('scroll', () => {
    const scrollTracker = document.querySelector('.scroll-tracker');
    if (scrollTracker) {
      const docHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrollPos = window.scrollY;
      const scrollPercent = (scrollPos / docHeight) * 100;
      scrollTracker.style.width = scrollPercent + '%';
    }
  });
</script>

<% content_for :styles do %>
  <style>
    /* CSS Variables system for Theming */
    :root {
      /* LIGHT MODE VARIABLES */
      --bg-primary: #f8fafc;
      --bg-secondary: #f1f5f9;
      --bg-card: #ffffff;
      --bg-nav: rgba(255, 255, 255, 0.85);
      
      --text-primary: #0f172a;
      --text-secondary: #475569;
      
      --border-color: #e2e8f0;
      --border-glow: rgba(59, 130, 246, 0.15);
      
      --card-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.01);
      --card-hover-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
      
      --gradient-1: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%);
      --gradient-2: linear-gradient(135deg, #EC4899 0%, #8B5CF6 100%);
      --gradient-3: linear-gradient(135deg, #10B981 0%, #3B82F6 100%);
      
      --btn-secondary-bg: #f1f5f9;
      --btn-secondary-text: #0f172a;
      --btn-secondary-hover: #e2e8f0;
      
      --shape-primary: rgba(59, 130, 246, 0.15);
      --shape-secondary: rgba(236, 72, 153, 0.1);
      --shape-accent: rgba(139, 92, 246, 0.15);
      
      /* Vibrant Colors for Light Theme */
      --color-blue: #3B82F6;
      --color-pink: #EC4899;
      --color-indigo: #4F46E5;
      --color-teal: #14B8A6;
      --color-orange: #F97316;
      --color-purple: #A855F7;
    }

    /* DARK MODE VARIABLES */
    [data-theme="dark"] {
      --bg-primary: #0B1120;
      --bg-secondary: #0d1612; /* Keep a hint of deep rich green-black */
      --bg-card: #151E32;
      --bg-nav: rgba(11, 17, 32, 0.85);
      
      --text-primary: #f8fafc;
      --text-secondary: #94a3b8;
      
      --border-color: rgba(255, 255, 255, 0.08);
      --border-glow: rgba(59, 130, 246, 0.3);
      
      --card-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.5), 0 8px 10px -6px rgba(0, 0, 0, 0.3);
      --card-hover-shadow: 0 20px 30px -5px rgba(0, 0, 0, 0.6), 0 10px 10px -5px rgba(0, 0, 0, 0.4);
      
      --gradient-1: linear-gradient(135deg, #60A5FA 0%, #C084FC 100%);
      --gradient-2: linear-gradient(135deg, #F472B6 0%, #C084FC 100%);
      --gradient-3: linear-gradient(135deg, #2DD4BF 0%, #60A5FA 100%);
      
      --btn-secondary-bg: rgba(255, 255, 255, 0.05);
      --btn-secondary-text: #f8fafc;
      --btn-secondary-hover: rgba(255, 255, 255, 0.1);
      
      --shape-primary: rgba(59, 130, 246, 0.2);
      --shape-secondary: rgba(236, 72, 153, 0.15);
      --shape-accent: rgba(139, 92, 246, 0.2);
      
      /* Vibrant Bright Colors for Dark Theme */
      --color-blue: #60A5FA;
      --color-pink: #F472B6;
      --color-indigo: #818CF8;
      --color-teal: #2DD4BF;
      --color-orange: #FB923C;
      --color-purple: #C084FC;
    }

    /* Base Setup */
    html {
      scroll-behavior: smooth;
    }
    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg-primary);
      color: var(--text-primary);
      margin: 0;
      overflow-x: hidden;
      transition: background-color 0.4s ease, color 0.4s ease;
    }
    
    /* Scroll Tracker */
    .scroll-tracker {
      position: fixed;
      top: 0;
      left: 0;
      height: 4px;
      background: var(--gradient-1); /* Vibrant Multi-Color Gradient */
      width: 0%;
      z-index: 2000; /* Must be entirely above the navbar */
      transition: width 0.1s ease-out;
    }
    
    h1, h2, h3, h4, h5, h6, .outfit, .logo-text {
      font-family: 'Outfit', sans-serif;
    }

    .text-primary-color { color: var(--text-primary) !important; font-family: 'Outfit', sans-serif;}
    .text-secondary-color { color: var(--text-secondary) !important; }
    .section-darker { background-color: var(--bg-secondary); }
    .fs-sm { font-size: 0.9rem; line-height: 1.5; }
    .section-title { font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.5px; }

    /* Gradients */
    .gradient-text-1 {
      background: var(--gradient-1); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      padding: 0.25em 0; display: inline-block; line-height: normal; margin-bottom: -0.25em;
    }
    .gradient-text-2 {
      background: var(--gradient-2); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      padding: 0.25em 0; display: inline-block; line-height: normal; margin-bottom: -0.25em;
    }
    .gradient-text-3 {
      background: var(--gradient-3); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      padding: 0.25em 0; display: inline-block; line-height: normal; margin-bottom: -0.25em;
    }
    
    .gradient-bg-1 { background: var(--gradient-1); }
    .gradient-bg-2 { background: var(--gradient-2); }
    .gradient-bg-3 { background: var(--gradient-3); }
    
    .text-blue { color: var(--color-blue); }
    .text-pink { color: var(--color-pink); }
    .text-teal { color: var(--color-teal); }
    .text-accent { color: var(--color-purple); }
    .text-hover-primary:hover { color: var(--color-blue) !important; }

    /* Animated Background */
    .landing-bg {
      position: absolute; top: 0; left: 0; width: 100%; height: 100%;
      overflow: hidden; z-index: -1; pointer-events: none;
    }
    
    .blur-blob {
      position: absolute; filter: blur(80px); border-radius: 50%;
      animation: float-shape 25s infinite ease-in-out alternate;
    }
    
    .shape-primary { background: var(--shape-primary); width: 600px; height: 600px; top: -10%; left: -20%; }
    .shape-secondary { background: var(--shape-secondary); width: 500px; height: 500px; top: 30%; right: -10%; animation-delay: -10s; }
    .shape-accent { background: var(--shape-accent); width: 400px; height: 400px; bottom: -10%; left: 30%; animation-delay: -5s; }

    /* Floating wireframe boxes (concept) */
    .floating-cube {
      position: absolute; border: 1px solid var(--border-glow); border-radius: 12px;
      backdrop-filter: blur(2px); animation: float-particle 20s infinite linear;
    }
    .cube-1 { width: 50px; height: 50px; top: 20%; left: 15%; animation-duration: 35s; transform: rotate(45deg); }
    .cube-2 { width: 80px; height: 80px; top: 70%; left: 85%; animation-duration: 40s; transform: rotate(15deg); }
    .cube-3 { width: 40px; height: 40px; top: 40%; left: 75%; animation-duration: 25s; transform: rotate(60deg); }

    @keyframes float-shape { 0% { transform: translate(0,0) scale(1); } 100% { transform: translate(100px, 50px) scale(1.1); } }
    @keyframes float-particle { 0% { transform: translateY(0) rotate(0deg); opacity: 0; } 10% { opacity: 0.5; } 90% { opacity: 0.5; } 100% { transform: translateY(-100vh) rotate(360deg); opacity: 0; } }

    /* Navbar */
    .landing-navbar {
      position: fixed; top: 0; left: 0; width: 100%; height: 80px; z-index: 1000;
      background: var(--bg-nav); backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border-color);
      transition: background 0.4s, border-color 0.4s;
    }
    .logo-text { font-size: 2rem; font-weight: 800; letter-spacing: -1px; line-height: 1.2; position: relative; top: 5px; }
    
    .nav-link { color: var(--text-secondary); font-weight: 500; font-size: 0.95rem; text-decoration: none; transition: color 0.3s; }
    .nav-link:hover { color: var(--text-primary); }
    
    .nav-divider { width: 1px; height: 24px; background-color: var(--border-color); }
    
    .btn-register-sm { background: var(--gradient-1); color: #fff; padding: 0.6rem 1.4rem; border-radius: 8px; font-weight: 600; text-decoration: none; transition: all 0.3s; border: none;}
    .btn-register-sm:hover { transform: translateY(-2px); box-shadow: var(--card-hover-shadow); color: #fff;}

    /* Theme Toggle Button */
    .theme-toggle {
      background: transparent; border: none; font-size: 1.2rem; cursor: pointer; color: var(--text-secondary);
      display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%;
      transition: background 0.3s, color 0.3s;
    }
    .theme-toggle:hover { background: var(--bg-secondary); color: var(--color-blue); }
    
    [data-theme="dark"] .icon-moon { display: none; }
    [data-theme="dark"] .icon-sun { display: block; color: var(--color-orange); }
    [data-theme="light"] .icon-sun { display: none; }
    [data-theme="light"] .icon-moon { display: block; }

    /* Hero Section */
    .hero-section { min-height: 100vh; padding-top: 100px; position: relative; overflow: hidden;}
    
    .hero-badge { 
      background: var(--bg-secondary); padding: 0.5rem 1.25rem; border-radius: 50px; 
      border: 1px solid var(--border-color); color: var(--text-secondary); font-size: 0.9rem; font-weight: 500; 
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }
    .badge-dot { width: 8px; height: 8px; background: var(--color-blue); border-radius: 50%; display: inline-block; box-shadow: 0 0 10px var(--color-blue); }
    
    .hero-title { font-size: clamp(3rem, 6vw, 5rem); line-height: 1.1; letter-spacing: -2px; }
    .hero-subtitle { font-size: clamp(1.1rem, 2vw, 1.25rem); max-width: 650px; line-height: 1.6; }
    
    .btn-primary-lg { display: inline-block; background: var(--gradient-1); color: #fff; border: none; padding: 1.1rem 2.5rem; border-radius: 12px; font-weight: 600; font-size: 1.05rem; text-decoration: none; transition: transform 0.3s, box-shadow 0.3s; }
    .btn-secondary-lg { display: inline-block; background: var(--btn-secondary-bg); color: var(--btn-secondary-text); border: 1px solid var(--border-color); padding: 1.1rem 2.5rem; border-radius: 12px; font-weight: 600; font-size: 1.05rem; text-decoration: none; transition: all 0.3s; }
    .btn-secondary-lg:hover { background: var(--btn-secondary-hover); transform: translateY(-2px); color: var(--btn-secondary-text); }
    .shadow-glow-primary:hover { transform: translateY(-3px); box-shadow: 0 15px 30px rgba(59, 130, 246, 0.4); color: #fff; }

    /* Hero Mockup Graphic */
    .hero-mockup {
      width: 100%; max-width: 800px; height: 350px; background: var(--bg-card);
      border-radius: 16px 16px 0 0; border: 1px solid var(--border-color); border-bottom: none;
      box-shadow: var(--card-shadow); position: relative; overflow: hidden;
      mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
      -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    }
    .mockup-header { padding: 1rem; border-bottom: 1px solid var(--border-color); display: flex; align-items: center; }
    .mockup-dots { display: flex; gap: 6px; }
    .mockup-dots span { width: 10px; height: 10px; border-radius: 50%; background: var(--border-color); }
    .mockup-body { height: 100%; background: radial-gradient(circle at center, var(--bg-secondary) 0%, var(--bg-card) 100%); }
    .mockup-stat-card {
      background: var(--bg-card); padding: 2rem; border-radius: 16px; border: 1px solid var(--border-color);
      box-shadow: var(--card-shadow); display: inline-block;
    }
    .floating-slow { animation: float-card 6s ease-in-out infinite; }
    @keyframes float-card { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-15px); } }

    /* How it Works Section */
    .timeline-line {
      position: absolute; top: 20%; left: 0; width: 100%; height: 2px;
      background: linear-gradient(90deg, transparent 0%, var(--border-color) 20%, var(--border-color) 80%, transparent 100%);
      z-index: 0;
    }
    .step-card { position: relative; z-index: 1; }
    .step-icon-wrapper {
      width: 80px; height: 80px; border-radius: 20px; display: flex; align-items: center; justify-content: center;
      box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1); transform: rotate(-5deg); transition: transform 0.4s;
    }
    .step-card:hover .step-icon-wrapper { transform: rotate(0) scale(1.1); }

    /* Hover Animations */
    .hover-scale { transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    .hover-scale:hover { transform: scale(1.05); }

    /* Keyframe Entrance Animations */
    @keyframes fadeInUp {
      0% { opacity: 0; transform: translateY(50px); }
      100% { opacity: 1; transform: translateY(0); }
    }
    
    @keyframes zoomInPulse {
      0% { opacity: 0; transform: scale(0.85); box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.4); }
      70% { transform: scale(1.02); box-shadow: 0 0 0 10px rgba(59, 130, 246, 0); }
      100% { opacity: 1; transform: scale(1); box-shadow: 0 0 0 0 rgba(59, 130, 246, 0); }
    }
    
    .hero-title, .hero-subtitle { animation: fadeInUp 1s ease-out forwards; }
    .hero-badge { animation: fadeInUp 0.8s ease-out forwards; }
    .hero-ctas { animation: fadeInUp 1.2s ease-out forwards; }

    /* Improved Scroll Reveal */
    .reveal { opacity: 0; transform: translateY(50px) scale(0.98); transition: all 1s cubic-bezier(0.16, 1, 0.3, 1); }
    .reveal.active { opacity: 1; transform: translateY(0) scale(1); }
    
    /* Staggered Feature Cards */
    .feature-card {
      background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 16px;
      box-shadow: var(--card-shadow); transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s, border-color 0.4s;
    }
    .feature-card:hover { transform: translateY(-10px) scale(1.02); box-shadow: var(--card-hover-shadow); border-color: var(--border-glow); }
    
    .feature-icon-box {
      width: 54px; height: 54px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.6rem;
      transition: transform 0.4s;
    }
    .feature-card:hover .feature-icon-box { transform: scale(1.15) rotate(5deg); }
    
    /* Colorful Feature Boxes */
    .box-blue { background: rgba(59, 130, 246, 0.1); color: var(--color-blue); }
    .box-pink { background: rgba(236, 72, 153, 0.1); color: var(--color-pink); }
    .box-indigo { background: rgba(79, 70, 229, 0.1); color: var(--color-indigo); }
    .box-teal { background: rgba(20, 184, 166, 0.1); color: var(--color-teal); }
    .box-orange { background: rgba(249, 115, 22, 0.1); color: var(--color-orange); }
    .box-purple { background: rgba(168, 85, 247, 0.1); color: var(--color-purple); }
    
    /* Portal Card Bounce */
    .portal-card {
      background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 16px;
      box-shadow: var(--card-shadow); transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s; position: relative; overflow: hidden;
    }
    .portal-card::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 4px; background: var(--border-color); transition: background 0.4s; }
    .portal-card:hover { transform: translateY(-12px); box-shadow: var(--card-hover-shadow); }
    .portal-card:hover::before { background: var(--gradient-1); }
    
    .portal-icon { width: 72px; height: 72px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; transition: transform 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55); }
    .portal-card:hover .portal-icon { transform: scale(1.2); }
    
    .portal-list li { margin-bottom: 0.8rem; font-size: 0.95rem; list-style: none; display: flex; align-items: center; gap: 0.5rem; transition: transform 0.3s; }
    .portal-card:hover .portal-list li { transform: translateX(5px); }

    /* FAQ Section */
    .faq-accordion { display: flex; flex-direction: column; gap: 1rem; }
    .faq-item {
      background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 12px; overflow: hidden;
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .faq-item.active { border-color: var(--color-blue); box-shadow: var(--card-shadow); }
    
    .faq-question {
      width: 100%; text-align: left; padding: 1.5rem; background: transparent; border: none; cursor: pointer;
      display: flex; justify-content: space-between; align-items: center; font-size: 1.1rem;
    }
    .faq-icon { transition: transform 0.3s ease; color: var(--text-secondary); }
    .faq-item.active .faq-icon { transform: rotate(180deg); color: var(--color-blue); }
    
    .faq-answer {
      max-height: 0; overflow: hidden; transition: max-height 0.4s ease, padding 0.4s ease; background: var(--bg-card); padding: 0 1.5rem;
    }
    .faq-item.active .faq-answer { max-height: 200px; padding: 0 1.5rem 1.5rem 1.5rem; }

    /* Final CTA Section */
    .border-glow {
      background: var(--bg-card); border: 1px solid var(--border-color); border-radius: 24px;
      box-shadow: var(--card-shadow);
    }
    .cta-glow-1 { position: absolute; top: -50px; left: -50px; width: 200px; height: 200px; background: var(--color-purple); filter: blur(100px); opacity: 0.4; pointer-events: none; border-radius: 50%; }
    .cta-glow-2 { position: absolute; bottom: -50px; right: -50px; width: 250px; height: 250px; background: var(--color-blue); filter: blur(120px); opacity: 0.3; pointer-events: none; border-radius: 50%; }

    /* Scroll Reveal */
    .reveal { opacity: 0; transform: translateY(40px); transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
    .reveal.active { opacity: 1; transform: translateY(0); }
  </style>
<% end %>