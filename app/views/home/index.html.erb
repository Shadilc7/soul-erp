<!-- JavaScript Logic -->
<script>
  // ── Theme Toggle ──────────────────────────────────────────────
  function applyTheme(newTheme) {
    document.documentElement.setAttribute('data-theme', newTheme);
    localStorage.setItem('beyaTheme', newTheme);
  }

  const toggleBtnDesktop = document.getElementById('themeToggleBtn');
  const toggleBtnMobile = document.getElementById('themeToggleBtnMobile');

  function themeHandler() {
    const currentTheme = document.documentElement.getAttribute('data-theme');
    applyTheme(currentTheme === 'dark' ? 'light' : 'dark');
  }

  if(toggleBtnDesktop) toggleBtnDesktop.addEventListener('click', themeHandler);
  if(toggleBtnMobile) toggleBtnMobile.addEventListener('click', themeHandler);

  // ── Scroll Reveal ─────────────────────────────────────────────
  function reveal() {
    const classes = ['reveal', 'reveal-left', 'reveal-right'];
    classes.forEach(cls => {
      document.querySelectorAll('.' + cls).forEach(el => {
        if (el.getBoundingClientRect().top < window.innerHeight - 100) {
          el.classList.add('active');
        }
      });
    });
  }

  // ── Mobile Navbar ─────────────────────────────────────────────
  function initLandingNavbar() {
    const navCollapseEl = document.getElementById('navCollapse');
    const navToggler = document.getElementById('navMenuToggle');
    if (!navCollapseEl || !navToggler) return;
    if (navCollapseEl.dataset.mobileNavInit === 'true') return;
    navCollapseEl.dataset.mobileNavInit = 'true';

    function closeMobileNav() {
      navCollapseEl.classList.remove('show');
      navToggler.setAttribute('aria-expanded', 'false');
    }

    navCollapseEl.querySelectorAll('a').forEach(el => {
      el.addEventListener('click', (e) => {
        const href = el.getAttribute('href');
        if (window.innerWidth < 992 && href && href.startsWith('#')) {
          e.preventDefault();
          closeMobileNav();
          // Wait for mobile nav collapse transition before scrolling
          setTimeout(() => {
            const target = document.querySelector(href);
            if (target) target.scrollIntoView({ behavior: 'smooth' });
          }, 320);
        } else {
          closeMobileNav();
        }
      });
    });

    navToggler.addEventListener('click', (event) => {
      if (window.innerWidth >= 992) return;
      event.preventDefault();
      event.stopPropagation();
      const willOpen = !navCollapseEl.classList.contains('show');
      navCollapseEl.classList.toggle('show', willOpen);
      navToggler.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
    });

    document.addEventListener('click', (event) => {
      const clickedInsideMenu = navCollapseEl.contains(event.target);
      const clickedToggler = navToggler.contains(event.target);
      if (navCollapseEl.classList.contains('show') && !clickedInsideMenu && !clickedToggler) {
        closeMobileNav();
      }
    });

    window.addEventListener('hashchange', closeMobileNav);
    window.addEventListener('resize', () => { if (window.innerWidth >= 992) closeMobileNav(); });
    document.addEventListener('turbo:before-cache', closeMobileNav);
    closeMobileNav();
  }

  // ── Active Nav Link on Scroll ─────────────────────────────────
  function initActiveNavLinks() {
    const navLinks = document.querySelectorAll('.nav-link[href^="#"]');
    const sectionIds = ['hero', 'about', 'origin', 'life-skills', 'medibuk', 'founder', 'videos'];
    const sections = sectionIds.map(id => document.getElementById(id)).filter(Boolean);

    function updateActiveNavLink() {
      let currentId = '';
      sections.forEach(section => {
        if (window.scrollY >= section.offsetTop - 120) currentId = '#' + section.id;
      });
      navLinks.forEach(link => {
        link.classList.toggle('nav-link-active', link.getAttribute('href') === currentId);
      });
    }

    window.addEventListener('scroll', updateActiveNavLink, { passive: true });
    updateActiveNavLink();
  }

  // ── Scroll Tracker & Navbar Shadow ───────────────────────────
  function initScrollEffects() {
    const scrollTracker = document.querySelector('.scroll-tracker');
    const navbar = document.querySelector('.landing-navbar');

    window.addEventListener('scroll', () => {
      const docHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      if (scrollTracker) scrollTracker.style.width = ((window.scrollY / docHeight) * 100) + '%';
      if (navbar) navbar.classList.toggle('scrolled', window.scrollY > 50);
    }, { passive: true });
  }

  // ── Impact Counter Animation ──────────────────────────────────
  function animateCounter(el) {
    const target = parseInt(el.dataset.target, 10);
    const duration = 2000;
    const steps = Math.ceil(duration / 16);
    const increment = target / steps;
    let current = 0;
    let step = 0;

    const timer = setInterval(() => {
      step++;
      current = Math.min(increment * step, target);
      if (target >= 1000000)      el.textContent = (current / 1000000).toFixed(1) + 'M+';
      else if (target >= 1000)    el.textContent = Math.round(current / 1000) + 'K+';
      else                        el.textContent = Math.round(current) + '+';
      if (step >= steps) clearInterval(timer);
    }, 16);
  }

  function initCounters() {
    const counterEls = document.querySelectorAll('.counter[data-target]');
    if (!counterEls.length) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !entry.target.dataset.animated) {
          entry.target.dataset.animated = 'true';
          animateCounter(entry.target);
        }
      });
    }, { threshold: 0.6 });

    counterEls.forEach(el => observer.observe(el));
  }

  // ── Boot ──────────────────────────────────────────────────────
  window.addEventListener('scroll', reveal, { passive: true });

  document.addEventListener('DOMContentLoaded', () => {
    reveal();
    initLandingNavbar();
    initActiveNavLinks();
    initScrollEffects();
    initCounters();
  });

  document.addEventListener('turbo:load', () => {
    initLandingNavbar();
    initActiveNavLinks();
    initScrollEffects();
    initCounters();
    reveal();
  });
</script>
